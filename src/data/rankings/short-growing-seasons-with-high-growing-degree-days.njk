{% include "components/external-source-links.njk" %}

<section class="card">
  <h2>Methodology</h2>
  <p>{{ board.methodology }}</p>
  <p>{{ board.caveat }}</p>
  <p class="small">
    Download: <a href="/assets/data/rankings/short-growing-seasons-with-high-growing-degree-days.json">short season, higher GDD JSON</a>.
  </p>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ board.title | dump | safe }},
  "description": {{ board.description | dump | safe }},
  "url": "https://growbydate.com/data/rankings/short-growing-seasons-with-high-growing-degree-days/",
  "numberOfItems": {{ board.entries.length }},
  "itemListElement": [
    {% for row in board.entries %}
      {
        "@type": "ListItem",
        "position": {{ row.rank }},
        "name": {{ (row.cityName ~ " short growing season high GDD") | dump | safe }},
        "url": {{ (site.url ~ row.url) | dump | safe }}
      }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
