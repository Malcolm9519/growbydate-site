        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Lightweight</strong></td>
          <td>Mild frost and insect protection</td>
          <td>Low to moderate</td>
          <td>High light transmission</td>
          <td>Frequent spring and fall use</td>
        </tr>

        <tr>
          <td><strong>Medium-weight</strong></td>
          <td>Typical vegetable-garden frost protection</td>
          <td>Moderate</td>
          <td>Moderate light reduction</td>
          <td>Best all-purpose category</td>
        </tr>

        <tr>
          <td><strong>Heavyweight</strong></td>
          <td>Colder frost events</td>
          <td>Higher</td>
          <td>Lower light transmission</td>
          <td>Emergency and short-duration protection</td>
        </tr>

        <tr>
