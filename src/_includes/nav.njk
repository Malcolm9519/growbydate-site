<div class="siteHeaderRow">
  <div class="brand">
    <h1>
      <a href="/" class="brandLink">
        <img
          src="/assets/img/GrowByDateLogo.png"
          alt="Grow By Date"
          class="brandLogo"
          width="220"
          height="60"
          loading="eager"
          decoding="async"
        />
      </a>
    </h1>
    <p class="tagline sr-only">Practical planning tools for short growing seasons.</p>
  </div>

  {# Desktop nav (pills) #}
  <nav class="siteNav siteNavDesktop" aria-label="Primary">
    <a href="/tools/seed-start-planner/" class="primaryLink">🌱Spring Last Frost Planner</a>
    <a href="/tools/growing-degree-day-planner/" class="primaryLink">🌻GDD Planner</a>
    <a href="/tools/first-frost-planner/" class="primaryLink">🍂Fall First Frost Planner</a>
    <a href="/tools/frost-date-finder/" class="primaryLink">❄️Frost Date Finder</a>

    <details class="navdrop">
      <summary>Tools</summary>
      <div class="navpanel">
        <a class="navall" href="/tools/">View all tools</a>
        <div class="navsep" aria-hidden="true"></div>
        {% for t in tools | sort(attribute="order") %}
          <a href="/tools/{{ t.slug }}/">{{ t.name }}</a>
        {% endfor %}
      </div>
    </details>

    {# No dropdowns for Guides/Crops to avoid nav inflation #}
    <a href="/guides/">Guides</a>
    <a href="/crops/">Crops</a>
  </nav>

  {# Mobile nav (hamburger) #}
  <nav class="siteNav siteNavMobile" aria-label="Primary">
    <details class="navdrop mobileMenu">
      <summary aria-label="Open menu">
        <span class="hamburger" aria-hidden="true"></span>
        Menu
      </summary>

      <div class="navpanel">
        <a href="/tools/">All tools</a>
        <a href="/guides/">All guides</a>
        <a href="/crops/">All crops</a>

        <div class="navsep" aria-hidden="true"></div>

        {# Optional: keep Tools list on mobile (remove if it grows too long) #}
        <p class="navlabel">Tools</p>
        {% for t in tools | sort(attribute="order") %}
          <a href="/tools/{{ t.slug }}/">{{ t.name }}</a>
        {% endfor %}
      </div>
    </details>
  </nav>
</div>