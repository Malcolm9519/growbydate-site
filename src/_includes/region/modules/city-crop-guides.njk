{% set cityCropLinks = [] %}

{% for item in (cropCitySummaries or []) %}
  {% if item.cityKey == city.key %}
    {% set cityCropLinks = cityCropLinks.concat([item]) %}
  {% endif %}
{% endfor %}

{% if cityCropLinks.length %}
<section class="card">
  <h2>Crop Guides for {{ city.name }}</h2>

  <p class="small" style="margin-top:-0.25rem; margin-bottom:0.85rem;">
    Explore published crop-specific planting guides for {{ city.name }}, ordered from best local fit to highest risk.
  </p>

  {% for confidence in ["strong", "good", "borderline", "risky"] %}
    {% set group = [] %}
    {% for item in cityCropLinks %}
      {% if item.confidence == confidence %}
        {% set group = group.concat([item]) %}
      {% endif %}
    {% endfor %}

    {% if group.length %}
      <div
        style="
          margin:{% if loop.first %}0.35rem{% else %}1rem{% endif %} 0 0.55rem 0;
          padding-top:{% if loop.first %}0{% else %}0.75rem{% endif %};
          border-top:{% if loop.first %}none{% else %}1px solid rgba(0,0,0,.08){% endif %};
        "
      >
        <p
          style="
            margin:0;
            font-size:0.78rem;
            font-weight:700;
            letter-spacing:0.06em;
            text-transform:uppercase;
            color:rgba(0,0,0,.68);
            line-height:1.2;
          "
        >
          {% if confidence == "strong" %}
            Strong fit
          {% elif confidence == "good" %}
            Good fit
          {% elif confidence == "borderline" %}
            Borderline
          {% elif confidence == "risky" %}
            Risky fit
          {% endif %}
        </p>
      </div>

<div class="city-crop-guides-grid">
        {% for item in group | sort(false, false, "cropName") %}
          {% set blurbOptions = item.fit.linkBlurbOptions or [] %}
          {% set rotatedBlurb = item.fit.summary %}
          {% if blurbOptions.length %}
            {% set rotatedBlurb = blurbOptions[loop.index0 % blurbOptions.length] %}
          {% endif %}

          <div style="border:1px solid rgba(0,0,0,.08); border-radius:12px; padding:0.65rem 0.8rem; background:rgba(255,255,255,.45);">
            <p class="small" style="margin:0 0 0.16rem 0; line-height:1.25;">
              <a href="{{ item.url }}" style="text-decoration:none;">
                <strong>{{ item.cropName }}</strong>
              </a>
            </p>

            <p class="small muted" style="margin:0; line-height:1.3;">
              {{ rotatedBlurb }}
            </p>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  {% endfor %}
</section>
{% endif %}