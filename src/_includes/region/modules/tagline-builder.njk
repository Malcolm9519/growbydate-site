{% macro buildTagline(state) %}

{% set openings = [
  "Plan your season with confidence in",
  "Understand what a typical year allows in",
  "Use this guide to plan planting and harvest in",
  "Get a realistic snapshot of the growing season in",
  "See how frost timing and heat shape gardening in"
] %}

{% set middlesCool = [
  "where shorter seasons reward careful timing.",
  "where frost often sets the pace.",
  "where fast-maturing crops matter most.",
  "where heat accumulation can be limited."
] %}

{% set middlesWarm = [
  "where longer seasons give gardeners more flexibility.",
  "where summer heat supports a wider planting window.",
  "where succession planting is often more realistic.",
  "where fall frost usually arrives later than in colder regions."
] %}

{% set seed = state.name | length %}

{% if state.gdd and state.gdd.medianRemaining and state.gdd.medianRemaining < 700 %}
  {% set middlePool = middlesCool %}
{% else %}
  {% set middlePool = middlesWarm %}
{% endif %}

{% set open = openings[seed % (openings | length)] %}
{% set mid = middlePool[seed % (middlePool | length)] %}

{{ open }} {{ state.name }}, {{ mid }}

{% endmacro %}