{# what-can-i-grow.njk — Crop viability matrix by typical remaining GDD checkpoints #}

<section class="card wcig">
  <h2>What Can You Usually Grow in {{ state.name }}?</h2>

  <style>
    .wcig .small { font-size: .95rem; }
    .wcig .muted { opacity: .75; }

    .wcig .wcigTableWrap {
      overflow-x: auto;
      margin-top: .75rem;
      border-radius: 12px;
      border: 1px solid rgba(0,0,0,0.12);
    }
    .wcig table {
      width: 100%;
      border-collapse: collapse;
      min-width: 760px;
      background: transparent;
    }
.wcig th, .wcig td {
  padding: .35rem .45rem;
      border-bottom: 1px solid rgba(0,0,0,0.08);
      vertical-align: middle;
    }
    .wcig th { text-align: left; font-weight: 700; }
    .wcig td { font-variant-numeric: tabular-nums; }

.wcig .wcigStatus{
  display: inline-block;
  border: none;
  border-radius: 0;
  width: auto;
  height: auto;
  padding: 0;
  background: transparent;
  line-height: 1;
  font-size: 1rem;
}

    .wcig .wcigLegend {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem 1rem;
      margin: .5rem 0 0;
    }
    .wcig .wcigLegend span { display: inline-flex; align-items: center; gap: .4rem; }

    .wcig .wcigMore { margin-top: .75rem; }

    .wcig .wcigCropLink { text-decoration: none; }
    .wcig .wcigCropLink:hover { text-decoration: underline; }

    .wcig .wcigMeta {
      margin-top: -.25rem;
      line-height: 1.45;

      .wcig td:first-child, .wcig th:first-child{
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 1px; /* enables ellipsis in table layouts */
}
    }

    .wcig td:not(:first-child):not(:nth-child(2)),
.wcig th:not(:first-child):not(:nth-child(2)){
  text-align: center;
}

.wcig .wcigCropEmoji { margin-right: .35rem; }
  </style>

  {% if not state.cropFit or not state.cropFit.byDate %}
    <p class="small">
      Crop-fit suggestions aren’t available for this region yet.
    </p>
  {% else %}

    {% set dates = state.cropFit.meta.dates or ["05-15", "06-01", "07-01", "08-01"] %}
    {% set marginPct = state.cropFit.meta.marginPct or 0.15 %}
    {% set marginLabel = (marginPct * 100) | round %}

    <p class="small wcigMeta">
      A normals-based guide to what typically has time to mature in {{ state.name }} by a few common planting checkpoints.
      We apply a <strong>{{ marginLabel }}% safety margin</strong> to separate “usually fits” from “borderline.”
    </p>

{% macro prettyMmdd(mmdd) %}
  {# mmdd is "MM-DD" #}
  {% set m = (mmdd[0] ~ mmdd[1]) %}
  {% set d = (mmdd[3] ~ mmdd[4]) | int %}

  {% if m == "01" %}Jan
  {% elseif m == "02" %}Feb
  {% elseif m == "03" %}Mar
  {% elseif m == "04" %}Apr
  {% elseif m == "05" %}May
  {% elseif m == "06" %}Jun
  {% elseif m == "07" %}Jul
  {% elseif m == "08" %}Aug
  {% elseif m == "09" %}Sep
  {% elseif m == "10" %}Oct
  {% elseif m == "11" %}Nov
  {% else %}Dec
  {% endif %}

  {{ " " ~ d }}
{% endmacro %}

    {# -------- EMOJI MAP (from original module) -------- #}
    {% set emojiMap = {
      "tomato":"🍅","tomatoes":"🍅",
      "pepper":"🫑","peppers":"🫑",
      "eggplant":"🍆",
      "cucumber":"🥒","zucchini":"🥒",
      "winter-squash":"🎃","squash":"🎃","pumpkin":"🎃",
      "corn-sweet":"🌽","corn":"🌽",
      "bean-bush":"🫘","beans":"🫘","bean":"🫘",
      "pea":"🟢","peas":"🟢",
      "carrot":"🥕","carrots":"🥕",
      "beet":"🟣","beets":"🟣",
      "potato":"🥔",
      "onion":"🧅","onions":"🧅",
      "garlic":"🧄",
      "broccoli":"🥦","cauliflower":"🥦",
      "cabbage":"🥬","lettuce":"🥬","kale":"🥬",
      "spinach":"🍃",
      "radish":"🌱","turnip":"🌱",
      "melon":"🍈","watermelon":"🍉",
      "strawberry":"🍓",
      "sunflower":"🌻",
      "basil":"🌿","herb":"🌿"
    } %}

    {# Derive a stable key for table crops: prefer c.slug, else last href segment #}
    {% macro cropKey(c) %}
      {% if c.slug %}
        {{ c.slug }}
      {% elseif c.href %}
        {% set parts = c.href.split("/") %}
        {% set last = "" %}
        {% for p in parts %}
          {% if p %}{% set last = p %}{% endif %}
        {% endfor %}
        {{ last }}
      {% else %}
        {{ "" }}
      {% endif %}
    {% endmacro %}

    {% macro getEmojiForCrop(c) %}
      {% set key = (cropKey(c) | trim) %}
      {% set name = (c.name or "") %}
      {% set lname = name | lower %}

      {% if key and emojiMap[key] %}
        {{ emojiMap[key] }}
      {% elseif ("bean" in key) or ("bean" in lname) %}
        🫘
      {% elseif ("pea" in key) or ("pea" in lname) %}
        🟢
      {% elseif emojiMap[lname] %}
        {{ emojiMap[lname] }}
      {% else %}
        {{ "" }}
      {% endif %}
    {% endmacro %}

    {# Build a unique crop list across all checkpoint dates #}
    {% set allCrops = [] %}
    {% set seen = "," %}
    {% for mmdd in dates %}
      {% set block = state.cropFit.byDate[mmdd] %}
      {% if block %}
        {% for c in (block.reliable or []) %}
          {% if c and c.href and (seen.indexOf("," ~ c.href ~ ",") == -1) %}
            {% set allCrops = allCrops.concat([c]) %}
            {% set seen = seen ~ c.href ~ "," %}
          {% endif %}
        {% endfor %}
        {% for c in (block.possible or []) %}
          {% if c and c.href and (seen.indexOf("," ~ c.href ~ ",") == -1) %}
            {% set allCrops = allCrops.concat([c]) %}
            {% set seen = seen ~ c.href ~ "," %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endfor %}

    {% set allCrops = allCrops | sort(attribute="gddRequired") %}

    {% macro statusFor(mmdd, href) %}
      {% set block = state.cropFit.byDate[mmdd] %}
      {% set s = "none" %}
      {% if block %}
        {% for x in (block.reliable or []) %}
          {% if x and x.href == href %}{% set s = "reliable" %}{% endif %}
        {% endfor %}
        {% if s == "none" %}
          {% for x in (block.possible or []) %}
            {% if x and x.href == href %}{% set s = "possible" %}{% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}
      {{ s }}
    {% endmacro %}

    {% macro renderStatus(mmdd, href) %}
      {% set s = (statusFor(mmdd, href) | trim) %}
      {% if s == "reliable" %}
        <span class="wcigStatus" title="Usually fits (with {{ marginLabel }}% safety margin).">✅</span>
      {% elseif s == "possible" %}
        <span class="wcigStatus" title="Borderline: can fit in normals, but doesn’t clear the {{ marginLabel }}% safety margin.">⚠️</span>
      {% else %}
        <span class="wcigStatus" title="Usually too tight by this checkpoint.">❌</span>
      {% endif %}
    {% endmacro %}

    <div class="wcigLegend small">
      <span><span class="wcigStatus" aria-hidden="true">✅</span> Usually fits</span>
      <span><span class="wcigStatus" aria-hidden="true">⚠️</span> Borderline</span>
      <span><span class="wcigStatus" aria-hidden="true">❌</span> Too tight</span>
    </div>

    <div class="wcigTableWrap" role="region" aria-label="Crop maturity fit table">
      <table>
        <thead>
          <tr>
<th style="min-width: 170px;">Crop</th>
            <th style="min-width: 120px;">Heat units</th>

            {% for mmdd in dates %}
              {% set block = state.cropFit.byDate[mmdd] %}
              <th style="min-width: 110px;">
                {{ prettyMmdd(mmdd) }}

                {% if block and block.runwayByBase and (block.runwayByBase["50"] is not none) %}
                  {% set runway = block.runwayByBase["50"] | int %}
                  {% set safe = (runway * (1 - marginPct)) | round %}
                  <div class="small muted" style="margin-top:.15rem;">
                    Base 50: {{ runway }} (safe {{ safe }})
                  </div>
                {% endif %}
              </th>
            {% endfor %}
          </tr>
        </thead>

        <tbody>
          {% if (allCrops | length) == 0 %}
            <tr>
              <td colspan="{{ 2 + (dates | length) }}" class="small muted">
                No crop-fit data found for this region.
              </td>
            </tr>
          {% else %}

            {# Keep the initial table compact; show the rest behind a details block #}
            {% set headLimit = 24 %}
            {% set headCrops = allCrops.slice(0, headLimit) %}
            {% set tailCrops = allCrops.slice(headLimit) %}

            {% for c in headCrops %}
              {# NOTE: your JS uses gddRequired; keep fallbacks for safety #}
              {% set gdd = c.gddRequired or c.gdd50 or c.gdd_required50 or c.gdd_required or c.gdd %}
              <tr>
                <td>
{% set e = getEmojiForCrop(c) | trim %}
<a class="wcigCropLink" href="{{ c.href }}" title="{{ c.name }}">
  {% if e %}<span class="wcigCropEmoji" aria-hidden="true">{{ e }}</span>{% endif %}
  {{ c.name }}
</a>
                </td>
                <td class="small">
                  {{ gdd | int }} <span class="muted">(base {{ c.base }})</span>
                </td>

                {% for mmdd in dates %}
                  <td>{{ renderStatus(mmdd, c.href) }}</td>
                {% endfor %}
              </tr>
            {% endfor %}

          {% endif %}
        </tbody>
      </table>
    </div>

    {% if tailCrops and (tailCrops | length) > 0 %}
      <details class="wcigMore">
        <summary class="small">Show {{ tailCrops | length }} more crops</summary>

        <div class="wcigTableWrap" style="margin-top:.6rem;">
          <table>
            <thead>
              <tr>
                <th style="min-width: 240px;">Crop</th>
                <th style="min-width: 120px;">Heat units</th>
                {% for mmdd in dates %}
                  <th style="min-width: 140px;">{{ prettyMmdd(mmdd) }}</th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for c in tailCrops %}
                {% set gdd = c.gddRequired or c.gdd50 or c.gdd_required50 or c.gdd_required or c.gdd %}
                <tr>
                  <td>
{% set e = getEmojiForCrop(c) | trim %}
<a class="wcigCropLink" href="{{ c.href }}" title="{{ c.name }}">
  {% if e %}<span class="wcigCropEmoji" aria-hidden="true">{{ e }}</span>{% endif %}
  {{ c.name }}
</a>
                  </td>
                  <td class="small">
                    {{ gdd | int }} <span class="muted">(base {{ c.base }})</span>
                  </td>
                  {% for mmdd in dates %}
                    <td>{{ renderStatus(mmdd, c.href) }}</td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </details>
    {% endif %}

    <p class="small muted" style="margin-top:.75rem;">
      Notes: “Usually fits” is based on typical remaining GDD and a {{ marginLabel }}% buffer.
      Microclimates, variety choice, and planting method can move results.
      For a specific location and planting date, use the crop timing calculator below.
    </p>

  {% endif %}

  
{% set gddWidget = {
  mode: "default",
  hideCrops: false,
  dateDefault: "today",
  widgetTitle: "Is It Too Late to Plant? Check Crop Timing in " ~ state.name,
  widgetLede: "Enter a ZIP / Postal Code in " ~ state.name ~ " and your planting date to see whether different crops can typically mature before first fall frost."
} %}
{% include "tools/gdd-planner-widget.njk" %}
</section>