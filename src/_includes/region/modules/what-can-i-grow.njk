{# what-can-i-grow.njk — collapsible sections + emojis (no bold section labels) #}

<section class="card wcig">
  <h2>What Can You Usually Grow in {{ state.name }}?</h2>

  <style>
    .wcig .wcigChips {
      display: flex;
      flex-wrap: wrap;
      gap: .35rem .45rem;
      line-height: 1.25;
    }
    .wcig .wcigChip {
      display: inline-flex;
      align-items: center;
      gap: .3rem;
      padding: .22rem .5rem;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.14);
      text-decoration: none;
      white-space: nowrap;
    }
    .wcig .wcigMore {
      display: inline-block;
      padding: .22rem .5rem;
      border-radius: 999px;
      border: 1px dashed rgba(0,0,0,0.22);
      opacity: .75;
      white-space: nowrap;
    }

    .wcig details.wcigDate {
      margin-top: 1rem;
      border: 1px solid rgba(0,0,0,0.12);
      border-radius: 14px;
      padding: .75rem .85rem;
      background: rgba(0,0,0,0.02);
    }

    .wcig details.wcigDate > summary {
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .wcig details.wcigDate > summary::-webkit-details-marker { display: none; }

    .wcig .wcigChevron {
      flex: 0 0 auto;
      width: 1.15rem;
      height: 1.15rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      border: 1px solid rgba(0,0,0,0.14);
      transition: transform .15s ease;
    }
    .wcig details.wcigDate[open] .wcigChevron {
      transform: rotate(180deg);
    }

    .wcig .wcigBody {
      margin-top: .75rem;
    }
  </style>

  {% if not state.cropFit or not state.cropFit.byDate %}
    <p class="small">
      Crop-fit suggestions aren’t available for this region yet.
    </p>
  {% else %}

    {% set may15 = state.cropFit.byDate["05-15"] %}
    {% set jun1  = state.cropFit.byDate["06-01"] %}
    {% set july  = state.cropFit.byDate["07-01"] %}
    {% set aug   = state.cropFit.byDate["08-01"] %}

    {% set marginLabel = (state.cropFit.meta.marginPct * 100) | round %}

    <p class="small muted" style="margin-top:-0.25rem;">
      A normals-based guide to what typically has time to finish in {{ state.name }}.
      We apply a <strong>{{ marginLabel }}% safety margin</strong>.
    </p>

    {# -------- EMOJI MAP -------- #}
    {% set emojiMap = {
      "tomato":"🍅","tomatoes":"🍅",
      "pepper":"🫑","peppers":"🫑",
      "eggplant":"🍆",
      "cucumber":"🥒","zucchini":"🥒",
      "winter-squash":"🎃","squash":"🎃","pumpkin":"🎃",
      "corn-sweet":"🌽","corn":"🌽",
      "bean-bush":"🫘","beans":"🫘","bean":"🫘",
      "pea":"🟢","peas":"🟢",
      "carrot":"🥕","carrots":"🥕",
      "beet":"🟣","beets":"🟣",
      "potato":"🥔",
      "onion":"🧅","onions":"🧅",
      "garlic":"🧄",
      "broccoli":"🥦","cauliflower":"🥦",
      "cabbage":"🥬","lettuce":"🥬","kale":"🥬",
      "spinach":"🍃",
      "radish":"🌱","turnip":"🌱",
      "melon":"🍈","watermelon":"🍉",
      "strawberry":"🍓",
      "sunflower":"🌻",
      "basil":"🌿","herb":"🌿"
    } %}

{% macro getEmoji(crop) %}
  {% set key = crop.key or "" %}
  {% set name = crop.name or "" %}

  {# Direct key match first #}
  {% if key and emojiMap[key] %}
    {{ emojiMap[key] }}

  {# Handle any bean variations #}
  {% elseif "bean" in key or "bean" in name | lower %}
    🫘

  {# Handle any pea variations #}
  {% elseif "pea" in key or "pea" in name | lower %}
    🟢

  {# Fallback to name match #}
  {% elseif emojiMap[name | lower] %}
    {{ emojiMap[name | lower] }}

  {% else %}
    {{ "" }}
  {% endif %}
{% endmacro %}

    {% macro cropLine(items, minBase, maxBase, limit) %}
      {% set shown = 0 %}
      {% set total = 0 %}

      {% for c in items %}
        {% if c and c.href and c.base >= minBase and c.base <= maxBase %}
          {% set total = total + 1 %}
        {% endif %}
      {% endfor %}

      {% if total == 0 %}
        <span class="muted">—</span>
      {% else %}
        <div class="wcigChips small">
          {% for c in items %}
            {% if shown < limit and c and c.href and c.base >= minBase and c.base <= maxBase %}
              <a class="wcigChip" href="{{ c.href }}">
                <span>{{ getEmoji(c) }}</span>
                <span>{{ c.name }}</span>
              </a>
              {% set shown = shown + 1 %}
            {% endif %}
          {% endfor %}

          {% if total > shown %}
            <span class="wcigMore">+{{ total - shown }} more</span>
          {% endif %}
        </div>
      {% endif %}
    {% endmacro %}

    {% macro monthTable(title, data) %}
      {% if data %}
        <div class="tableWrap">
          <table class="table">
            <thead>
              <tr>
                <th colspan="2" style="text-align:center;">
                  {{ title }}
                </th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td colspan="2">Warm-Season</td>
              </tr>
              <tr>
                <td style="width:28%;">What Works Best:</td>
                <td>{{ cropLine(data.reliable or [], 50, 50, 10) }}</td>
              </tr>
              <tr>
                <td>Might Be Possible:</td>
                <td>{{ cropLine(data.possible or [], 50, 50, 10) }}</td>
              </tr>

              <tr>
                <td colspan="2" style="padding-top:0.75rem;">
                  Cool-Season
                </td>
              </tr>
              <tr>
                <td>What Works Best:</td>
                <td>{{ cropLine(data.reliable or [], 40, 45, 12) }}</td>
              </tr>
              <tr>
                <td>Might Be Possible:</td>
                <td>{{ cropLine(data.possible or [], 40, 45, 12) }}</td>
              </tr>
            </tbody>
          </table>
        </div>
      {% endif %}
    {% endmacro %}

    <details class="wcigDate">
      <summary>
        <strong>May 15</strong>
        <span class="wcigChevron">
          <svg viewBox="0 0 20 20" width="14" height="14">
            <path d="M5.5 7.5 L10 12 L14.5 7.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
          </svg>
        </span>
      </summary>
      <div class="wcigBody">
        {{ monthTable(state.name ~ " Spring: May 15", may15) }}
      </div>
    </details>

    <details class="wcigDate">
      <summary>
        <strong>June 1</strong>
        <span class="wcigChevron">
          <svg viewBox="0 0 20 20" width="14" height="14">
            <path d="M5.5 7.5 L10 12 L14.5 7.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
          </svg>
        </span>
      </summary>
      <div class="wcigBody">
        {{ monthTable(state.name ~ " Early Summer: June 1", jun1) }}
      </div>
    </details>

    <details class="wcigDate">
      <summary>
        <strong>July 1</strong>
        <span class="wcigChevron">
          <svg viewBox="0 0 20 20" width="14" height="14">
            <path d="M5.5 7.5 L10 12 L14.5 7.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
          </svg>
        </span>
      </summary>
      <div class="wcigBody">
        {{ monthTable(state.name ~ " Summer: July 1", july) }}
      </div>
    </details>

    <details class="wcigDate">
      <summary>
        <strong>August 1</strong>
        <span class="wcigChevron">
          <svg viewBox="0 0 20 20" width="14" height="14">
            <path d="M5.5 7.5 L10 12 L14.5 7.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
          </svg>
        </span>
      </summary>
      <div class="wcigBody">
        {{ monthTable(state.name ~ " Late Summer: August 1", aug) }}
      </div>
    </details>

  {% endif %}
</section>