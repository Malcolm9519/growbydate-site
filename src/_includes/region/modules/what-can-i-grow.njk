{# what-can-i-grow.njk — Crop viability matrix by typical remaining GDD checkpoints #}
<section class="card">

<div class="wcig">
  <h2>Missed Your Planting Window? What Can You Still Grow?</h2>

  {% if not state.cropFit or not state.cropFit.byDate %}
    <p class="small">
      Crop-fit suggestions aren’t available for this region yet.
    </p>
  {% else %}

    {% set preferredDates = ["05-15", "06-01", "07-01", "08-01"] %}
    {% set allDates = state.cropFit.meta.dates or [] %}
    {% set dates = [] %}

    {% for d in preferredDates %}
      {% if d in allDates %}
        {% set dates = dates.concat([d]) %}
      {% endif %}
    {% endfor %}

    {% if not dates.length %}
      {% set dates = ["05-15", "06-01", "07-01", "08-01"] %}
    {% endif %}

    {% set marginPct = state.cropFit.meta.marginPct or 0.15 %}
    {% set marginLabel = (marginPct * 100) | round %}

    <p class="small wcigMeta">
      If you're starting later in the season, use this normals-based guide to what typically still has time to mature in {{ state.name }} at a few common planting checkpoints.
      We apply a <strong>{{ marginLabel }}% safety margin</strong> to separate crops that usually fit from ones that are more borderline.
    </p>

    {% macro prettyMmdd(mmdd) %}
      {% set m = (mmdd[0] ~ mmdd[1]) %}
      {% set d = (mmdd[3] ~ mmdd[4]) | int %}

      {% if m == "01" %}Jan
      {% elseif m == "02" %}Feb
      {% elseif m == "03" %}Mar
      {% elseif m == "04" %}Apr
      {% elseif m == "05" %}May
      {% elseif m == "06" %}Jun
      {% elseif m == "07" %}Jul
      {% elseif m == "08" %}Aug
      {% elseif m == "09" %}Sep
      {% elseif m == "10" %}Oct
      {% elseif m == "11" %}Nov
      {% else %}Dec
      {% endif %}

      {{ " " ~ d }}
    {% endmacro %}

    {% set emojiMap = {
      "tomato":"🍅","tomatoes":"🍅",
      "pepper":"🫑","peppers":"🫑",
      "eggplant":"🍆",
      "cucumber":"🥒","zucchini":"🥒","cucumbers":"🥒",
      "winter-squash":"🎃","squash":"🎃","pumpkin":"🎃",
      "sweet-corn":"🌽","corn":"🌽","sweet corn":"🌽",
      "bean-bush":"🫘","beans":"🫘","bean":"🫘",
      "pea":"🟢","peas":"🟢",
      "carrot":"🥕","carrots":"🥕",
      "beet":"🟣","beets":"🟣",
      "potatoes":"🥔",
      "potato":"🥔",
      "onion":"🧅","onions":"🧅",
      "garlic":"🧄",
      "broccoli":"🥦",
      "cauliflower":"🥦",
      "cabbage":"🥬",
      "lettuce":"🥬",
      "kale":"🥬",
      "spinach":"🥬",
      "swiss-chard":"🥬",
      "radish":"⭕","radishes":"⭕"
    } %}

    {% macro getEmojiForCrop(c) %}
      {% set key = (c.slug or c.key or "") | lower %}
      {% set lname = (c.name or "") | lower %}

      {% if key and emojiMap[key] %}
        {{ emojiMap[key] }}
      {% elseif ("bean" in key) or ("bean" in lname) %}
        🫘
      {% elseif ("pea" in key) or ("pea" in lname) %}
        🟢
      {% elseif emojiMap[lname] %}
        {{ emojiMap[lname] }}
      {% else %}
        {{ "" }}
      {% endif %}
    {% endmacro %}

    {% set activeCity = city or null %}
    {% set isCityPage = activeCity and activeCity.key %}
    {% set allCrops = [] %}
    {% set seen = "," %}

{# City pages: use crop-city rows for coverage/links, but borrow canonical keys from cropFit catalog #}
{% if isCityPage %}
  {% for item in (cropCitySummaries or []) %}
    {% if item.cityKey == activeCity.key %}
      {% set rowHref = item.url %}
      {% if rowHref and (seen.indexOf("," ~ rowHref ~ ",") == -1) %}

        {% set cropBase = 50 %}
        {% if item.gdd and item.gdd.base %}
          {% set cropBase = item.gdd.base %}
        {% endif %}

        {% set cropReq = item.targetGdd or 0 %}
        {% if not cropReq and item.gdd and item.gdd.required %}
          {% set cropReq = item.gdd.required %}
        {% endif %}

        {# default to raw city key, then replace with canonical catalog key if we find a match #}
        {% set canonicalSlug = item.cropKey %}
        {% set canonicalKey = item.cropKey %}

        {% for c in (state.cropFit.meta.catalog or []) %}
          {% if c %}
            {% set catalogName = (c.name or "") | lower | trim %}
            {% set itemName = (item.cropName or "") | lower | trim %}
            {% set catalogSlug = (c.slug or c.key or "") | lower | trim %}
            {% set itemKey = (item.cropKey or "") | lower | trim %}

            {% if catalogName == itemName or catalogSlug == itemKey %}
              {% set canonicalSlug = c.slug or c.key or canonicalSlug %}
              {% set canonicalKey = c.key or c.slug or canonicalKey %}
            {% endif %}
          {% endif %}
        {% endfor %}

        {% set allCrops = allCrops.concat([{
          "slug": canonicalSlug,
          "key": canonicalKey,
          "name": item.cropName,
          "href": rowHref,
          "base": cropBase,
          "gddRequired": cropReq
        }]) %}
        {% set seen = seen ~ rowHref ~ "," %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% elseif state.cropFit.meta and state.cropFit.meta.catalog %}
  {% for c in (state.cropFit.meta.catalog or []) %}
    {% if c and c.href and (seen.indexOf("," ~ c.href ~ ",") == -1) %}
      {% set allCrops = allCrops.concat([c]) %}
      {% set seen = seen ~ c.href ~ "," %}
    {% endif %}
  {% endfor %}
{% else %}
  {# Fallback: original behavior #}
  {% for mmdd in dates %}
    {% set block = state.cropFit.byDate[mmdd] %}
    {% if block %}
      {% for c in (block.reliable or []) %}
        {% if c and c.href and (seen.indexOf("," ~ c.href ~ ",") == -1) %}
          {% set allCrops = allCrops.concat([c]) %}
          {% set seen = seen ~ c.href ~ "," %}
        {% endif %}
      {% endfor %}
      {% for c in (block.possible or []) %}
        {% if c and c.href and (seen.indexOf("," ~ c.href ~ ",") == -1) %}
          {% set allCrops = allCrops.concat([c]) %}
          {% set seen = seen ~ c.href ~ "," %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}
{% endif %}

    {% set allCrops = allCrops | sort(attribute="gddRequired") %}

    {% macro statusFor(mmdd, cropItem) %}
      {% set block = state.cropFit.byDate[mmdd] %}
      {% set targetHref = cropItem.href or "" %}
      {% set targetSlug = cropItem.slug or cropItem.key or "" %}
      {% set s = "none" %}

      {% if block %}
        {% for x in (block.reliable or []) %}
          {% set xSlug = x.slug or x.key or "" %}
          {% if x and ((targetHref and x.href == targetHref) or (targetSlug and xSlug == targetSlug)) %}
            {% set s = "reliable" %}
          {% endif %}
        {% endfor %}

        {% if s == "none" %}
          {% for x in (block.possible or []) %}
            {% set xSlug = x.slug or x.key or "" %}
            {% if x and ((targetHref and x.href == targetHref) or (targetSlug and xSlug == targetSlug)) %}
              {% set s = "possible" %}
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endif %}

      {{ s }}
    {% endmacro %}

    {% macro renderStatus(mmdd, cropItem) %}
      {% set s = (statusFor(mmdd, cropItem) | trim) %}
      {% if s == "reliable" %}
        <span class="wcigStatus" title="Usually fits (with {{ marginLabel }}% safety margin).">✅</span>
      {% elseif s == "possible" %}
        <span class="wcigStatus" title="Borderline: can fit in normals, but doesn’t clear the {{ marginLabel }}% safety margin.">⚠️</span>
      {% else %}
        <span class="wcigStatus" title="Usually too tight by this checkpoint.">❌</span>
      {% endif %}
    {% endmacro %}

    <div class="wcigLegend small">
      <span><span class="wcigStatus" aria-hidden="true">✅</span> Usually fits</span>
      <span><span class="wcigStatus" aria-hidden="true">⚠️</span> Borderline</span>
      <span><span class="wcigStatus" aria-hidden="true">❌</span> Too tight</span>
    </div>

    <div class="wcigTableWrap">
      <table>
        <thead>
          <tr>
            <th style="min-width: 170px;">Crop</th>
            <th style="min-width: 120px;">Heat Units</th>

            {% for mmdd in dates %}
              <th style="min-width: 110px;">
                {{ prettyMmdd(mmdd) }}
              </th>
            {% endfor %}
          </tr>
        </thead>

        <tbody>
          {% if (allCrops | length) == 0 %}
            <tr>
              <td colspan="{{ 2 + (dates | length) }}" class="small muted">
                No crop-fit data found for this region.
              </td>
            </tr>
          {% else %}

            {% set headLimit = 24 %}
            {% set headCrops = allCrops.slice(0, headLimit) %}
            {% set tailCrops = allCrops.slice(headLimit) %}

            {% for c in headCrops %}
              {% set gdd = c.gddRequired or c.gdd50 or c.gdd_required50 or c.gdd_required or c.gdd %}
              <tr>
                <td>
                  {% set e = getEmojiForCrop(c) | trim %}
                  <span title="{{ c.name }}">
                    {% if e %}<span class="wcigCropEmoji" aria-hidden="true">{{ e }}</span>{% endif %}
                    {{ c.name }}
                  </span>
                </td>
                <td class="small">
                  {{ gdd | int }} <span class="muted">(base {{ c.base }})</span>
                </td>

                {% for mmdd in dates %}
                  <td>{{ renderStatus(mmdd, c) }}</td>
                {% endfor %}
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>

    {% if tailCrops and (tailCrops | length) > 0 %}
      <details class="wcigMore">
        <summary class="small">Show {{ tailCrops | length }} more crops</summary>

        <div class="wcigTableWrap">
          <table>
            <thead>
              <tr>
                <th style="min-width: 170px;">Crop</th>
                <th style="min-width: 120px;">Heat Units</th>

                {% for mmdd in dates %}
                  <th style="min-width: 110px;">{{ prettyMmdd(mmdd) }}</th>
                {% endfor %}
              </tr>
            </thead>

            <tbody>
              {% for c in tailCrops %}
                {% set gdd = c.gddRequired or c.gdd50 or c.gdd_required50 or c.gdd_required or c.gdd %}
                <tr>
                  <td>
                    {% set e = getEmojiForCrop(c) | trim %}
                    <span title="{{ c.name }}">
                      {% if e %}<span class="wcigCropEmoji" aria-hidden="true">{{ e }}</span>{% endif %}
                      {{ c.name }}
                    </span>
                  </td>
                  <td class="small">
                    {{ gdd | int }} <span class="muted">(base {{ c.base }})</span>
                  </td>

                  {% for mmdd in dates %}
                    <td>{{ renderStatus(mmdd, c) }}</td>
                  {% endfor %}
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </details>
    {% endif %}

  {% endif %}
</div>
</section>