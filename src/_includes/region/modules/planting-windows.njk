  <h2>{{ state.name }} Spring Planting Windows</h2>

  <p class="small" style="margin-top:-0.25rem;">
    A practical guide to when planting usually works in {{ state.name }}. These windows are based on climate normals (not a forecast) and line up with the
    <strong>50% last spring frost</strong> and typical early-season heat.
  </p>

  {% set activeCity = city or null %}
  {% set isCityPage = activeCity and activeCity.key %}
  {% set windows = [] %}

  {% set cropSlugsByKey = {
    "broccoli": "broccoli",
    "kale": "kale",
    "spinach": "spinach",
    "tomatoes": "tomatoes",
    "peppers": "peppers",
    "lettuce": "lettuce",
    "cabbage": "cabbage",
    "beans": "beans",
    "cucumbers": "cucumbers",
    "zucchini": "zucchini",
    "carrots": "carrots",
    "beets": "beets",
    "radishes": "radishes",
    "onions": "onions",
    "swiss-chard": "swiss-chard",
    "cauliflower": "cauliflower",
    "peas": "peas",
    "garlic": "garlic",
    "pumpkin": "pumpkin",
    "corn": "corn-sweet",
    "sweet-corn": "corn-sweet",
    "squash": "winter-squash",
    "winter-squash": "winter-squash",
    "potatoes": "potato"
  } %}

  {% set cropKeyByLabel = {
    "Tomatoes": "tomatoes",
    "Peppers": "peppers",
    "Cucumbers": "cucumbers",
    "Zucchini": "zucchini",
    "Squash": "squash",
    "Winter squash": "winter-squash",
    "Pumpkin": "pumpkin",
    "Pumpkins": "pumpkin",
    "Sweet corn": "corn",
    "Corn": "corn",
    "Beans": "beans",
    "Peas": "peas",
    "Carrots": "carrots",
    "Beets": "beets",
    "Potatoes": "potatoes",
    "Onions": "onions",
    "Garlic": "garlic",
    "Broccoli": "broccoli",
    "Cauliflower": "cauliflower",
    "Cabbage": "cabbage",
    "Lettuce": "lettuce",
    "Kale": "kale",
    "Spinach": "spinach",
    "Radishes": "radishes",
    "Swiss chard": "swiss-chard"
  } %}

  {% set coolKeys = [
    "peas", "spinach", "lettuce", "carrots", "beets", "radishes",
    "onions", "garlic", "broccoli", "cauliflower", "cabbage", "kale",
    "swiss-chard", "potatoes"
  ] %}

  {% set warmKeys = [
    "beans", "corn", "sweet-corn", "cucumbers", "zucchini",
    "squash", "winter-squash", "pumpkin", "tomatoes", "peppers"
  ] %}

  {% macro confidenceLabel(confidence) %}
    {% if confidence == "strong" %}
      Strong fit
    {% elif confidence == "good" %}
      Good fit
    {% elif confidence == "borderline" %}
      Borderline
    {% elif confidence == "risky" %}
      Risky fit
    {% else %}
      —
    {% endif %}
  {% endmacro %}

{# City pages: use crop-city summaries for links/confidence, but pull real ranges from city planting windows when available #}
{% if isCityPage %}
  {% set plantingWindowKeyMap = {
    "sweet-corn": "corn-sweet",
    "corn-sweet": "corn-sweet",
    "winter-squash": "squash",
    "pumpkin": "squash",
    "zucchini": "cucumbers"
  } %}

  {% for item in (cropCitySummaries or []) %}
    {% if item.cityKey == activeCity.key %}
      {% set cropKey = item.cropKey %}
      {% set planting = item.planting or {} %}
      {% set sourceWindows = item.plantingWindows or [] %}

      {% set lookupKey = cropKey %}
      {% if plantingWindowKeyMap[lookupKey] %}
        {% set lookupKey = plantingWindowKeyMap[lookupKey] %}
      {% endif %}

      {% set matchedWindow = null %}
      {% for pw in sourceWindows %}
        {% if pw.key == lookupKey %}
          {% set matchedWindow = pw %}
        {% endif %}
      {% endfor %}

      {% set start = null %}
      {% set end = null %}
      {% set method = "—" %}

      {% if matchedWindow %}
        {% set start = matchedWindow.start or null %}
        {% set end = matchedWindow.end or null %}
        {% set method = matchedWindow.method or "—" %}
      {% else %}
        {# Fallback only if there is no city planting-window row #}
        {% set start = planting.primaryPlantingDate or item.primaryPlantingDate or planting.plantOutDate or planting.directSowDate or planting.startIndoorsDate or null %}
        {% set end = null %}

        {% if planting.plantOutDate %}
          {% set method = "Transplant outside" %}
        {% elif planting.directSowDate %}
          {% set method = "Direct sow" %}
        {% elif planting.startIndoorsDate %}
          {% set method = "Start indoors" %}
        {% endif %}
      {% endif %}

      {% set windows = windows.concat([{
        "label": item.cropName,
        "key": cropKey,
        "cropKey": cropKey,
        "start": start,
        "end": end,
        "method": method,
        "href": item.url,
        "confidence": item.confidence
      }]) %}
    {% endif %}
  {% endfor %}

  {% set windows = windows | sort(false, false, "start") %}
{% else %}
  {# State/province pages stay on the existing generic list #}
  {% set windows = state.plantingWindows or [] %}
{% endif %}

  {% if windows.length %}
    {% set coolWindows = [] %}
    {% set warmWindows = [] %}
    {% set otherWindows = [] %}

    {% for w in windows %}
      {% set rawLabel = (w.label or "") | trim %}
      {% set cropKey = w.key or w.cropKey or cropKeyByLabel[rawLabel] %}

      {% if cropKey in coolKeys %}
        {% set coolWindows = coolWindows.concat([w]) %}
      {% elif cropKey in warmKeys %}
        {% set warmWindows = warmWindows.concat([w]) %}
      {% else %}
        {% set otherWindows = otherWindows.concat([w]) %}
      {% endif %}
    {% endfor %}

    <div class="tableWrap plantingWindowsWrap">
<table class="table plantingWindowsTable{% if isCityPage %} plantingWindowsTableCity{% endif %}">
        <tbody>
          {% if coolWindows.length %}
            <tr class="plantWindowSectionRow">
<td colspan="{{ isCityPage and 4 or 3 }}">
                <strong>Cool-season / early window</strong>
                <span class="plantWindowSectionHint">
                  Cold-tolerant crops that usually handle cooler spring conditions better.
                </span>
              </td>
            </tr>

            {% for w in coolWindows %}
              {% set rawLabel = (w.label or "") | trim %}
              {% set cropKey = w.key or w.cropKey or cropKeyByLabel[rawLabel] %}
              {% set cropSlug = cropKey and cropSlugsByKey[cropKey] %}
              {% set rowHref = w.href or (cropSlug and "/crops/" ~ cropSlug ~ "/") or null %}

              <tr class="plantWindowCropRow plantWindowCropRowCool">
                <td class="plantWindowCropCell">
                  <strong>
                    {% if rowHref %}
                      <a href="{{ rowHref }}">{{ w.label }}</a>
                    {% else %}
                      {{ w.label }}
                    {% endif %}
                  </strong>
                </td>
                <td>
                  {% if w.start and w.end %}
                    {{ w.start | mmddLong }} – {{ w.end | mmddLong }}
                  {% elseif w.start %}
                    {{ w.start | mmddLong }}
                  {% else %}
                    —
                  {% endif %}
                </td>
                <td>
                  <span class="plantMethodTag">{{ w.method or "—" }}</span>
                </td>
{% if isCityPage %}
  <td>
    {% if w.confidence %}
      <span class="fitBadge fitBadge-{{ w.confidence }}">
        {{ confidenceLabel(w.confidence) | trim }}
      </span>
    {% else %}
      —
    {% endif %}
  </td>
{% endif %}
              </tr>
            {% endfor %}
          {% endif %}

          {% if warmWindows.length %}
            <tr class="plantWindowSectionRow">
<td colspan="{{ isCityPage and 4 or 3 }}">
                <strong>Main warm-season window</strong>
                <span class="plantWindowSectionHint">
                  Crops that usually do best once frost risk fades and the season starts opening up more fully.
                </span>
              </td>
            </tr>

            {% for w in warmWindows %}
              {% set rawLabel = (w.label or "") | trim %}
              {% set cropKey = w.key or w.cropKey or cropKeyByLabel[rawLabel] %}
              {% set cropSlug = cropKey and cropSlugsByKey[cropKey] %}
              {% set rowHref = w.href or (cropSlug and "/crops/" ~ cropSlug ~ "/") or null %}

              <tr class="plantWindowCropRow plantWindowCropRowWarm">
                <td class="plantWindowCropCell">
                  <strong>
                    {% if rowHref %}
                      <a href="{{ rowHref }}">{{ w.label }}</a>
                    {% else %}
                      {{ w.label }}
                    {% endif %}
                  </strong>
                </td>
                <td>
                  {% if w.start and w.end %}
                    {{ w.start | mmddLong }} – {{ w.end | mmddLong }}
                  {% elseif w.start %}
                    {{ w.start | mmddLong }}
                  {% else %}
                    —
                  {% endif %}
                </td>
                <td>
                  <span class="plantMethodTag">{{ w.method or "—" }}</span>
                </td>
{% if isCityPage %}
  <td>
    {% if w.confidence %}
      <span class="fitBadge fitBadge-{{ w.confidence }}">
        {{ confidenceLabel(w.confidence) | trim }}
      </span>
    {% else %}
      —
    {% endif %}
  </td>
{% endif %}
              </tr>
            {% endfor %}
          {% endif %}

          {% if otherWindows.length %}
            <tr class="plantWindowSectionRow">
<td colspan="{{ isCityPage and 4 or 3 }}">
                <strong>Other crops</strong>
              </td>
            </tr>

            {% for w in otherWindows %}
              {% set rawLabel = (w.label or "") | trim %}
              {% set cropKey = w.key or w.cropKey or cropKeyByLabel[rawLabel] %}
              {% set cropSlug = cropKey and cropSlugsByKey[cropKey] %}
              {% set rowHref = w.href or (cropSlug and "/crops/" ~ cropSlug ~ "/") or null %}

              <tr class="plantWindowCropRow">
                <td class="plantWindowCropCell">
                  <strong>
                    {% if rowHref %}
                      <a href="{{ rowHref }}">{{ w.label }}</a>
                    {% else %}
                      {{ w.label }}
                    {% endif %}
                  </strong>
                </td>
                <td>
                  {% if w.start and w.end %}
                    {{ w.start | mmddLong }} – {{ w.end | mmddLong }}
                  {% elseif w.start %}
                    {{ w.start | mmddLong }}
                  {% else %}
                    —
                  {% endif %}
                </td>
                <td>
                  <span class="plantMethodTag">{{ w.method or "—" }}</span>
                </td>
{% if isCityPage %}
  <td>
    {% if w.confidence %}
      <span class="fitBadge fitBadge-{{ w.confidence }}">
        {{ confidenceLabel(w.confidence) | trim }}
      </span>
    {% else %}
      —
    {% endif %}
  </td>
{% endif %}
              </tr>
            {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>

    <div class="small muted plantingWindowsNote">
      <p>
        <strong>How to use this:</strong> aim for the earlier part of each window for the most reliable results. Later planting can still work, but it usually depends more on variety maturity, warmer microclimates, and simple protection like row cover or low tunnels.
      </p>
    </div>
  {% else %}
    <p class="small">
      Planting window guidance isn’t available for this region yet.
    </p>
  {% endif %}
</section>