  <h2 id="source-links-{{ sourceLinkId }}">{{ sourceLinkHeading }}</h2>
  <p>{{ sourceLinkIntro }}</p>

  {% if sourceLinkVariant == "us-climate" %}
    <ul class="tight sourceLinkList">
