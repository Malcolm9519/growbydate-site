{% set sourceLinkVariant = sourceLinksVariant or "climate-data" %}
{% set sourceLinkId = sourceLinksId or sourceLinkVariant %}
{% set sourceLinkHeading = sourceLinksHeading or "Sources and limits" %}
{% set sourceLinkIntro = sourceLinksIntro or "GrowByDate uses public climate references, crop-planning assumptions, and garden-specific interpretation to turn long-term averages into practical planning guidance." %}

