{% set localGuideCards = cropRelatedGuides.localByCrop[crop.key] or cropRelatedGuides.localDefault %}

<section class="card index-card relatedGuides">
  <h2>Related Crops and Guides</h2>

  {% if crop.relatedCrops and crop.relatedCrops.length %}
    <h3>Related crops</h3>
    <ul class="index-list">
      {% for key in crop.relatedCrops %}
        {% set relatedCropName = key | replace("-", " ") | title %}
        <li class="index-item">
          <a class="index-link" href="/planting-dates/{% if pageData.country == 'canada' %}canada/{% endif %}{{ pageData.regionKey }}/{{ pageData.cityKey }}/{{ key }}/">
            <strong>{{ relatedCropName }} in {{ pageData.cityName }}</strong>
          </a>
          <div class="small index-desc">
            Compare local planting timing, frost margin, and season fit for another crop in the same city.
          </div>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if localGuideCards and localGuideCards.length %}
    <h3>Related guides</h3>
    <ul class="index-list">
      {% for guide in localGuideCards %}
        <li class="index-item">
          <a class="index-link" href="{{ guide.url | toMainSiteUrl }}">
            <strong>{{ guide.title }}</strong>
          </a>
          {% if guide.note %}
            <div class="small index-desc">{{ guide.note }}</div>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</section>
