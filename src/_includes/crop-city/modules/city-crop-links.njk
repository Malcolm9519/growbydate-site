{% set cityCropLinks = [] %}

{% for item in (cropCitySummaries or []) %}
  {% if item.cityKey == pageData.cityKey and item.cropKey != pageData.cropKey %}
    {% set cityCropLinks = cityCropLinks.concat([item]) %}
  {% endif %}
{% endfor %}

{% if cityCropLinks.length %}
<section class="card">
  <h2>More Crop Guides for {{ pageData.cityName }}</h2>

  <p class="small" style="margin-top:-0.25rem;">
    Compare how other crops fit the same local season.
  </p>

  <div style="margin-top:0.85rem;">
    {% for item in cityCropLinks %}
      {% set blurbOptions = item.fit.linkBlurbOptions or [] %}
      {% set rotatedBlurb = item.fit.summary %}
      {% if blurbOptions.length %}
        {% set rotatedBlurb = blurbOptions[loop.index0 % blurbOptions.length] %}
      {% endif %}

      <p class="small" style="margin:0 0 0.6rem 0;">
        <a href="{{ item.url }}"><strong>{{ item.cropName }}</strong></a>
        — {{ rotatedBlurb }}
      </p>
    {% endfor %}
  </div>
</section>
{% endif %}