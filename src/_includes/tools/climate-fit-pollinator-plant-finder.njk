    { common: "Sunflower", botanical: "Helianthus annuus", type: "annual", zMin: 2, zMax: 11, sun: ["full"], moisture: ["dry", "average"], hMin: 36, hMax: 120, bloom: ["summer", "late-summer"], goals: ["bees", "butterflies", "drought"], deer: false, notes: "Annual; supports bees and birds if seedheads remain." },
    { common: "Purple prairie clover", botanical: "Dalea purpurea", type: "perennial", zMin: 3, zMax: 8, sun: ["full"], moisture: ["dry"], hMin: 12, hMax: 30, bloom: ["summer"], goals: ["bees", "front-yard", "drought"], deer: true, notes: "Compact and drought-adapted." },
    { common: "Golden alexanders", botanical: "Zizia aurea", type: "perennial", zMin: 3, zMax: 8, sun: ["full", "part"], moisture: ["average", "moist"], hMin: 18, hMax: 36, bloom: ["spring", "early-summer"], goals: ["bees", "butterflies", "front-yard", "rain-garden"], deer: false, notes: "Early umbel; useful in layered plantings." },
    { common: "Obedient plant", botanical: "Physostegia virginiana", type: "perennial", zMin: 3, zMax: 9, sun: ["full", "part"], moisture: ["average", "moist"], hMin: 24, hMax: 48, bloom: ["late-summer", "fall"], goals: ["bees", "hummingbirds", "rain-garden"], deer: true, notes: "Can spread; good late bloom." },
    { common: "Blue giant hyssop", botanical: "Agastache foeniculum", type: "perennial", zMin: 4, zMax: 8, sun: ["full"], moisture: ["dry", "average"], hMin: 24, hMax: 48, bloom: ["summer", "late-summer"], goals: ["bees", "butterflies", "hummingbirds", "drought"], deer: true, notes: "Strong nectar plant, aromatic leaves." }
  ];

  let lastMatches = [];

  function labelJoin(values) {
    return values.map((v) => v.replace("early-summer", "early summer").replace("late-summer", "late summer")).join(", ");
  }

  function pill(label, cls) {
    return '<span class="gbd-pill ' + cls + '">' + label + '</span>';
  }

  function scorePlant(plant, filters) {
    let score = 0;
    let hardFail = false;
    const reasons = [];

    if (filters.zone >= plant.zMin && filters.zone <= plant.zMax) {
      score += 32;
      if (filters.zone > plant.zMin) score += 5;
    } else {
      score -= 60;
      hardFail = true;
      reasons.push("outside listed zone range");
    }

    if (filters.sun === "any" || plant.sun.includes(filters.sun)) score += 18;
    else { score -= 18; reasons.push("sun mismatch"); }

    if (filters.moisture === "any" || plant.moisture.includes(filters.moisture)) score += 18;
    else { score -= 18; reasons.push("moisture mismatch"); }

    if (plant.hMax <= filters.height) score += 12;
    else { score -= 10; reasons.push("too tall"); }

    if (filters.bloom === "any" || plant.bloom.includes(filters.bloom)) score += 10;
    else score -= 4;

    if (filters.goal === "any" || plant.goals.includes(filters.goal)) score += 16;
    else score -= 2;

    if (filters.deer === "strict-resistant" && !plant.deer) { score -= 25; reasons.push("not a deer-resistance candidate"); }
    if (filters.deer === "prefer-resistant" && plant.deer) score += 8;
    if (filters.deer === "prefer-resistant" && !plant.deer) score -= 3;

    if (filters.type !== "any" && plant.type !== filters.type) { score -= 20; reasons.push("type mismatch"); }
    if (filters.type === plant.type) score += 8;

    if (filters.goal === "front-yard" && plant.hMax <= 36) score += 8;
    if (filters.goal === "rain-garden" && plant.moisture.includes("moist")) score += 8;
    if (filters.goal === "drought" && plant.moisture.includes("dry")) score += 8;

    return { score, hardFail, reasons };
  }

  function fitLabel(score) {
    if (score >= 82) return { text: "Excellent", cls: "good" };
    if (score >= 62) return { text: "Good", cls: "good" };
    if (score >= 42) return { text: "Near fit", cls: "warn" };
    return { text: "Weak fit", cls: "bad" };
  }

  function getFilters() {
    return {
      zone: Number(document.getElementById("pft-zone").value),
      sun: document.getElementById("pft-sun").value,
      moisture: document.getElementById("pft-moisture").value,
      height: Number(document.getElementById("pft-height").value),
      bloom: document.getElementById("pft-bloom").value,
      goal: document.getElementById("pft-goal").value,
      deer: document.getElementById("pft-deer").value,
      type: document.getElementById("pft-type").value,
      strict: document.getElementById("pft-strict").value
    };
  }

  function calculate() {
    const filters = getFilters();
    lastMatches = plants.map((plant) => ({ plant, result: scorePlant(plant, filters) }))
      .filter((item) => filters.strict === "strict" ? (!item.result.hardFail && item.result.score >= 62) : item.result.score >= 35)
      .sort((a, b) => b.result.score - a.result.score)
      .slice(0, 30);

    const excellent = lastMatches.filter((item) => item.result.score >= 82).length;
    const nativeCaution = lastMatches.filter((item) => item.plant.type === "annual").length;
    const avgHeight = lastMatches.length ? Math.round(lastMatches.reduce((s, item) => s + item.plant.hMax, 0) / lastMatches.length) : 0;
    const seasons = ["spring", "early-summer", "summer", "late-summer", "fall"];

    document.getElementById("pft-kpis").innerHTML = [
      { label: "Shortlist plants", value: lastMatches.length },
      { label: "Excellent matches", value: excellent },
      { label: "Average max height", value: avgHeight ? avgHeight + " in" : "—" },
      { label: "Hardiness zone", value: "Zone " + filters.zone },
      { label: "Annual / non-perennial options", value: nativeCaution },
      { label: "Database plants screened", value: plants.length }
    ].map((item) => '<div class="gbd-kpi"><span class="label">' + item.label + '</span><span class="value">' + item.value + '</span></div>').join("");

    const seasonCounts = seasons.map((season) => ({
      season,
      count: lastMatches.filter((item) => item.plant.bloom.includes(season)).length
    }));
    const maxCount = Math.max(1, ...seasonCounts.map((item) => item.count));
    document.getElementById("pft-bloom-bars").innerHTML = seasonCounts.map((item) => {
      const label = item.season.replace("early-summer", "early summer").replace("late-summer", "late summer");
      return '<div class="gbd-bar-row"><strong>' + label + '</strong><span class="gbd-bar-track"><span class="gbd-bar-fill" style="width:' + Math.round(item.count / maxCount * 100) + '%"></span></span><span>' + item.count + '</span></div>';
    }).join("");

    const missing = seasonCounts.filter((item) => item.count === 0).map((item) => item.season.replace("early-summer", "early summer").replace("late-summer", "late summer"));
    const strategy = [];
    if (!lastMatches.length) strategy.push("No strong matches. Loosen height, sun, moisture, or strictness filters.");
    else strategy.push("Start with 3–5 excellent or good matches, then add plants to cover missing bloom seasons.");
    if (missing.length) strategy.push("Bloom gaps in this shortlist: " + missing.join(", ") + ". Consider relaxing the bloom filter or adding complementary plants.");
    if (filters.goal === "monarchs") strategy.push("For monarch support, include at least one milkweed plus nectar plants before and after milkweed bloom.");
    if (filters.deer !== "any") strategy.push("Deer resistance is never absolute. Treat it as pressure reduction, not a guarantee.");
    strategy.push("Verify regional native status and local invasive concerns before buying.");
    document.getElementById("pft-strategy").innerHTML = strategy.map((item) => '<li>' + item + '</li>').join("");

    document.getElementById("pft-results").innerHTML = lastMatches.map((item) => {
      const plant = item.plant;
      const fit = fitLabel(item.result.score);
      const reasonText = item.result.reasons.length ? ' Near-fit cautions: ' + item.result.reasons.join(", ") + '.' : '';
      return '<tr>' +
        '<td><strong>' + plant.common + '</strong><br><span class="muted"><em>' + plant.botanical + '</em> · ' + plant.type + '</span></td>' +
        '<td>' + pill(fit.text, fit.cls) + '<br><span class="muted">Score ' + Math.max(0, Math.round(item.result.score)) + '</span></td>' +
        '<td>' + plant.zMin + '–' + plant.zMax + '</td>' +
        '<td>' + labelJoin(plant.sun) + '</td>' +
        '<td>' + labelJoin(plant.moisture) + '</td>' +
        '<td>' + plant.hMin + '–' + plant.hMax + ' in</td>' +
        '<td>' + labelJoin(plant.bloom) + '</td>' +
        '<td>' + labelJoin(plant.goals) + '</td>' +
        '<td>' + plant.notes + (plant.deer ? ' Often considered less deer-preferred.' : '') + reasonText + '</td>' +
      '</tr>';
    }).join("");
  }

  function reset() {
    document.getElementById("pft-zone").value = "4";
    document.getElementById("pft-sun").value = "full";
    document.getElementById("pft-moisture").value = "dry";
    document.getElementById("pft-height").value = "36";
    document.getElementById("pft-bloom").value = "summer";
    document.getElementById("pft-goal").value = "bees";
    document.getElementById("pft-deer").value = "any";
    document.getElementById("pft-type").value = "any";
    document.getElementById("pft-strict").value = "ranked";
    calculate();
  }

  function csvEscape(value) {
    return '"' + String(value == null ? "" : value).replace(/"/g, '""') + '"';
  }

  function downloadCsv() {
    if (!lastMatches.length) calculate();
    const header = ["Common name", "Botanical name", "Fit score", "Zones", "Sun", "Moisture", "Height", "Bloom", "Best for", "Notes"];
    const lines = [header.map(csvEscape).join(",")].concat(lastMatches.map((item) => {
      const p = item.plant;
      return [p.common, p.botanical, Math.round(item.result.score), p.zMin + "-" + p.zMax, labelJoin(p.sun), labelJoin(p.moisture), p.hMin + "-" + p.hMax + " in", labelJoin(p.bloom), labelJoin(p.goals), p.notes].map(csvEscape).join(",");
    }));
    const blob = new Blob([lines.join("\n")], { type: "text/csv" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "climate-fit-pollinator-shortlist.csv";
    a.click();
    URL.revokeObjectURL(url);
  }


  const pftResultsCard = document.getElementById("pft-results-card");

  function pftScrollToResults() {
    if (!pftResultsCard) return;
    const header = document.querySelector(".siteHeader");
    const headerOffset = header ? Math.ceil(header.getBoundingClientRect().height) : 0;
    const top = pftResultsCard.getBoundingClientRect().top + window.scrollY - headerOffset - 16;
    const reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    window.scrollTo({ top: Math.max(0, top), behavior: reduceMotion ? "auto" : "smooth" });
    window.setTimeout(() => {
      try { pftResultsCard.focus({ preventScroll: true }); } catch (error) {}
    }, reduceMotion ? 0 : 350);
  }
  document.getElementById("pft-filter").addEventListener("click", () => { calculate(); pftScrollToResults(); });
  document.getElementById("pft-reset").addEventListener("click", reset);
  document.getElementById("pft-csv").addEventListener("click", downloadCsv);
  root.addEventListener("change", (event) => {
    if (event.target.closest("input, select")) calculate();
  });
  calculate();
})();
</script>
