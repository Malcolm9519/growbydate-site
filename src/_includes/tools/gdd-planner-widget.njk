{#
  GrowByDate — GDD Planner Widget (embed-safe)
  - UI only (no H1 / long explanation)
  - Includes build-time JSON data scripts needed by the widget JS
  - Option A: loads JS here so embeds work without page-level script management

  Optional per-embed config:
    {% set gddWidget = {
      mode: "default" | "late-season" | "single-crop",
      cropDefault: "corn-sweet" (comma/pipe/space separated; can be siteId, site slug, or gdd slug),
      dateDefault: "today" | "MM-DD" | "YYYY-MM-DD",
      hideDate: true|false,
      hideCrops: true|false,

      // Optional copy overrides
      widgetTitle: "Check Tomato Timing",
      widgetLede: "Enter your ZIP / Postal and planting date to see whether tomatoes can typically mature before first fall frost."
    } %}
#}

{% set cfg = gddWidget or {} %}

{# --- Booleans (handles true/false or "true"/"false") --- #}
{% set hideCrops = (cfg.hideCrops == true) or (cfg.hideCrops == "true") %}
{% set hideDate = (cfg.hideDate == true) or (cfg.hideDate == "true") %}

{# --- Derive a human-friendly crop label for single-crop embeds --- #}
{% set cropKey = (cfg.cropDefault or "") | lower %}
{% set cropLabel = "your crop" %}

{% if cropKey %}
  {% if "tomato" in cropKey %}
    {% set cropLabel = "Tomato" %}
  {% elif "pepper" in cropKey %}
    {% set cropLabel = "Pepper" %}
  {% elif "cucumber" in cropKey %}
    {% set cropLabel = "Cucumber" %}
  {% elif "zucchini" in cropKey %}
    {% set cropLabel = "Zucchini" %}
  {% elif "pumpkin" in cropKey %}
    {% set cropLabel = "Pumpkin" %}
{% elif "winter-squash" in cropKey or ("squash" in cropKey and (not ("summer" in cropKey))) %}    {% set cropLabel = "Winter Squash" %}
  {% elif "corn" in cropKey %}
    {% set cropLabel = "Sweet Corn" %}
  {% elif "bean" in cropKey %}
    {% set cropLabel = "Bean" %}
  {% elif "pea" in cropKey %}
    {% set cropLabel = "Pea" %}
  {% elif "carrot" in cropKey %}
    {% set cropLabel = "Carrot" %}
  {% elif "beet" in cropKey %}
    {% set cropLabel = "Beet" %}
  {% elif "lettuce" in cropKey %}
    {% set cropLabel = "Lettuce" %}
  {% elif "broccoli" in cropKey %}
    {% set cropLabel = "Broccoli" %}
  {% elif "cabbage" in cropKey %}
    {% set cropLabel = "Cabbage" %}
  {% elif "cauliflower" in cropKey %}
    {% set cropLabel = "Cauliflower" %}
  {% elif "spinach" in cropKey %}
    {% set cropLabel = "Spinach" %}
  {% elif "kale" in cropKey %}
    {% set cropLabel = "Kale" %}
  {% else %}
    {% set cropLabel = "your crop" %}
  {% endif %}
{% endif %}

{# --- Default copy (can be overridden) --- #}
{% set defaultTitle = "Enter Your Growing Details" %}
{% set defaultLede = "Enter a <strong>5-digit ZIP</strong> (U.S.) or the <strong>first 3 characters</strong> of your postal code (Canada FSA), select one or more crops, and choose your planting date." %}

{% if hideCrops %}
  {% set defaultTitle = "Check " ~ cropLabel ~ " Timing" %}
  {% set defaultLede = "Enter your ZIP / Postal and planting date to see whether " ~ cropLabel ~ " can typically mature before first fall frost." %}
{% endif %}

<div
  class="toolRoot"
  data-tool="gdd-planner"

  {# Tell JS whether copy is custom (so it won’t overwrite on init) #}
  data-has-custom-title="{{ 'true' if (cfg.widgetTitle is defined) and (cfg.widgetTitle | trim) else 'false' }}"
  data-has-custom-lede="{{ 'true' if (cfg.widgetLede is defined) and (cfg.widgetLede | trim) else 'false' }}"

  {% if cfg.mode %}data-mode="{{ cfg.mode }}"{% endif %}
  {% if cfg.cropDefault %}data-crop-default="{{ cfg.cropDefault }}"{% endif %}
  {% if cfg.dateDefault %}data-date-default="{{ cfg.dateDefault }}"{% endif %}
  {% if cfg.hideDate is defined %}data-hide-date="{{ cfg.hideDate }}"{% endif %}
  {% if cfg.hideCrops is defined %}data-hide-crops="{{ cfg.hideCrops }}"{% endif %}
>

  {# Embedded canonical build-time data (scoped to this widget instance) #}
  <script type="application/json" data-site-crops>{{ crops | dump | safe }}</script>
  <script type="application/json" data-gdd-crops>{{ gddCrops | dump | safe }}</script>

<section aria-label="Growing degree day planner">
    <h2 data-role="widgetTitle">{{ cfg.widgetTitle or defaultTitle }}</h2>

    <p class="small" data-role="widgetIntro" style="opacity:0.86; margin-top:6px;">
      {{ (cfg.widgetLede or defaultLede) | safe }}
    </p>

    <div class="stack" style="margin-top:10px;">
      <div data-role="locationWrap">
        <label>ZIP / Postal</label>
        <input type="text" data-role="location" placeholder="ZIP or Postal Code" autocomplete="postal-code" aria-label="ZIP or postal code">
      </div>

      <div data-role="cropWrap" {% if hideCrops %}style="display:none;"{% endif %}>
        <label>Crops</label>
        <div class="small" data-role="cropHelp">Select one or more crops.</div>
        <div data-role="cropList" class="cropList"></div>
      </div>

      <div data-role="plantingWrap" {% if hideDate %}style="display:none;"{% endif %}>
        <label>Planting date</label>
        <input type="date" data-role="planting" aria-label="Planting date">
      </div>
    </div>

    <div class="btnRow" style="margin-top:12px;">
      <button class="button primary" data-role="run" type="button">Estimate Maturity</button>
      <button class="btn" data-role="reset" type="button">Reset</button>
      <div class="small muted" data-role="status" aria-live="polite" style="align-self:center;"></div>
    </div>

    <div class="warn" data-role="formWarn" style="display:none; margin-top:12px;" role="alert"></div>

    <p class="small muted" style="margin-top:12px;">
      Reminder: microclimates matter. Gardens in wind-sheltered low spots often frost earlier than the “average” for a ZIP or FSA.
    </p>
  </section>

<section data-role="resultsCard" style="display:none;" aria-label="Results">
    <h2>Results</h2>

    <div class="small">
      <span class="pill">Planning tip</span>
      This is a “typical year” estimate. For short seasons, aim to mature <strong>before</strong> the risk window — not inside it.
    </div>

    <table aria-label="GDD maturity estimate" style="margin-top:0.75rem;">
      <tbody data-role="resultsBody"></tbody>
    </table>

    <div class="warn" data-role="riskBox" style="display:none; margin-top:12px;">
      <div><strong data-role="riskLabel"></strong></div>
      <div class="small" data-role="riskNote" style="margin-top:6px;"></div>
    </div>

    <p class="small muted" data-role="footnote" style="margin-top:12px;"></p>

    <div class="btnRow" data-role="resultsActions" style="margin-top:12px;">
      <button class="btn" data-role="copyBtn" type="button" style="display:none;">Copy results</button>
      <button class="btn" data-role="printBtn" type="button" style="display:none;">Print</button>
      <button class="btn" data-role="csvBtn" type="button" style="display:none;">Download CSV</button>
      <button class="btn" data-role="txtBtn" type="button" style="display:none;">Download text</button>
    </div>
  </section>

</div>

{# Option A — load JS from inside the widget include #}
<script type="module" src="/assets/js/gdd-planner.js"></script>

<script>
/*
  GrowByDate GDD Planner — Patch v5
  Fixes:
   - Per-crop "Assessment: Unknown" when the crop clearly cannot mature
   - Overall "Unknown / Not enough data" when at least one crop has an evaluable fail

  Safe: does NOT replace existing widget functions; only post-processes DOM.
*/
(() => {
  const norm = (s) => (s || "").replace(/\s+/g, " ").trim();
  const lower = (s) => norm(s).toLowerCase();

  function parseGddNumber(s) {
    const m = (s || "").match(/(-?\d+)\s*gdd/i);
    return m ? parseInt(m[1], 10) : null;
  }

  function isCropHeaderRow(tr) {
    const cells = Array.from(tr.querySelectorAll("th, td"));
    if (!cells.length) return false;
    // crop header is commonly 1 cell with colspan=2, but allow 2-cell variants too
    const text = norm(cells[0].textContent);
    if (!text) return false;
    // your headers look like: "🌽 Sweet Corn · Base 50°F"
    return text.includes("·") && /base\s*\d/i.test(text);
  }

  function getKV(tr) {
    const cells = Array.from(tr.querySelectorAll("th, td"));
    if (cells.length < 2) return null;
    const k = norm(cells[0].textContent);
    const v = norm(cells[1].textContent);
    if (!k) return null;
    return { k, v, valueCell: cells[1] };
  }

  function scanCrops(tbody) {
    const rows = Array.from(tbody.querySelectorAll("tr"));
    const crops = [];
    let cur = null;

    const push = () => {
      if (cur) crops.push(cur);
      cur = null;
    };

    for (const tr of rows) {
      if (isCropHeaderRow(tr)) {
        push();
        cur = {
          maturity: "",
          latest: "",
          shortfall: null,
          assessmentText: "",
          assessmentCell: null,
        };
        continue;
      }
      if (!cur) continue;

      const kv = getKV(tr);
      if (!kv) continue;

      const k = lower(kv.k);
      const v = kv.v;

      if (k.includes("estimated maturity date")) cur.maturity = v;
      else if (k.includes("latest typical planting date")) cur.latest = v;
      else if (k.includes("estimated shortfall")) cur.shortfall = parseGddNumber(v);
      else if (k === "assessment" || k.includes("assessment")) {
        cur.assessmentText = v;
        cur.assessmentCell = kv.valueCell;
      }
    }
    push();
    return crops;
  }

  function outcomeForCrop(c) {
    const maturity = lower(c.maturity);
    const latest   = lower(c.latest);
    const assess   = lower(c.assessmentText);
    const shortfall = c.shortfall;

    const hardFail =
      maturity.includes("not reached") ||
      maturity.includes("year-end") ||
      latest.includes("not possible") ||
      (typeof shortfall === "number" && shortfall > 0);

    const pass =
      (typeof shortfall === "number" && shortfall <= 0) ||
      assess === "pass" ||
      assess === "good" ||
      assess.includes("likely to mature");

    if (hardFail) return "fail";
    if (pass) return "pass";
    return "unknown";
  }

  function fixAssessmentRows(crops) {
    for (const c of crops) {
      if (!c.assessmentCell) continue;
      if (lower(c.assessmentCell.textContent) !== "unknown") continue;

      const out = outcomeForCrop(c);
      if (out === "fail") c.assessmentCell.textContent = "Unlikely to mature before frost";
      else if (out === "pass") c.assessmentCell.textContent = "Likely to mature in time";
      // leave truly unknown as-is
    }
  }

  function fixRiskBox(root, crops) {
    const riskBox  = root.querySelector('[data-role="riskBox"]');
    const riskLabel = root.querySelector('[data-role="riskLabel"]');
    const riskNote  = root.querySelector('[data-role="riskNote"]');
    if (!riskBox || !riskLabel || !riskNote) return;

    const labelNow = lower(riskLabel.textContent);
    const noteNow  = lower(riskNote.textContent);

    // Only override when widget currently says Unknown / Not enough data
    const isUnknownNow =
      labelNow.includes("unknown") || noteNow.includes("not enough data");

    if (!isUnknownNow) return;

    const outcomes = crops.map(outcomeForCrop).filter(o => o !== "unknown");
    if (!outcomes.length) return; // truly unknown: keep it

    const anyPass = outcomes.includes("pass");
    const anyFail = outcomes.includes("fail");

    riskBox.style.display = "";
    if (anyPass && anyFail) {
      riskLabel.textContent = "Mixed results";
      riskNote.textContent =
        "Some selected crops can mature before your area’s typical first fall frost in a typical year, while others likely won’t. Review each crop section above for crop-specific details.";
    } else if (anyFail) {
      riskLabel.textContent = "Unlikely to mature before frost";
      riskNote.textContent =
        "At least one crop has enough data to evaluate, but it does not reach maturity before your area’s typical first fall frost in a typical year. Review each crop section above for crop-specific details.";
    } else {
      riskLabel.textContent = "Likely to mature in time";
      riskNote.textContent =
        "Based on a typical year estimate, your selected crops appear to reach maturity before your area’s typical first fall frost. Review each crop section above for crop-specific details.";
    }
  }

  function apply(root) {
    const tbody = root.querySelector('[data-role="resultsBody"]');
    if (!tbody) return;

    const crops = scanCrops(tbody);
    if (!crops.length) return;

    fixAssessmentRows(crops);
    fixRiskBox(root, crops);
  }

  function hook(root) {
    // Run after initial render and whenever results update
    setTimeout(() => apply(root), 0);
    const obs = new MutationObserver(() => apply(root));
    obs.observe(root, { subtree: true, childList: true, characterData: true });
  }

  document
    .querySelectorAll('.toolRoot[data-tool="gdd-planner"]')
    .forEach(hook);
})();
</script>

{# Tool-scoped styles (moved here so embeds match the canonical tool page) #}
<style>
  .row { display: grid; gap: 10px; grid-template-columns: 1fr; }
  .row > div { min-width: 0; }

  label { font-weight: 600; }

  input[type="date"], input[type="text"], input[type="number"], select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ccc;
    border-radius: 12px;
    font: inherit;
    box-sizing: border-box;
  }

  .small { font-size: 14px; opacity: .85; }
  .muted { color: rgba(0, 0, 0, 0.75); }

  table { width: 100%; border-collapse: collapse; margin-top: 10px; }
  th, td { padding: 10px 8px; border-bottom: 1px solid #e5e5e5; text-align: left; vertical-align: top; }
  th { font-weight: 700; }

  .pill { display: inline-block; padding: 2px 8px; border: 1px solid #222; border-radius: 999px; font-size: 12px; opacity: .9; }
  .warn { border: 1px solid #e3c46b; border-radius: 12px; padding: 10px 12px; background: #fff8e1; }

  .btnRow { display:flex; align-items:end; gap:10px; flex-wrap: wrap; }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 14px;
    border: 1px solid #111;
    border-radius: 12px;
    background: transparent;
    cursor: pointer;
    font: inherit;
    line-height: 1.2;
    white-space: nowrap;
    box-sizing: border-box;
  }
  .btn:hover { opacity: .85; }

  .btnRow .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 14px;
    border-radius: 12px;
    font: inherit;
    line-height: 1.2;
    white-space: nowrap;
    box-sizing: border-box;
  }

  .cropList {
    border: 1px solid var(--border, #ddd);
    border-radius: 10px;
    padding: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 10px;
    max-height: none;
    overflow: visible;
  }
  .cropPickRow { width: auto; display: inline-flex; }
  .cropPickIcon { margin-right: 6px; }
  .cropPickLabel:hover { background: rgba(0,0,0,0.04); }
  .cropPickLabel input { flex: 0 0 auto; }
  .cropPickName {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }
  .cropPickLabel {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 999px;
    cursor: pointer;
    user-select: none;
    border: 1px solid rgba(0,0,0,0.10);
    background: rgba(0,0,0,0.02);
    width: auto;
  }

  .cropHeaderRow td { padding: 10px 12px; background: rgba(0,0,0,0.04); border-top: 1px solid rgba(0,0,0,0.08); }
  .cropHeaderRow:first-child td { border-top: 0; }
  .cropHeaderIcon { margin-right: 8px; }
  .cropHeaderLink { font-weight: 700; text-decoration: none; }
  .cropHeaderLink:hover { text-decoration: underline; }

  [data-tool="gdd-planner"] [data-role="resultsCard"] .muted,
  [data-tool="gdd-planner"] [data-role="resultsCard"] .small { opacity: 1; }

  @media print {
    body * { visibility: hidden !important; }
    [data-tool="gdd-planner"] [data-role="resultsCard"],
    [data-tool="gdd-planner"] [data-role="resultsCard"] * { visibility: visible !important; }
    [data-tool="gdd-planner"] [data-role="resultsCard"] {
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      display: block !important;
      box-shadow: none !important;
      border: none !important;
    }
    [data-tool="gdd-planner"] [data-role="resultsActions"] { display: none !important; }
  }
</style>