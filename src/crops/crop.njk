---
layout: layout-base.njk
pagination:
  data: crops
  size: 1
  alias: crop
permalink: "crops/{{ crop.slug }}/"
eleventyComputed:
  title: "When to Plant {{ crop.name }} in Short Seasons | Frost Dates & Timing"
  description: "{{ crop.description }}"
  canonical: "https://growbydate.com/crops/{{ crop.slug }}/"
---

<header class="header">
<h1>When to Plant {{ crop.name }} in Short Growing Seasons</h1>
  <p class="tagline">{{ crop.tagline or "Practical crop-by-crop planning references." }}</p>
<p class="lede">
  {{ crop.lede or "Use frost dates, soil conditions, and days to maturity to decide when to start, transplant, or direct sow " ~ crop.name | lower ~ " in a short growing season." }}
</p>
</header>

<section class="card">
  <h2>Quick Planning Reference</h2>

  <ul>
    {% if crop.indoorStartWeeks %}
      <li>
        <strong>Indoor start:</strong>
        {{ crop.indoorStartWeeks[1] }}–{{ crop.indoorStartWeeks[0] }} weeks before your average last frost
      </li>
    {% endif %}

    {% if crop.transplantWeeks %}
      <li>
        <strong>Transplant:</strong>
        {% if crop.transplantWeeks[0] < 0 or crop.transplantWeeks[1] < 0 %}
          {{ crop.transplantWeeks[0] | abs }}–{{ crop.transplantWeeks[1] | abs }} weeks <em>before</em> last frost (weather permitting)
        {% else %}
          {{ crop.transplantWeeks[1] }}–{{ crop.transplantWeeks[0] }} weeks <em>after</em> last frost (once conditions are suitable)
        {% endif %}
      </li>
    {% endif %}

    {% if crop.directSowWeeks %}
      <li>
        <strong>Direct sow:</strong>
        {% if crop.directSowWeeks[0] < 0 or crop.directSowWeeks[1] < 0 %}
          {{ crop.directSowWeeks[0] | abs }}–{{ crop.directSowWeeks[1] | abs }} weeks <em>before</em> last frost
        {% else %}
          {{ crop.directSowWeeks[0] }}–{{ crop.directSowWeeks[1] }} weeks <em>after</em> last frost (once soil is warm)
        {% endif %}
      </li>
    {% endif %}

    {% if crop.daysToMaturity %}
      <li>
        <strong>Days to maturity:</strong>
        {{ crop.daysToMaturity[0] }}–{{ crop.daysToMaturity[1] }} days (variety-dependent)
      </li>
    {% endif %}

    <li><strong>Frost tolerance:</strong> {{ crop.frostTolerance }}</li>
  </ul>

  <p class="fine muted" style="margin-top:14px;">
    These are practical ranges. Local conditions matter—especially soil temperature, wind exposure, and cold nights.
  </p>
</section>

{% if crop.editorial and crop.editorial.detailPartial %}
  {% include crop.editorial.detailPartial ignore missing %}
{% else %}
  {% set detailsPathA = "crops/" + crop.slug + "-details.njk" %}
  {% set detailsPathB = crop.slug + "-details.njk" %}
  {% include detailsPathA ignore missing %}
  {% include detailsPathB ignore missing %}
{% endif %}
{% include "crops/related-planning-guides.njk" %}
