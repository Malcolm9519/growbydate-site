  function renderPosts(platforms) {
    els.posts.innerHTML = Object.keys(PLATFORMS).map(function (platformKey) {
      const config = PLATFORMS[platformKey];
      const post = platforms[platformKey] || {};
      const checks = validatePlatformPost(platformKey, post, state.selectedPage, els.angle.value);

      return [
        '<article class="social-kit__post-card" data-platform-card="' + escapeHtml(platformKey) + '">',
        '<div class="social-kit__post-header">',
        '<h3 class="social-kit__post-title">' + escapeHtml(config.label) + '</h3>',
        '<div class="social-kit__qa-summary" data-platform-summary="' + escapeHtml(platformKey) + '">' + buildQaSummaryHtml(checks, "QA") + '</div>',
        '</div>',
        '<div class="social-kit__post-body">',
        config.fields.map(function (field) {
          const value = post[field.key] || "";
          const fieldId = "post-" + platformKey + "-" + field.key;
          const control = field.type === "input"
            ? '<input id="' + escapeHtml(fieldId) + '" type="text" value="' + escapeHtml(value) + '" data-platform-field="' + escapeHtml(platformKey) + '" data-field-key="' + escapeHtml(field.key) + '">'
            : '<textarea id="' + escapeHtml(fieldId) + '" data-platform-field="' + escapeHtml(platformKey) + '" data-field-key="' + escapeHtml(field.key) + '">' + escapeHtml(value) + '</textarea>';

          return [
            '<div class="social-kit__field' + (field.key === "altText" ? ' social-kit__field--compact' : '') + '">',
            '<label for="' + escapeHtml(fieldId) + '">' + escapeHtml(field.label) + '</label>',
            control,
            '<div class="social-kit__field-status" data-count-for="' + escapeHtml(platformKey + ":" + field.key) + '"></div>',
            '</div>'
          ].join("");
        }).join(""),
        '<ul class="social-kit__qa-list" data-platform-qa="' + escapeHtml(platformKey) + '">' + buildQaListHtml(checks) + '</ul>',
        '<div class="social-kit__post-actions">',
        '<button class="social-kit__button social-kit__button--secondary" type="button" data-copy-platform="' + escapeHtml(platformKey) + '">Copy ' + escapeHtml(config.label) + '</button>',
        '<button class="social-kit__button social-kit__button--ghost" type="button" data-reset-platform="' + escapeHtml(platformKey) + '">Reset</button>',
        '<span class="social-kit__copy-status" data-status="' + escapeHtml(platformKey) + '"></span>',
        '</div>',
        '</div>',
        '</article>'
      ].join("");
    }).join("");

    bindPostControls();
    refreshAllFieldCounts();
