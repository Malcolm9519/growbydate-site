      plantingBestVarietyText: getBestVarietyLabel(page),
      plantingNoteText: getPlantingTip(page, cropGroup),
      frostBoxAnswer: getFrostBoxAnswer(page),
      frostBoxText: getFrostReason(page, cropGroup),
      seasonBoxAnswer: getSeasonBoxAnswer(page),
      seasonBoxText: getSeasonBoxText(page, cropGroup),
      mistakeBoxAnswer: getCommonMistakeAnswer(page, cropGroup),
      mistakeBoxText: getCommonMistakeReason(page, cropGroup),
      fitBoxAnswer: getFitBoxAnswer(page),
