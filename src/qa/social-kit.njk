    return formatSocialDate(getNested(page, "planting.startIndoorsDate") || getNested(page, "methodSummary.startIndoorsDate"));
  }

  function getPlantingTransplantText(page) {
    return formatSocialDate(getNested(page, "planting.plantOutDate") || getNested(page, "methodSummary.plantOutDate"));
  }

  function getPlantingDirectSowText(page) {
    return formatSocialDate(getNested(page, "planting.directSowDate") || getNested(page, "methodSummary.directSowDate"));
  }

  function getPlantingMaturityText(page) {
    const maturity = getDaysToMaturity(page);
    const maturityFrom = getMaturityFromLabel(page);
    if (!maturity) return "";
    return maturity + " days" + (maturityFrom ? " from " + maturityFrom : "");
  }

  function getDaysToMaturity(page) {
    return cleanValue(getNested(page, "crop.daysToMaturityTypical"))
      || cleanValue(getNested(page, "daysToMaturityTypical"))
      || cleanValue(getNested(page, "crop.planning.daysToMaturityTypical"))
      || "";
  }

  function getMaturityFromLabel(page) {
    const value = cleanValue(getNested(page, "crop.maturityFrom"))
      || cleanValue(getNested(page, "maturityFrom"))
      || "";
    if (!value) return "";
    return String(value).replace(/[-_]+/g, " ");
  }

  function getBestVarietyLabel(page) {
    const direct = cleanValue(getNested(page, "fit.bestVarietyLabel"));
    if (direct) return direct;

    const examples = getNested(page, "fit.fittingVarietyExamplesDetailed");
    if (Array.isArray(examples) && examples.length) {
      const first = examples.find(function (item) { return item && item.name; });
      if (first) return first.name;
    }

    const labels = getNested(page, "fit.fittingVarietyLabels") || page.fittingVarietyLabels;
    if (Array.isArray(labels) && labels.length) return labels[0];

    return "";
  }

  function formatSignedMetricNumber(value) {
    if (value === null || value === undefined || value === "") return "";
    const number = Number(value);
    if (!Number.isFinite(number)) return String(value);
    return (number > 0 ? "+" : "") + number.toLocaleString();
  }

  function getAngleVisualStyle(angle, backgroundStyle) {
    const styles = {
      planting_timing: { bgStart: "#2f6f3e", bgMid: "#7ea24a", bgEnd: "#e1c64f", sunOuter: "#f5d85b", sunInner: "#fff2a6", accent: "#d0a822", pill: "#2f6f3e" },
      frost_risk: { bgStart: "#255d4d", bgMid: "#6d8f5d", bgEnd: "#d8c35a", sunOuter: "#f0d261", sunInner: "#fff4bb", accent: "#b99b2e", pill: "#285e46" },
      short_season: { bgStart: "#1f573c", bgMid: "#638f4b", bgEnd: "#d4b948", sunOuter: "#f7d85b", sunInner: "#fff3b2", accent: "#c9a62c", pill: "#245f3a" },
      easy_or_risky: { bgStart: "#275f39", bgMid: "#7ea64f", bgEnd: "#dcc257", sunOuter: "#efd45a", sunInner: "#fff3b0", accent: "#c59d2a", pill: "#2f6f3e" },
      common_mistake: { bgStart: "#46652d", bgMid: "#8f9c45", bgEnd: "#d7b84c", sunOuter: "#f1cf54", sunInner: "#fff1a2", accent: "#c28f1f", pill: "#2f6f3e" },
      planting_guide: { bgStart: "#214f35", bgMid: "#6f9647", bgEnd: "#dfc861", sunOuter: "#f3d86a", sunInner: "#fff5c6", accent: "#cbab39", pill: "#245a3c" }
    };

    const backgroundStyles = {
      garden: { bgStart: "#2f6f3e", bgMid: "#7ea24a", bgEnd: "#e1c64f", sunOuter: "#f5d85b", sunInner: "#fff2a6", accent: "#d0a822", pill: "#2f6f3e" },
      sunset: { bgStart: "#425f2f", bgMid: "#b99242", bgEnd: "#f0cf63", sunOuter: "#f3c551", sunInner: "#fff1a5", accent: "#c28f1f", pill: "#2f6f3e" },
      frost: { bgStart: "#24535f", bgMid: "#699680", bgEnd: "#d9d8a5", sunOuter: "#e8e6ad", sunInner: "#fff8cf", accent: "#4d8f8a", pill: "#245f50" },
      cream: { bgStart: "#d8d1a8", bgMid: "#ece2bd", bgEnd: "#fbf7ef", sunOuter: "#eedb82", sunInner: "#fff6c5", accent: "#b99726", pill: "#2f6f3e" },
      deep: { bgStart: "#13351f", bgMid: "#245b33", bgEnd: "#5f863c", sunOuter: "#d8bc4a", sunInner: "#fff0a4", accent: "#d3ad2e", pill: "#1f4d2f" }
    };

    if (backgroundStyle && backgroundStyle !== "auto" && backgroundStyles[backgroundStyle]) {
      return backgroundStyles[backgroundStyle];
    }

    return styles[angle] || styles.planting_timing;
  }

  function getSvgPillWidth(text, minWidth, maxWidth, charWidth, padding) {
    const width = (padding || 92) + String(text || "").length * (charWidth || 15);
    return Math.max(minWidth || 220, Math.min(maxWidth || 520, width));
  }

  function getPlantingSentence(page) {
    return cleanSentence(getNested(page, "methodSummary.summarySentence")
      || getWindowSentence(page)
      || getNested(page, "copy.oneSentenceSummary")
      || "");
  }

  function getStrategySentence(page) {
    return cleanSentence(getNested(page, "advisory.bestStrategy")
      || getNested(page, "fit.summary")
      || getNested(page, "fit.varietyFitSentence")
      || getNested(page, "copy.shortSeasonStrategy")
      || "");
  }

  function getRiskSentence(page) {
    return cleanSentence(getNested(page, "fit.mainRiskSentence")
      || getNested(page, "copy.commonFailureMode")
      || getNested(page, "advisory.localInterpretation")
      || "");
  }

  function getCommonMistakeText(page) {
    const cropLower = lowerFirst(page.cropName || "this crop");
    const city = page.cityName || "your city";
    const source = getNested(page, "copy.commonFailureMode")
      || getNested(page, "fit.mainRiskSentence")
      || getNested(page, "advisory.localInterpretation");

    return cleanSentence(source || "In " + city + ", a common " + cropLower + " mistake is planting outside the local window instead of checking frost and season timing first.");
  }

  function getCommonMistakeImageText(page) {
    return shortenText(getCommonMistakeText(page), 118);
  }

  function getFrostRiskImageText(page) {
    const cropLower = lowerFirst(page.cropName || "this crop");
    const city = page.cityName || "your city";
    const method = String(getPrimaryMethod(page) || "").toLowerCase();
    const source = getRiskSentence(page);

    if (source) return shortenText(source, 120);
    if (method.indexOf("transplant") > -1) return "Wait until frost risk has passed before moving " + cropLower + " outdoors.";
    if (method.indexOf("sow") > -1 || method.indexOf("direct") > -1) return "Spring frost and soil timing both matter before sowing " + cropLower + ".";

    return "In " + city + ", frost dates are one of the first timing checks for " + cropLower + ".";
  }

  function getWindowSentence(page) {
    const cropLower = lowerFirst(page.cropName || "this crop");
    const city = page.cityName || "your city";
    const dateRange = getPlantingDateRange(page);
    const method = getPrimaryMethod(page);

    if (dateRange && method) {
      const cleanMethod = method.toLowerCase();
      if (cleanMethod.indexOf("/") > -1 || cleanMethod.indexOf("direct sow / transplant") > -1) {
        return "In " + city + ", " + cropLower + " can usually be planted around " + dateRange + ".";
      }
      return "In " + city + ", the local " + cleanMethod + " window for " + cropLower + " is around " + dateRange + ".";
    }

    if (dateRange) return "In " + city + ", the local planting window for " + cropLower + " is around " + dateRange + ".";

    const primary = getPrimaryDate(page);
    if (primary) return "Key local timing for " + cropLower + ": " + formatSocialDate(primary) + ".";

    return "";
  }

  function getPlantingVerb(page) {
    const method = String(getPrimaryMethod(page) || "").toLowerCase();
    if (method.indexOf("sow") > -1 || method.indexOf("direct") > -1) return "Sow";
    if (method.indexOf("transplant") > -1 || method.indexOf("plant out") > -1) return "Transplant";
    return "Plant";
  }

  function getPrimaryMethod(page) {
    return cleanValue(getNested(page, "planting.windowMethod"))
      || cleanValue(getNested(page, "plantingWindow.method"))
      || cleanValue(getNested(page, "methodSummary.primaryLabel"))
      || "";
  }

  function getPrimaryDate(page) {
    return cleanValue(getNested(page, "methodSummary.primaryDate"))
      || cleanValue(getNested(page, "planting.primaryPlantingDate"))
      || cleanValue(getNested(page, "planting.windowStart"))
      || "";
  }

  function getPlantingDateRange(page) {
    return formatSocialDateRange(
      getNested(page, "planting.windowStart") || getNested(page, "plantingWindow.start"),
      getNested(page, "planting.windowEnd") || getNested(page, "plantingWindow.end")
    );
  }

  function getConfidenceRaw(page) {
    return cleanValue(getNested(page, "fit.confidence"))
      || cleanValue(page.confidence)
      || cleanValue(getNested(page, "monetization.primaryAction.confidence"));
  }

  function getConfidenceLabel(page) {
    const value = String(getConfidenceRaw(page) || "").toLowerCase();
    const labels = {
      surplus: "Comfortable fit",
      strong: "Strong fit",
      good: "Good fit",
      workable: "Workable fit",
      borderline: "Timing-sensitive fit",
      tight: "Tight fit",
      risky: "Risky fit",
      poor: "Poor fit"
    };

    return labels[value] || titleCase(value);
  }

  function getRequiredGdd(page) {
    return getFirstAvailable(page, ["targetGdd", "crop.gddTargetTypical", "heat.targetTypical", "fit.targetGdd", "fit.gddTargetTypical"]);
  }

  function getLocalGdd(page) {
    return getFirstAvailable(page, ["availableGddFromPlanting", "fit.availableGddFromPlanting", "heat.availableFromPlanting"]);
  }

  function getGddMargin(page) {
    return getFirstAvailable(page, ["gddMargin", "fit.gddMargin", "heat.margin"]);
  }

  function getFirstAvailable(obj, paths) {
    for (let i = 0; i < paths.length; i += 1) {
      const value = getNested(obj, paths[i]);
      if (value !== null && value !== undefined && value !== "") return value;
    }
    return "";
  }

  function buildHashtags(page) {
    const cityTag = stripNonTagChars(page.cityName || "") + "Gardeners";
    const cropTag = stripNonTagChars(page.cropName || "");
    const regionTag = stripNonTagChars(page.regionName || "");
    const countryTag = page.country === "canada" ? "CanadianGardening" : (page.country === "usa" ? "USAGardening" : "Gardening");

    return uniqueSorted([
      "#GrowByDate",
      cityTag ? "#" + cityTag : "",
      cropTag ? "#" + cropTag : "",
      regionTag ? "#" + regionTag + "Gardening" : "",
      "#" + countryTag,
      "#VegetableGarden",
      "#PlantingDates"
    ].filter(Boolean));
  }

  function extractHashtags(text) {
    return String(text || "").match(/#[a-z0-9_]+/gi) || [];
  }

  function containsBadToken(text) {
    const value = String(text || "").toLowerCase();
    return BAD_TOKENS.some(function (token) { return value.indexOf(token) > -1; });
  }

  function hasGrammarRedFlag(text) {
    const value = String(text || "").toLowerCase();
    return /\busually has\b/.test(value)
      || /\bare usually has\b/.test(value)
      || /\bis usually are\b/.test(value)
      || /\bcan usually has\b/.test(value);
  }

  function usesGenericFallback(text) {
    const value = String(text || "").toLowerCase();
    return value.indexOf("local planting timing can make a big difference") > -1
      || value.indexOf("check local planting timing") > -1
      || value.indexOf("planting outside the local window") > -1;
  }

  function containsLoose(text, needle) {
    if (!needle) return true;
    return normalizeSearch(text).indexOf(normalizeSearch(needle)) > -1;
  }

  function getLengthLabel(count, fieldConfig) {
    if (count < fieldConfig.min) return "Too short";
    if (count > fieldConfig.max) return "Too long";
    if (count < fieldConfig.idealMin) return "A little short";
    if (count > fieldConfig.idealMax) return "Review length";
    return "Good";
  }

  function cleanSentence(text) {
    return String(text || "")
      .replace(/\s+/g, " ")
      .replace(/\btomatoes usually has\b/gi, "tomatoes usually have")
      .replace(/\bcucumbers usually has\b/gi, "cucumbers usually have")
      .replace(/\bmelons usually has\b/gi, "melons usually have")
      .replace(/\bwatermelons usually has\b/gi, "watermelons usually have")
      .replace(/\bpotatoes usually has\b/gi, "potatoes usually have")
      .replace(/\bbeans usually has\b/gi, "beans usually have")
      .trim();
  }

  function cleanValue(value) {
    if (value === null || value === undefined) return "";
    const text = String(value).trim();
    if (!text || text === "Not listed" || text === "null" || text === "undefined") return "";
    return text;
  }

  function shortenText(text, maxLength) {
    const value = cleanSentence(text);
    if (!value) return "";
    if (value.length <= maxLength) return value;
    return value.slice(0, maxLength - 1).replace(/\s+\S*$/, "") + "…";
  }

  function formatMetricNumber(value) {
    if (value === null || value === undefined || value === "") return "";
    const number = Number(value);
    if (!Number.isFinite(number)) return String(value);
    return number.toLocaleString();
  }

  function formatSocialDate(value) {
    if (!value) return "";
    const text = String(value).trim();
    const match = text.match(/^(\d{2})-(\d{2})$/);
    if (!match) return text;

    const monthIndex = Number(match[1]) - 1;
    const day = Number(match[2]);
    const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

    if (monthIndex < 0 || monthIndex > 11 || day < 1 || day > 31) return text;
    return months[monthIndex] + " " + day;
  }

  function formatSocialDateRange(start, end) {
    const formattedStart = formatSocialDate(start);
    const formattedEnd = formatSocialDate(end);
    if (formattedStart && formattedEnd) return formattedStart + " to " + formattedEnd;
    return formattedStart || formattedEnd || "";
  }

  function formatValue(value) {
    if (value === null || value === undefined || value === "") return "Not listed";
    const text = String(value);
    if (text.match(/^(\d{2})-(\d{2})$/)) return formatSocialDate(text);
    return text;
  }

  function getNested(object, path) {
    return String(path || "").split(".").reduce(function (current, key) {
      return current && current[key] != null ? current[key] : undefined;
    }, object);
  }

  function lowerFirst(value) {
    const text = String(value || "");
    return text ? text.charAt(0).toLowerCase() + text.slice(1) : text;
  }

  function titleCase(value) {
    return String(value || "").replace(/[-_]+/g, " ").replace(/\b\w/g, function (letter) {
      return letter.toUpperCase();
    });
  }

  function uniqueSorted(values) {
    return Array.from(new Set(values.filter(Boolean))).sort(function (a, b) {
      return String(a).localeCompare(String(b));
    });
  }

  function stripNonTagChars(value) {
    return String(value || "").replace(/[^a-zA-Z0-9]/g, "");
  }

  function slugify(value) {
    return String(value || "")
      .toLowerCase()
      .replace(/&/g, " and ")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "")
      || "social-kit";
  }

  function tokenize(value) {
    return normalizeSearch(value).split(/\s+/).filter(Boolean);
  }

  function normalizeSearch(value) {
    return String(value || "").toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
  }

  function wrapText(text, maxChars, maxLines) {
    const words = String(text || "").split(/\s+/).filter(Boolean);
    const lines = [];
    let current = "";

    words.forEach(function (word) {
      const next = current ? current + " " + word : word;
      if (next.length <= maxChars) {
        current = next;
      } else {
        if (current) lines.push(current);
        current = word;
      }
    });

    if (current) lines.push(current);

    if (lines.length > maxLines) {
      const trimmed = lines.slice(0, maxLines);
      trimmed[maxLines - 1] = trimmed[maxLines - 1].replace(/[.,;:!?]$/, "") + "…";
      return trimmed;
    }

    return lines;
  }



  function wrapTextUnlimited(text, maxChars) {
    const safeMax = Math.max(8, Number(maxChars) || 32);
    const lines = [];

    String(text || "").split(/\n+/).forEach(function (paragraph) {
      const words = paragraph.split(/\s+/).filter(Boolean);
      let current = "";

      words.forEach(function (word) {
        const next = current ? current + " " + word : word;
        if (next.length <= safeMax) {
          current = next;
        } else {
          if (current) lines.push(current);
          current = word;
        }
      });

      if (current) lines.push(current);
    });

    return lines.length ? lines : [""];
  }

  function copyText(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }

    const textarea = document.createElement("textarea");
    textarea.value = text;
    textarea.setAttribute("readonly", "");
    textarea.style.position = "fixed";
    textarea.style.top = "-9999px";
    document.body.appendChild(textarea);
    textarea.select();

    try {
      document.execCommand("copy");
    } finally {
      textarea.remove();
    }

    return Promise.resolve();
  }

  function downloadTextFile(filename, text, type) {
    const blob = new Blob([text], { type: type || "text/plain" });
    const link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    link.remove();

    window.setTimeout(function () {
      URL.revokeObjectURL(link.href);
    }, 1000);
  }

  function showStatus(element, message) {
    if (!element) return;
    element.textContent = message;
    window.clearTimeout(element._statusTimer);
    element._statusTimer = window.setTimeout(function () {
      element.textContent = "";
    }, 1800);
  }

  function getPageKey(page) {
    return [page.cropKey, page.cityKey, page.url].filter(Boolean).join("::");
  }

  function getPublicUrl(page) {
    if (!page || !page.url) return SITE_ORIGIN;
    if (/^https?:\/\//i.test(page.url)) return page.url;
    return SITE_ORIGIN + page.url;
  }

  function escapeHtml(value) {
    return String(value == null ? "" : value)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  function escapeXml(value) {
    return escapeHtml(value);
  }

  function cssEscape(value) {
    if (window.CSS && window.CSS.escape) return window.CSS.escape(value);
    return String(value).replace(/"/g, '\\"');
  }

  init();
})();
</script>
