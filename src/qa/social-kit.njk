      }) : "",

      (showFooter || showFooterTagline) ? [
        '<g transform="translate(' + innerX + ' ' + footerY + ')">',
        showFooter ? '<text x="0" y="0" font-family="Arial, Helvetica, sans-serif" font-size="' + Math.round(25 * footerFieldScale) + '" font-weight="900" fill="#2f6f3e">' + escapeXml(footer) + '</text>' : '',
        showFooterTagline ? '<text x="' + (cardW - 120) + '" y="0" text-anchor="end" font-family="Arial, Helvetica, sans-serif" font-size="18" font-weight="700" fill="#526459">Local planting guidance</text>' : "",
        '</g>'
