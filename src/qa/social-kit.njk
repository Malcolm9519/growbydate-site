  ];

  const FIELD_PREF_KEYS = TEXT_CONTROL_FIELD_KEYS.reduce(function (list, key) {
    list.push(key + "TextSize", key + "OffsetY");
    return list;
  }, []);

  const IMAGE_PREF_STORAGE_KEY = "growbydate-social-kit-image-prefs-v3";
  const IMAGE_PREF_KEYS = [
    "showCityName", "showHeadline", "showIcon", "showBadge", "showBadgeText", "showAnswerLabel", "showSectionLabels", "showFooter", "showFooterTagline",
    "showAnswer", "showReason", "showSnapshot", "showFact1", "showFact2", "showFact3", "showTip", "showTipText",
    "showPlantingBox", "showPlantingBoxAnswer", "showPlantingBoxText", "showPlantingMethod", "showPlantingStartIndoors", "showPlantingTransplant", "showPlantingDirectSow", "showPlantingMaturity", "showPlantingBestVariety", "showPlantingNote",
    "showFrostBox", "showFrostBoxAnswer", "showFrostBoxText",
    "showSeasonBox", "showSeasonBoxAnswer", "showSeasonBoxText",
    "showMistakeBox", "showMistakeBoxAnswer", "showMistakeBoxText",
    "showFitBox", "showFitBoxAnswer", "showFitBoxText",
    "showDataBox", "showDataBoxAnswer", "showDataBoxText",
    "backgroundStyle", "textScale", "citySize", "titleSize", "emojiSize", "badgeSize",
