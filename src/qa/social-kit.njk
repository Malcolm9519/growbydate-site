  function bindImageControls() {
    els.images.querySelectorAll("[data-image-field]").forEach(function (field) {
      field.addEventListener("input", function () {
        const platformKey = field.getAttribute("data-image-field");
        refreshImage(platformKey, false);
      });
    });

    els.images.querySelectorAll("[data-image-control]").forEach(function (field) {
      const eventName = field.type === "checkbox" ? "change" : "input";
      field.addEventListener(eventName, function () {
        const platformKey = field.getAttribute("data-image-control");
        refreshImage(platformKey, false);
      });
    });

    els.images.querySelectorAll("[data-refresh-image]").forEach(function (button) {
      button.addEventListener("click", function () {
        refreshImage(button.getAttribute("data-refresh-image"), true);
      });
    });

    els.images.querySelectorAll("[data-download-image]").forEach(function (button) {
      button.addEventListener("click", function () {
        downloadPng(button.getAttribute("data-download-image"));
      });
    });

    els.images.querySelectorAll("[data-download-current-set]").forEach(function (button) {
      button.addEventListener("click", downloadCurrentPngSet);
    });

    els.images.querySelectorAll("[data-download-filtered-images]").forEach(function (button) {
      button.addEventListener("click", function () {
        downloadFilteredPngs(button.getAttribute("data-download-filtered-images"));
      });
    });

    els.images.querySelectorAll("[data-copy-svg]").forEach(function (button) {
      button.addEventListener("click", function () {
        const platformKey = button.getAttribute("data-copy-svg");
        const status = els.images.querySelector('[data-image-status="' + cssEscape(platformKey) + '"]');
        copyText(state.currentSvgs[platformKey] || "").then(function () {
          showStatus(status, "SVG copied.");
        });
      });
    });
  }

  function refreshImage(platformKey, showMessage) {
    const image = getImageValues(platformKey);
    rememberImagePrefs(platformKey, image);
    const svg = buildSvgCard(image, platformKey);
    const preview = els.images.querySelector('[data-image-preview="' + cssEscape(platformKey) + '"]');
    const status = els.images.querySelector('[data-image-status="' + cssEscape(platformKey) + '"]');
    const qa = els.images.querySelector('[data-image-qa="' + cssEscape(platformKey) + '"]');

    state.currentSvgs[platformKey] = svg;
    if (preview) preview.innerHTML = svg;
    if (qa) qa.innerHTML = buildQaListHtml(validateImageFields(platformKey, image));
    if (showMessage) showStatus(status, "Image refreshed.");
  }

  function getPlatformValues(platformKey) {
    const values = {};
    els.posts.querySelectorAll('[data-platform-field="' + cssEscape(platformKey) + '"]').forEach(function (field) {
      values[field.getAttribute("data-field-key")] = field.value;
    });
    return values;
  }

  function getImageValues(platformKey) {
    const base = state.kit && state.kit.images ? (state.kit.images[platformKey] || {}) : {};
    const values = Object.assign({}, base);

    els.images.querySelectorAll('[data-image-field="' + cssEscape(platformKey) + '"]').forEach(function (field) {
      values[field.getAttribute("data-image-key")] = field.value;
    });

    els.images.querySelectorAll('[data-image-control="' + cssEscape(platformKey) + '"]').forEach(function (field) {
      const key = field.getAttribute("data-image-key");
      if (field.type === "checkbox") {
        values[key] = field.checked;
      } else if (field.type === "number") {
        values[key] = field.value === "" ? "" : Number(field.value);
      } else {
        values[key] = field.value;
      }
    });

    values.platform = platformKey;
    values.angle = els.angle.value;
    values.cityName = values.cityName || (state.selectedPage ? state.selectedPage.cityName : values.cityName);
    values.cropName = values.cropName || (state.selectedPage ? state.selectedPage.cropName : values.cropName);
    return values;
  }

  function getPlatformCopyText(platformKey) {
    const values = getPlatformValues(platformKey);

    if (platformKey === "instagram") {
      return [
        values.caption || "",
        values.hashtags || "",
        "Alt text: " + (values.altText || "")
      ].filter(Boolean).join("\n\n");
    }

    if (platformKey === "pinterest") {
      return [
        "Title: " + (values.title || ""),
        "Description: " + (values.description || ""),
        "Alt text: " + (values.altText || ""),
        "URL: " + (values.destinationUrl || "")
      ].join("\n\n");
    }

    return Object.keys(values).map(function (key) {
      return key + ": " + values[key];
    }).join("\n");
  }

  function copyAllText() {
    if (!state.kit) return;

    const text = Object.keys(PLATFORMS).map(function (platformKey) {
      return "## " + PLATFORMS[platformKey].label + "\n\n" + getPlatformCopyText(platformKey);
    }).join("\n\n---\n\n");

    copyText(text).then(function () {
      els.copyAll.textContent = "Copied All";
      window.setTimeout(function () {
        els.copyAll.textContent = "Copy All Text";
      }, 1600);
    });
  }

  function exportJson() {
    if (!state.kit) return;

    const payload = {
      generatedAt: new Date().toISOString(),
      source: state.kit.source,
      platforms: {
        instagram: getPlatformValues("instagram"),
        pinterest: getPlatformValues("pinterest")
      },
      images: Object.assign({
        instagram: Object.assign(getImageValues("instagram"), { format: "1080x1350" }),
        pinterest: Object.assign(getImageValues("pinterest"), { format: "1000x1500" })
      }, state.kit.images && state.kit.images.cover ? { cover: Object.assign(getImageValues("cover"), { format: "1080x1350" }) } : {}),
      qa: {
        page: validatePageData(state.selectedPage, els.angle.value),
        instagram: validatePlatformPost("instagram", getPlatformValues("instagram"), state.selectedPage, els.angle.value),
        pinterest: validatePlatformPost("pinterest", getPlatformValues("pinterest"), state.selectedPage, els.angle.value),
        instagramImage: validateImageFields("instagram", getImageValues("instagram")),
        pinterestImage: validateImageFields("pinterest", getImageValues("pinterest"))
      }
    };

    downloadTextFile(
      "growbydate-social-kit-" + slugify(state.kit.source.cityName + "-" + state.kit.source.cropName + "-" + state.kit.source.angle) + ".json",
      JSON.stringify(payload, null, 2),
      "application/json"
    );
  }

  function downloadPng(platformKey) {
    const config = getImageConfig(platformKey);
    if (!config || !state.currentSvgs[platformKey] || !state.selectedPage) return;

    const filename = buildImageFilename(state.selectedPage, config, els.angle.value);
    const status = els.images.querySelector('[data-image-status="' + cssEscape(platformKey) + '"]');
    downloadSvgAsPng(state.currentSvgs[platformKey], config, filename, status);
  }

  function downloadCurrentPngSet() {
    if (!state.kit || !state.kit.images) return;
    const keys = getImagePlatformKeys(state.kit.images);
    keys.forEach(function (platformKey, index) {
      window.setTimeout(function () {
        refreshImage(platformKey, false);
        downloadPng(platformKey);
      }, index * 450);
    });
  }

  function downloadFilteredPngs(platformKey) {
    if (!state.selectedPage || !state.kit) return;
    const config = getImageConfig(platformKey);
    if (!config) return;

    const pages = (state.filteredPages && state.filteredPages.length) ? state.filteredPages.slice() : [state.selectedPage];
    if (!pages.length) return;

    const currentValues = getImageValues(platformKey);
    rememberImagePrefs(platformKey, currentValues);

    if (pages.length > 30) {
      const proceed = window.confirm('This will download ' + pages.length + ' PNG files for the current filter. Continue?');
      if (!proceed) return;
    }

    const status = els.images.querySelector('[data-image-status="' + cssEscape(platformKey) + '"]');
    showStatus(status, 'Starting ' + pages.length + ' downloads…');

    pages.forEach(function (page, index) {
      window.setTimeout(function () {
        const imagePayload = buildImagePayload(page, els.angle.value, platformKey);
        const svg = buildSvgCard(imagePayload, platformKey);
        const filename = buildImageFilename(page, config, els.angle.value);
        downloadSvgAsPng(svg, config, filename, index === pages.length - 1 ? status : null);
      }, index * 500);
    });
  }

  function buildImageFilename(page, config, angle) {
    return [
      'growbydate',
      config.filenamePart,
      slugify(page.cityName),
      slugify(page.cropName),
      slugify(angle)
    ].filter(Boolean).join('-') + '.png';
  }

  function downloadSvgAsPng(svg, config, filename, status) {
    const svgBlob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(svgBlob);
    const image = new Image();

    image.onload = function () {
      const canvas = document.createElement('canvas');
      canvas.width = config.width;
      canvas.height = config.height;

      const context = canvas.getContext('2d');
      context.fillStyle = '#ffffff';
      context.fillRect(0, 0, canvas.width, canvas.height);
      context.drawImage(image, 0, 0);

      URL.revokeObjectURL(url);

      canvas.toBlob(function (blob) {
        if (!blob) {
          showStatus(status, 'Could not create PNG.');
          return;
        }

        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();

        window.setTimeout(function () {
          URL.revokeObjectURL(link.href);
        }, 1000);

        showStatus(status, 'PNG downloaded.');
      }, 'image/png');
    };

    image.onerror = function () {
      URL.revokeObjectURL(url);
      showStatus(status, 'Could not render SVG.');
    };

    image.src = url;
  }

  function runBatchQa() {
    const angle = els.angle.value;
    const rows = [];
    const totals = { pass: 0, warn: 0, fail: 0 };

    data.forEach(function (page) {
      const kit = buildSocialKit(page, angle);
      const checks = []
        .concat(validatePageData(page, angle))
        .concat(validatePlatformPost("instagram", kit.platforms.instagram, page, angle))
        .concat(validatePlatformPost("pinterest", kit.platforms.pinterest, page, angle))
        .concat(validateImageFields("instagram", kit.images.instagram))
        .concat(validateImageFields("pinterest", kit.images.pinterest));

      const status = getOverallStatus(checks);
      totals[status] += 1;

      if (status !== "pass") {
        rows.push({
          status: status,
          page: page.cropName + " in " + page.cityName + ", " + page.regionName,
          angle: ANGLE_LABELS[angle] || angle,
          issues: checks.filter(function (check) {
            return check.status !== "pass";
          }).map(function (check) {
            return check.message;
          }).slice(0, 6)
        });
      }
    });

    const shownRows = rows.slice(0, 40);
    els.batchResults.hidden = false;
    els.batchResults.innerHTML = [
      '<div class="social-kit__qa-summary">',
      '<span class="social-kit__pill" data-status="pass">✓ ' + totals.pass + ' clean</span>',
      '<span class="social-kit__pill" data-status="warn">⚠ ' + totals.warn + ' warning</span>',
      '<span class="social-kit__pill" data-status="fail">× ' + totals.fail + ' failing</span>',
      '</div>',
      rows.length ? '<p class="social-kit__small">Showing the first ' + shownRows.length + ' rows with warnings or failures for the current angle.</p>' : '<p class="social-kit__small">No warnings or failures found for the current angle.</p>',
      shownRows.length ? [
        '<div class="social-kit__batch-table-wrap">',
        '<table class="social-kit__batch-table">',
        '<thead><tr><th>Status</th><th>Page</th><th>Angle</th><th>Issues</th></tr></thead>',
        '<tbody>',
        shownRows.map(function (row) {
          return [
            '<tr>',
            '<td><span class="social-kit__pill" data-status="' + escapeHtml(row.status) + '">' + escapeHtml(row.status.toUpperCase()) + '</span></td>',
            '<td>' + escapeHtml(row.page) + '</td>',
            '<td>' + escapeHtml(row.angle) + '</td>',
            '<td>' + row.issues.map(escapeHtml).join('<br>') + '</td>',
            '</tr>'
          ].join("");
        }).join(""),
        '</tbody></table></div>'
      ].join("") : ""
    ].join("");
  }

  function validatePageData(page, angle) {
    const checks = [];
    const dateRange = getPlantingDateRange(page);
    const springFrost = page.springFrost;
    const fallFrost = page.fallFrost;
    const frostFreeDays = page.frostFreeDays;
    const confidence = getConfidenceRaw(page);
    const gddLocal = getLocalGdd(page);
    const gddMargin = getGddMargin(page);
    const risk = getRiskSentence(page);
    const strategy = getStrategySentence(page);

    checks.push(check(dateRange, "Planting window is available.", "Missing planting window; generated copy may become generic."));
    checks.push(check(springFrost && fallFrost, "Spring and fall frost dates are available.", "Missing frost-date data."));
    checks.push(check(frostFreeDays, "Frost-free day count is available.", "Missing frost-free day count."));
    checks.push(check(confidence, "Fit/confidence label is available.", "Missing fit/confidence label."));

    if (angle === "short_season") {
      checks.push(check(gddLocal !== "" || frostFreeDays, "Season-length support data is available.", "Missing both local GDD and frost-free day support data."));
      checks.push(warnIf(gddMargin === "", "GDD margin is missing; season-check copy will lean on frost-free days and variety guidance."));
    }

    if (angle === "frost_risk" || angle === "common_mistake") {
      checks.push(check(risk || strategy, "Risk or strategy sentence is available.", "Missing risk/strategy sentence; angle may use fallback wording."));
    }

    return checks.filter(Boolean);
  }

  function validatePlatformPost(platformKey, post, page, angle) {
    const config = PLATFORMS[platformKey];
    const checks = [];
    const combined = Object.keys(post || {}).map(function (key) { return post[key]; }).join("\n");
    const city = page && page.cityName ? page.cityName : "";
    const crop = page && page.cropName ? page.cropName : "";

    config.fields.forEach(function (field) {
      const value = post[field.key] || "";
      const count = String(value).length;
      checks.push(check(count >= field.min, field.label + " is present.", field.label + " is too short or missing."));
      checks.push(warnIf(count > field.max, field.label + " is over the recommended max of " + field.max + " characters."));
    });

    checks.push(check(!containsBadToken(combined), "No placeholder values found.", "Contains undefined, null, NaN, Not listed, or [object Object]."));
    checks.push(check(!hasGrammarRedFlag(combined), "No obvious grammar red flags found.", "Potential grammar red flag found, such as “usually has.”"));
    checks.push(check(containsLoose(combined, city), "City is mentioned.", "City name is missing from the generated text."));
    checks.push(check(containsLoose(combined, crop), "Crop is mentioned.", "Crop name is missing from the generated text."));
    checks.push(warnIf(usesGenericFallback(combined), "Generic fallback wording is present; check whether source data is missing."));

    if (platformKey === "instagram") {
      const hashtags = extractHashtags((post.caption || "") + " " + (post.hashtags || ""));
      checks.push(check(hashtags.length >= 4, "Instagram has at least 4 hashtags.", "Instagram hashtag set is too thin."));
      checks.push(warnIf(hashtags.length > 12, "Instagram has more than 12 hashtags; consider trimming."));
      checks.push(check(String(post.altText || "").length >= 60, "Instagram alt text is usable.", "Instagram alt text is missing or too thin."));
    }

    if (platformKey === "pinterest") {
      checks.push(check(/^https?:\/\//i.test(post.destinationUrl || ""), "Pinterest destination URL is present.", "Pinterest destination URL is missing or invalid."));
      checks.push(check(String(post.title || "").length <= 100, "Pinterest title fits common title limits.", "Pinterest title is too long."));
      checks.push(check(String(post.description || "").length <= 500, "Pinterest description fits common description limits.", "Pinterest description is too long."));
      checks.push(check(String(post.altText || "").length >= 60, "Pinterest alt text is usable.", "Pinterest alt text is missing or too thin."));
    }

    return checks.filter(Boolean);
  }

  function validateImageFields(platformKey, image) {
    const checks = [];
    const showHeadline = boolSetting(image.showHeadline, true);
    const showBadge = boolSetting(image.showBadge, true);
    const showBadgeText = boolSetting(image.showBadgeText, true);
    const showAnswer = boolSetting(image.showAnswer, true);
    const showReason = boolSetting(image.showReason, true);
    const showSnapshot = boolSetting(image.showSnapshot, true);
    const showFact1 = boolSetting(image.showFact1, true);
    const showFact2 = boolSetting(image.showFact2, true);
    const showFact3 = boolSetting(image.showFact3, true);
    const showTip = (platformKey === "pinterest" || platformKey === "cover") && boolSetting(image.showTip, true) && boolSetting(image.showTipText, true);
    const showFooter = boolSetting(image.showFooter, true);
    const layout = estimateImageLayout(platformKey, image);
    const visibleFacts = [
      showSnapshot && showFact1 ? (image.fact1 || image.bullet1) : "",
      showSnapshot && showFact2 ? (image.fact2 || image.bullet2) : "",
      showSnapshot && showFact3 ? image.fact3 : ""
    ].filter(Boolean);
    const fields = [
      showHeadline ? image.headline : "",
      showBadge && showBadgeText ? image.badge : "",
      showAnswer ? (image.answer || image.primary) : "",
      showReason ? image.reason : "",
      visibleFacts.join(" "),
      showTip ? image.tip : "",
      showFooter ? image.footer : ""
    ];
    const combined = fields.join(" ");
    const usefulText = [
      showAnswer ? (image.answer || image.primary) : "",
      showReason ? image.reason : "",
      visibleFacts.join(" "),
      showTip ? image.tip : ""
    ].filter(Boolean).join(" ");
    const headlineLength = String(image.headline || "").length;
    const answerLength = String(image.answer || image.primary || "").length;
    const reasonLength = String(image.reason || "").length;
    const badgeLength = String(image.badge || "").length;
    const factCount = visibleFacts.length;
    const usefulMin = platformKey === "pinterest" ? (showSnapshot ? 160 : 100) : (showSnapshot ? 120 : 80);
    const usefulMax = platformKey === "pinterest" ? 560 : 460;

    checks.push(check(!showHeadline || image.headline, "Image headline is present.", "Image headline is enabled but missing."));
    checks.push(check(!showAnswer || image.answer || image.primary, "Image quick answer is present.", "Quick answer is enabled but missing."));
    checks.push(check(!showReason || reasonLength >= 35, "Image includes an explanatory reason.", "Reason is enabled but too thin; add why the dates matter."));
    checks.push(check(!showBadge || !showBadgeText || image.badge, "Angle pill text is available.", "Angle pill text is enabled but missing."));
    checks.push(check(!showSnapshot || factCount >= 1, "Image includes local fact data.", "Local facts are enabled but all fact fields are hidden or empty."));
    checks.push(check(usefulText.length >= usefulMin, "Image copy has enough useful substance.", "Visible image copy may be too thin; add a reason, local context, or practical action."));
    checks.push(warnIf(usefulText.length > usefulMax, "Image copy is getting dense; preview for readability."));
    checks.push(warnIf(layout.overflows, "Image sections may run into the footer. Remove a section, lower text scale, or use smaller extra-height values."));
    checks.push(check(!containsBadToken(combined), "Image has no placeholder values.", "Image text contains undefined, null, NaN, Not listed, or [object Object]."));
    checks.push(check(!hasGrammarRedFlag(combined), "Image text has no obvious grammar red flags.", "Image text has a likely grammar issue."));
    checks.push(warnIf(showHeadline && headlineLength > (platformKey === "pinterest" ? 58 : 52), "Headline may wrap too much; preview carefully."));
    checks.push(warnIf(showAnswer && answerLength > (platformKey === "pinterest" ? 140 : 125), "Quick answer is long; the box will expand, but preview the layout."));
    checks.push(warnIf(showBadge && showBadgeText && badgeLength > 24, "Badge is long; keep it punchy."));
    checks.push(check(platformKey !== "pinterest" || PLATFORMS.pinterest.height / PLATFORMS.pinterest.width === 1.5, "Pinterest image is vertical 2:3.", "Pinterest image is not vertical 2:3."));
    checks.push(check(platformKey !== "instagram" || PLATFORMS.instagram.height / PLATFORMS.instagram.width === 1.25, "Instagram image is 4:5.", "Instagram image is not 4:5."));

    return checks.filter(Boolean);
  }

  function check(condition, passMessage, failMessage) {
    return {
      status: condition ? "pass" : "fail",
      message: condition ? passMessage : failMessage
    };
  }

  function warnIf(condition, message) {
    return condition ? { status: "warn", message: message } : null;
  }

  function renderQaList(container, checks) {
    container.innerHTML = buildQaListHtml(checks);
  }

  function renderQaSummary(container, checks, label) {
    container.innerHTML = buildQaSummaryHtml(checks, label);
  }

  function buildQaListHtml(checks) {
    return checks.map(function (item) {
      const mark = item.status === "pass" ? "✓" : (item.status === "warn" ? "⚠" : "×");
      return [
        '<li class="social-kit__qa-item" data-status="' + escapeHtml(item.status) + '">',
        '<span class="social-kit__qa-mark">' + mark + '</span>',
        '<span>' + escapeHtml(item.message) + '</span>',
        '</li>'
      ].join("");
    }).join("");
  }

  function buildQaSummaryHtml(checks, label) {
    const counts = countStatuses(checks);
    const overall = getOverallStatus(checks);
    return [
      '<span class="social-kit__pill" data-status="' + overall + '">' + escapeHtml(label) + ': ' + overall.toUpperCase() + '</span>',
      '<span class="social-kit__pill" data-status="pass">✓ ' + counts.pass + '</span>',
      '<span class="social-kit__pill" data-status="warn">⚠ ' + counts.warn + '</span>',
      '<span class="social-kit__pill" data-status="fail">× ' + counts.fail + '</span>'
    ].join("");
  }

  function countStatuses(checks) {
    return checks.reduce(function (counts, item) {
      counts[item.status] = (counts[item.status] || 0) + 1;
      return counts;
    }, { pass: 0, warn: 0, fail: 0 });
  }

  function getOverallStatus(checks) {
    if (checks.some(function (item) { return item.status === "fail"; })) return "fail";
    if (checks.some(function (item) { return item.status === "warn"; })) return "warn";
    return "pass";
  }

  function getInstagramOpening(page, angle) {
    const cropLower = lowerFirst(page.cropName || "this crop");
    const city = page.cityName || "your city";

    if (angle === "frost_risk") {
      return "Growing " + cropLower + " in " + city + "? Start with the frost dates, not a generic seed packet date.";
    }

    if (angle === "short_season") {
      return "Will " + cropLower + " mature in " + city + "? Start with the local heat window, not just days to maturity.";
    }

    if (angle === "easy_or_risky") {
      return "Can you grow " + cropLower + " in " + city + "? The answer depends on local season length, planting timing, and variety speed.";
    }

    if (angle === "common_mistake") {
      return "Before planting " + cropLower + " in " + city + ", watch for this local timing mistake.";
    }

    if (angle === "planting_guide") {
      return city + " gardeners: start with local frost dates, season length, and planting windows.";
    }

    return "Growing " + cropLower + " in " + city + "? Timing can make or break the season.";
  }

  function getInstagramCloser(page, angle) {
    const city = page.cityName || "your city";

    if (angle === "common_mistake") {
      return "GrowByDate checks the local window so you can plant with more context and less guesswork.";
    }

    if (angle === "frost_risk") {
      return "Use the local GrowByDate guide before you plant in " + city + ".";
    }

    if (angle === "planting_guide") {
      return "Save this local planting guide before planning your spring garden.";
    }

    return "Save the local GrowByDate guide before you plant.";
  }

  function getAngleSentence(page, angle) {
    const cropLower = lowerFirst(page.cropName || "this crop");
    const city = page.cityName || "your city";
    const confidence = getConfidenceRaw(page);
    const risk = getRiskSentence(page);
    const strategy = getStrategySentence(page);
    const gddMargin = getGddMargin(page);
    const localGdd = getLocalGdd(page);
    const frostFreeDays = page.frostFreeDays;

    if (angle === "frost_risk") {
      return cleanSentence(risk || "In " + city + ", frost timing can make a real difference for " + cropLower + ".");
    }

    if (angle === "short_season") {
      const confidenceLabel = getConfidenceLabel(page).toLowerCase();
      const tightFit = /tight|risk|poor|borderline|timing/.test(confidenceLabel);

      if (tightFit) {
        return "In " + city + ", " + cropLower + " needs an early start, fast varieties, and the warmest practical garden spot.";
      }

      return cleanSentence(strategy || (frostFreeDays ? city + " has about " + frostFreeDays + " frost-free days, so match the variety and planting date to that local window." : city + " has a limited growing window, so timing and variety speed matter for " + cropLower + "."));
    }

    if (angle === "easy_or_risky") {
      if (confidence) {
        return "Local fit for " + cropLower + " in " + city + " is " + getConfidenceLabel(page).toLowerCase() + " when the planting window is respected.";
      }

      return "The local season length, frost dates, and planting window all affect whether " + cropLower + " is a good fit for " + city + ".";
    }

    if (angle === "common_mistake") {
      return cleanSentence(risk || getCommonMistakeText(page));
    }

    if (angle === "planting_guide") {
      return cleanSentence("Use the local frost dates, season length, and crop timing framework for " + city + " before picking planting dates.");
    }

    return getWindowSentence(page) || "Local planting timing can make a big difference for " + cropLower + " in " + city + ".";
  }

  function getPinterestTitle(page, angle) {
    const cropName = page.cropName || "This Crop";
    const city = page.cityName || "Your City";

    if (angle === "frost_risk") return cropName + " Frost Dates and Planting Timing in " + city;
    if (angle === "short_season") return "Will " + cropName + " Mature in Time in " + city + "?";
    if (angle === "easy_or_risky") return "Can You Grow " + cropName + " in " + city + "?";
    if (angle === "common_mistake") return cropName + " Planting Mistakes to Avoid in " + city;
    if (angle === "planting_guide") return city + " Planting Guide";

    return "When to Plant " + cropName + " in " + city;
  }

  function getPinterestDescription(page, angle) {
    const cropLower = lowerFirst(page.cropName || "this crop");
    const city = page.cityName || "your city";
    const region = page.regionName || page.country || "";
    const location = city + (region ? ", " + region : "");
    const planting = getPlantingSentence(page);
    const strategy = getStrategySentence(page);
    const risk = getRiskSentence(page);

    if (angle === "frost_risk") {
      return cleanSentence("Check local frost dates, planting windows, and risk notes for growing " + cropLower + " in " + location + ". " + (risk || planting));
    }

    if (angle === "short_season") {
      return cleanSentence("See whether " + cropLower + " has enough season to mature in " + location + ", with local frost timing, season-length context, and variety-speed guidance. " + (strategy || planting));
    }

    if (angle === "easy_or_risky") {
      return cleanSentence("Check whether " + cropLower + " is a good, tight, or risky crop for " + location + " based on season length, frost dates, planting timing, and variety fit. " + (strategy || planting));
    }

    if (angle === "common_mistake") {
      return cleanSentence("Avoid common timing mistakes when planting " + cropLower + " in " + location + ". " + (risk || getCommonMistakeText(page) || planting));
    }

    if (angle === "planting_guide") {
      return cleanSentence("Plan your garden with local frost dates, season length, and planting-window context for " + location + ". " + (planting || strategy));
    }

    return cleanSentence("Find local planting dates, frost timing, season-length context, and practical growing guidance for " + cropLower + " in " + location + ". " + planting);
  }

  function buildAltText(page, angle, fallback) {
    const cropName = page.cropName || "this crop";
    const city = page.cityName || "your city";
    const range = getPlantingDateRange(page);
    const frostFreeDays = page.frostFreeDays;
    const confidence = getConfidenceLabel(page);

    const parts = [
      angle === "planting_guide" ? "GrowByDate planting guide cover graphic for " + city + "." : "GrowByDate social graphic for " + cropName + " in " + city + ".",
      range ? "It highlights a local planting window around " + range + "." : "It highlights local planting timing.",
      frostFreeDays ? "The page lists about " + frostFreeDays + " frost-free days." : "",
      confidence ? "Local fit is shown as " + confidence.toLowerCase() + "." : ""
    ].filter(Boolean);

    return cleanSentence(parts.join(" ") || fallback);
  }

