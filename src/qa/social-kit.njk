      '<circle cx="' + (width - 110) + '" cy="' + (isPinterest ? 145 : 150) + '" r="' + (isPinterest ? 145 : 150) + '" fill="' + style.sunOuter + '" opacity="0.94"/>',
      '<circle cx="' + (width - 110) + '" cy="' + (isPinterest ? 145 : 150) + '" r="' + (isPinterest ? 106 : 110) + '" fill="' + style.sunInner + '" opacity="0.82"/>',
      '<path d="M0 ' + hillY1 + ' C220 ' + (hillY1 - 90) + ' 420 ' + (hillY1 - 30) + ' 620 ' + (hillY1 - 80) + ' C800 ' + (hillY1 - 125) + ' 940 ' + (hillY1 - 40) + ' ' + width + ' ' + (hillY1 - 80) + ' L' + width + ' ' + height + ' L0 ' + height + ' Z" fill="#1f4d2f" opacity="0.18"/>',
