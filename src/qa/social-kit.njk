        showBadgeText ? '<text x="' + (badgeW / 2) + '" y="' + (Math.round(35 * badgeScale) + badgeFieldOffset) + '" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="' + Math.round(21 * badgeScale * badgeFieldScale) + '" font-weight="950" fill="#ffffff">' + escapeXml(badge) + '</text>' : '', 
