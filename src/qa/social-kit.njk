          answerDy: layout.answerDy,
          answerOffsetY: layout.answerOffsetY,
          textSizeLocal: layout.textSizeLocal,
          textDyLocal: layout.textDyLocal,
          textOffsetY: layout.textOffsetY,
          image: image,
          module: layout.module
        });
      }).join(""),

      showSnapshot ? buildSvgSnapshotBox({
        x: boxX,
        y: snapshotY,
        width: boxW,
        height: snapshotH,
        accent: style.accent,
        label: showSectionLabels ? "LOCAL SNAPSHOT" : "",
        facts: factEntries,
        isPinterest: isPinterest,
        labelSize: Math.round((isPinterest ? 24 : 22) * textScale)
      }) : "",

      showTip ? buildSvgTipBox({
        x: boxX,
        y: tipY,
