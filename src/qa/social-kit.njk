  function bindPostControls() {
    els.posts.querySelectorAll("[data-platform-field]").forEach(function (field) {
      field.addEventListener("input", function () {
        refreshFieldCount(field);
        refreshPlatformQa(field.getAttribute("data-platform-field"));
      });
    });

    els.posts.querySelectorAll("[data-copy-platform]").forEach(function (button) {
      button.addEventListener("click", function () {
        const platformKey = button.getAttribute("data-copy-platform");
        const status = els.posts.querySelector('[data-status="' + cssEscape(platformKey) + '"]');
        copyText(getPlatformCopyText(platformKey)).then(function () {
          showStatus(status, "Copied.");
        });
      });
    });

    els.posts.querySelectorAll("[data-reset-platform]").forEach(function (button) {
      button.addEventListener("click", function () {
        const platformKey = button.getAttribute("data-reset-platform");
        const original = state.kit && state.kit.platforms ? state.kit.platforms[platformKey] : null;
        if (!original) return;

        Object.keys(original).forEach(function (key) {
          const field = els.posts.querySelector('[data-platform-field="' + cssEscape(platformKey) + '"][data-field-key="' + cssEscape(key) + '"]');
          if (field) field.value = original[key] || "";
        });

        refreshAllFieldCounts();
        refreshPlatformQa(platformKey);
      });
    });
  }

  function refreshPlatformQa(platformKey) {
    const post = getPlatformValues(platformKey);
    const checks = validatePlatformPost(platformKey, post, state.selectedPage, els.angle.value);
    const list = els.posts.querySelector('[data-platform-qa="' + cssEscape(platformKey) + '"]');
    const summary = els.posts.querySelector('[data-platform-summary="' + cssEscape(platformKey) + '"]');

    if (list) list.innerHTML = buildQaListHtml(checks);
    if (summary) summary.innerHTML = buildQaSummaryHtml(checks, "QA");
  }

  function refreshAllFieldCounts() {
    els.posts.querySelectorAll("[data-platform-field]").forEach(refreshFieldCount);
  }

  function refreshFieldCount(field) {
    const platformKey = field.getAttribute("data-platform-field");
    const fieldKey = field.getAttribute("data-field-key");
    const config = PLATFORMS[platformKey];
    const fieldConfig = config && config.fields.find(function (item) { return item.key === fieldKey; });
    const status = els.posts.querySelector('[data-count-for="' + cssEscape(platformKey + ":" + fieldKey) + '"]');

    if (!status || !fieldConfig) return;

    const count = String(field.value || "").length;
    const label = getLengthLabel(count, fieldConfig);
    status.innerHTML = '<span>' + count + ' characters</span><strong>' + escapeHtml(label) + '</strong>';
  }

  function renderImages(images) {
