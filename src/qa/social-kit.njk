  function buildSvgGuideCoverCard(image, platformKey, style, cropEmoji) {
    const config = getImageConfig(platformKey);
    const width = config.width;
    const height = config.height;
    const city = image.cityName || "Your City";
    const headline = image.headline || "Planting Guide";
    const answer = image.answer || "Frost dates, season length, and planting windows for local gardens.";
    const reason = image.reason || "Start here before choosing crop-by-crop planting dates.";
    const footer = image.footer || "GrowByDate.com";
    const tip = image.tip || "Swipe for crop-by-crop timing.";

    const showCityName = boolSetting(image.showCityName, true);
    const showHeadline = boolSetting(image.showHeadline, true);
    const showIcon = boolSetting(image.showIcon, true);
    const showAnswer = boolSetting(image.showAnswer, true);
    const showReason = boolSetting(image.showReason, true);
    const showSnapshot = boolSetting(image.showSnapshot, true);
    const showFact1 = boolSetting(image.showFact1, true);
    const showFact2 = boolSetting(image.showFact2, true);
    const showFact3 = boolSetting(image.showFact3, true);
    const showTip = boolSetting(image.showTip, true) && boolSetting(image.showTipText, true);
    const showFooter = boolSetting(image.showFooter, true);
    const showFooterTagline = boolSetting(image.showFooterTagline, true);
    const showSectionLabels = boolSetting(image.showSectionLabels, true);

    const textScale = clampNumber(Number(image.textScale || 104), 35, 260) / 100;
    const cityScale = clampNumber(Number(image.citySize || 110), 25, 320) / 100;
    const titleScale = clampNumber(Number(image.titleSize || 118), 25, 320) / 100;
    const emojiScale = clampNumber(Number(image.emojiSize || 100), 25, 320) / 100;
    const coverStatsShiftY = clampNumber(Number(image.coverStatsShiftY || 0), -600, 600);
    const coverCtaShiftY = clampNumber(Number(image.coverCtaShiftY || 0), -600, 600);

    const cityFieldScale = getFieldScale(image, "cityName", 100);
    const cityFieldOffset = getFieldOffset(image, "cityName");
    const headlineFieldScale = getFieldScale(image, "headline", 100);
    const headlineFieldOffset = getFieldOffset(image, "headline");
    const answerFieldScale = getFieldScale(image, "answer", 100);
    const answerFieldOffset = getFieldOffset(image, "answer");
    const reasonFieldScale = getFieldScale(image, "reason", 100);
    const reasonFieldOffset = getFieldOffset(image, "reason");
    const tipFieldScale = getFieldScale(image, "tip", 100);
    const tipFieldOffset = getFieldOffset(image, "tip");
    const footerFieldScale = getFieldScale(image, "footer", 100);
    const footerFieldOffset = getFieldOffset(image, "footer");
    const emojiFieldScale = getFieldScale(image, "emoji", 100);
    const emojiFieldOffset = getFieldOffset(image, "emoji");

    const centerX = width / 2;
    const cityFont = Math.round(42 * cityScale * cityFieldScale);
    const titleFont = Math.round(108 * titleScale * headlineFieldScale);
    const titleDy = Math.round(titleFont * 0.9);
    const subtitleFont = Math.round(33 * textScale * answerFieldScale);
    const subtitleDy = Math.round(subtitleFont * 1.22);
    const reasonFont = Math.round(24 * textScale * reasonFieldScale);
    const reasonDy = Math.round(reasonFont * 1.28);
    const iconSize = Math.round(118 * emojiScale * emojiFieldScale);
    const topY = 118;
    const cityY = topY + cityFieldOffset;
    const titleY = cityY + (showCityName ? 115 : 40) + headlineFieldOffset;
    const titleLines = showHeadline ? wrapText(headline, Math.max(10, Math.round(13 / Math.max(0.4, titleScale * headlineFieldScale))), 2) : [];
    const subtitleY = titleY + Math.max(titleDy, titleLines.length * titleDy) + 58 + answerFieldOffset;
    const answerLines = showAnswer ? wrapText(answer, Math.max(18, Math.round(36 / (textScale * answerFieldScale))), 3) : [];
    const reasonLines = showReason ? wrapText(reason, Math.max(20, Math.round(44 / (textScale * reasonFieldScale))), 2) : [];
    const facts = [
      showFact1 ? { key: "fact1", raw: image.fact1 || image.bullet1 } : null,
      showFact2 ? { key: "fact2", raw: image.fact2 || image.bullet2 } : null,
      showFact3 ? { key: "fact3", raw: image.fact3 } : null
    ].filter(Boolean).map(function (entry) {
      const parsed = parseGuideStatFact(entry.raw);
      const scale = getFieldScale(image, entry.key, 100);
      return {
        key: entry.key,
        label: parsed.label,
        value: parsed.value,
        valueLines: wrapText(parsed.value, parsed.value.length > 18 ? 14 : 13, 2),
        valueFont: Math.round((parsed.value.length > 15 ? 29 : 35) * scale),
        labelFont: Math.round(17 * Math.min(scale, 1.3)),
        offsetY: getFieldOffset(image, entry.key)
      };
    }).slice(0, 3);
    const statY = 825 + coverStatsShiftY;
    const statW = 274;
    const statH = 132;
    const statGap = 28;
    const statStartX = centerX - ((facts.length * statW + Math.max(0, facts.length - 1) * statGap) / 2);
    const ctaY = 1030 + coverCtaShiftY;
    const ctaH = 115;
    const footerY = height - 72 + footerFieldOffset;
    const ctaLines = showTip ? wrapText(tip, Math.max(22, Math.round(42 / tipFieldScale)), 2) : [];

    function centeredLines(lines, y, fontSize, weight, fill, dy, letterSpacing) {
      return (lines || []).map(function (line, index) {
        return '<text x="' + centerX + '" y="' + (y + index * dy) + '" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="' + fontSize + '" font-weight="' + weight + '" fill="' + fill + '" letter-spacing="' + (letterSpacing || 0) + '">' + escapeXml(line) + '</text>';
      }).join("");
    }

    const titleMarkup = centeredLines(titleLines, titleY, titleFont, 950, "#ffffff", titleDy, -1.4);
    const answerMarkup = centeredLines(answerLines, subtitleY, subtitleFont, 900, "#fff3bd", subtitleDy, 0);
    const reasonMarkup = centeredLines(reasonLines, subtitleY + answerLines.length * subtitleDy + (answerLines.length ? 30 : 0) + reasonFieldOffset, reasonFont, 800, "#e2efdf", reasonDy, 0);
    const statMarkup = showSnapshot ? facts.map(function (fact, index) {
      const x = statStartX + index * (statW + statGap);
      return [
        '<g>',
        '<rect x="' + x + '" y="' + statY + '" width="' + statW + '" height="' + statH + '" rx="30" fill="#fbf7ef" opacity="0.95"/>',
        showSectionLabels ? '<text x="' + (x + statW / 2) + '" y="' + (statY + 38) + '" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="' + fact.labelFont + '" font-weight="950" fill="#2f6f3e" letter-spacing="1.1">' + escapeXml(fact.label.toUpperCase()) + '</text>' : '',
        fact.valueLines.map(function (line, lineIndex) {
          return '<text x="' + (x + statW / 2) + '" y="' + (statY + (showSectionLabels ? 84 : 68) + fact.offsetY + lineIndex * (fact.valueFont + 7)) + '" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="' + fact.valueFont + '" font-weight="950" fill="#1e3f28">' + escapeXml(line) + '</text>';
        }).join(''),
        '</g>'
      ].join('');
    }).join('') : '';

    return [
      '<svg xmlns="http://www.w3.org/2000/svg" width="' + width + '" height="' + height + '" viewBox="0 0 ' + width + ' ' + height + '" role="img" aria-label="GrowByDate planting guide cover for ' + escapeXml(city) + '">',
      '<defs>',
      '<linearGradient id="guideCoverBg-' + platformKey + '" x1="0" y1="0" x2="1" y2="1">',
      '<stop offset="0%" stop-color="#12351f"/>',
      '<stop offset="52%" stop-color="' + style.bgStart + '"/>',
      '<stop offset="100%" stop-color="' + style.bgEnd + '"/>',
      '</linearGradient>',
      '<radialGradient id="guideCoverGlow-' + platformKey + '" cx="72%" cy="16%" r="56%">',
      '<stop offset="0%" stop-color="' + style.sunInner + '" stop-opacity="0.9"/>',
      '<stop offset="45%" stop-color="' + style.sunOuter + '" stop-opacity="0.42"/>',
      '<stop offset="100%" stop-color="' + style.sunOuter + '" stop-opacity="0"/>',
      '</radialGradient>',
      '<pattern id="guideCoverPattern-' + platformKey + '" width="78" height="78" patternUnits="userSpaceOnUse">',
      '<path d="M18 42 C18 24 38 18 54 18 C52 38 40 52 18 42Z" fill="#ffffff" opacity="0.07"/>',
      '</pattern>',
      '</defs>',
      '<rect width="' + width + '" height="' + height + '" fill="url(#guideCoverBg-' + platformKey + ')"/>',
      '<rect width="' + width + '" height="' + height + '" fill="url(#guideCoverPattern-' + platformKey + ')"/>',
      '<rect width="' + width + '" height="' + height + '" fill="url(#guideCoverGlow-' + platformKey + ')"/>',
      '<circle cx="' + (width - 150) + '" cy="145" r="170" fill="#fff3bd" opacity="0.16"/>',
      '<path d="M0 870 C230 760 430 915 625 805 C820 690 940 850 1080 760 L1080 1350 L0 1350 Z" fill="#0e2d1a" opacity="0.34"/>',
      '<path d="M0 1000 C220 910 430 1055 640 965 C820 890 960 1020 1080 935 L1080 1350 L0 1350 Z" fill="#ffffff" opacity="0.08"/>',
      showIcon ? [
        '<g transform="translate(' + (width - iconSize - 104) + ' ' + (116 + emojiFieldOffset) + ')">',
        '<circle cx="' + (iconSize / 2) + '" cy="' + (iconSize / 2) + '" r="' + (iconSize / 2) + '" fill="#fbf7ef" opacity="0.94"/>',
        '<circle cx="' + (iconSize / 2) + '" cy="' + (iconSize / 2) + '" r="' + (iconSize * 0.36) + '" fill="#2f6f3e" opacity="0.16"/>',
        buildEmojiIcon(iconSize, cropEmoji || "🌱"),
        '</g>'
      ].join('') : '',
      showCityName ? '<text x="' + centerX + '" y="' + cityY + '" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="' + cityFont + '" font-weight="950" fill="#fff3bd" letter-spacing="3.2">' + escapeXml(city.toUpperCase()) + '</text>' : '',
      titleMarkup,
      answerMarkup,
      reasonMarkup,
      statMarkup,
      showTip ? [
        '<g>',
        '<rect x="120" y="' + ctaY + '" width="840" height="' + ctaH + '" rx="42" fill="#fbf7ef" opacity="0.95"/>',
        ctaLines.map(function (line, index) {
          return '<text x="' + centerX + '" y="' + (ctaY + 48 + tipFieldOffset + index * Math.round(35 * tipFieldScale)) + '" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="' + Math.round(30 * tipFieldScale) + '" font-weight="950" fill="#1f3f28">' + escapeXml(line) + '</text>';
        }).join(''),
        '</g>'
      ].join('') : '',
      '<path d="M100 1218 C165 1160 240 1160 310 1218" fill="none" stroke="#fff3bd" stroke-width="7" stroke-linecap="round" opacity="0.38"/>',
      '<path d="M770 1218 C840 1160 915 1160 980 1218" fill="none" stroke="#fff3bd" stroke-width="7" stroke-linecap="round" opacity="0.38"/>',
      (showFooter || showFooterTagline) ? [
        '<g transform="translate(' + centerX + ' ' + footerY + ')">',
        showFooter ? '<text x="0" y="0" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="' + Math.round(34 * footerFieldScale) + '" font-weight="950" fill="#ffffff">' + escapeXml(footer) + '</text>' : '',
        showFooterTagline ? '<text x="0" y="34" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="18" font-weight="800" fill="#dcebdc" opacity="0.92">Local planting guidance</text>' : '',
        '</g>'
      ].join('') : '',
      '</svg>'
    ].join('');
  }

  function parseGuideStatFact(text) {
    const value = String(text || '').replace(/^•\s*/, '').trim();
    const match = value.match(/^([^:]+):\s*(.+)$/);
    if (!match) return { label: 'LOCAL NOTE', value: value, note: '' };

    let label = match[1].trim();
    let factValue = match[2].trim();
    if (/last frost/i.test(label)) label = 'Last spring frost';
    else if (/fall frost/i.test(label)) label = 'First fall frost';
    else if (/season/i.test(label)) {
      label = 'Frost-free season';
      const daysMatch = factValue.match(/(\d+)/);
      if (daysMatch) factValue = daysMatch[1] + ' days';
    }
    return { label: label, value: factValue, note: '' };
  }

  function getVisibleCardModules(image, platformKey) {
    const showLabels = boolSetting(image.showSectionLabels, true);
    const rows = getUnifiedContentBoxRows(image, showLabels);

    if (!rows.length) return [];

    return [{
      flag: "showUnifiedContentBox",
      label: showLabels ? "DETAILS" : "",
      answerKey: "",
      answer: "",
      rows: rows
    }];
  }

  function getUnifiedContentBoxRows(image, showLabels) {
    const rows = [];

    function addSection(title, enabled, items) {
      if (!enabled) return;
      const visibleItems = (items || []).filter(function (item) {
        return item && item.text;
      });
      if (!visibleItems.length) return;

      if (showLabels) rows.push({ key: "section-" + slugify(title), text: title, isHeading: true, synthetic: true });
      visibleItems.forEach(function (item) { rows.push(item); });
    }

    addSection("Planting window", boolSetting(image.showPlantingBox, false), getStructuredPlantingBoxItems(image));
    addSection("Frost timing", boolSetting(image.showFrostBox, false), [
      boolSetting(image.showFrostBoxAnswer, true) && image.frostBoxAnswer ? { key: "frostBoxAnswer", text: image.frostBoxAnswer, isEmphasis: true } : null,
      boolSetting(image.showFrostBoxText, true) && image.frostBoxText ? { key: "frostBoxText", text: image.frostBoxText } : null
    ]);
    addSection("Heat / maturity", boolSetting(image.showSeasonBox, false), [
      boolSetting(image.showSeasonBoxAnswer, true) && image.seasonBoxAnswer ? { key: "seasonBoxAnswer", text: image.seasonBoxAnswer, isEmphasis: true } : null,
      boolSetting(image.showSeasonBoxText, true) && image.seasonBoxText ? { key: "seasonBoxText", text: image.seasonBoxText } : null
    ]);
    addSection("Timing mistake", boolSetting(image.showMistakeBox, false), [
      boolSetting(image.showMistakeBoxAnswer, true) && image.mistakeBoxAnswer ? { key: "mistakeBoxAnswer", text: image.mistakeBoxAnswer, isEmphasis: true } : null,
      boolSetting(image.showMistakeBoxText, true) && image.mistakeBoxText ? { key: "mistakeBoxText", text: image.mistakeBoxText } : null
    ]);
    addSection("Local fit", boolSetting(image.showFitBox, false), [
      boolSetting(image.showFitBoxAnswer, true) && image.fitBoxAnswer ? { key: "fitBoxAnswer", text: image.fitBoxAnswer, isEmphasis: true } : null,
      boolSetting(image.showFitBoxText, true) && image.fitBoxText ? { key: "fitBoxText", text: image.fitBoxText } : null
    ]);
    addSection("Data / ranking", boolSetting(image.showDataBox, false), [
      boolSetting(image.showDataBoxAnswer, true) && image.dataBoxAnswer ? { key: "dataBoxAnswer", text: image.dataBoxAnswer, isEmphasis: true } : null,
      boolSetting(image.showDataBoxText, true) && image.dataBoxText ? { key: "dataBoxText", text: image.dataBoxText } : null
    ]);

    return rows;
  }

  function getStructuredPlantingBoxItems(image) {
    const items = [
      boolSetting(image.showPlantingBoxAnswer, true) && image.plantingBoxAnswer ? { key: "plantingBoxAnswer", text: image.plantingBoxAnswer, isEmphasis: true } : null,
      boolSetting(image.showPlantingMethod, true) && image.plantingMethodText ? { key: "plantingMethodText", text: "Method: " + image.plantingMethodText } : null,
      boolSetting(image.showPlantingStartIndoors, true) && image.plantingStartIndoorsText ? { key: "plantingStartIndoorsText", text: "Start indoors: " + image.plantingStartIndoorsText } : null,
      boolSetting(image.showPlantingTransplant, true) && image.plantingTransplantText ? { key: "plantingTransplantText", text: "Transplant: " + image.plantingTransplantText } : null,
      boolSetting(image.showPlantingDirectSow, true) && image.plantingDirectSowText ? { key: "plantingDirectSowText", text: "Direct sow: " + image.plantingDirectSowText } : null,
      boolSetting(image.showPlantingMaturity, true) && image.plantingMaturityText ? { key: "plantingMaturityText", text: "Maturity: " + image.plantingMaturityText } : null,
      boolSetting(image.showPlantingBestVariety, true) && image.plantingBestVarietyText ? { key: "plantingBestVarietyText", text: "Best variety/class: " + image.plantingBestVarietyText } : null,
      boolSetting(image.showPlantingNote, false) && image.plantingNoteText ? { key: "plantingNoteText", text: image.plantingNoteText } : null
    ];

    return items.filter(Boolean);
  }

  function getStructuredPlantingBoxText(image) {
    return getStructuredPlantingBoxItems(image).map(function (item) {
      return item.text;
    }).join("\n");
  }

  function getModuleLayouts(modules, startY, boxW, textScale, lineDy, moduleBoxExtra, isPinterest, gap, image) {
    image = image || {};
    let cursorY = startY;
    return modules.map(function (module) {
      const answerScale = getFieldScale(image, module.answerKey || "answer", 100);
      const answerLines = module.answer ? wrapTextUnlimited(module.answer || "", Math.max(16, isPinterest ? Math.round(36 / (textScale * answerScale)) : Math.round(34 / (textScale * answerScale)))) : [];
      const rows = (module.rows || []).map(function (row) {
        const rowScale = row.synthetic ? 1 : getFieldScale(image, row.key, 100);
        const baseSize = row.isHeading ? (isPinterest ? 22 : 20) : (row.isEmphasis ? (isPinterest ? 28 : 26) : (isPinterest ? 25 : 23));
        const fontSize = Math.round(baseSize * textScale * rowScale);
        const lineDy = Math.round((baseSize + (row.isHeading ? 8 : 10)) * textScale * rowScale);
        return {
          key: row.key,
          lines: wrapTextUnlimited(row.text || "", Math.max(18, isPinterest ? Math.round((row.isHeading ? 58 : 50) / (textScale * rowScale)) : Math.round((row.isHeading ? 54 : 46) / (textScale * rowScale)))),
          fontSize: fontSize,
          lineDy: lineDy,
