      platform: platform,
      cityName: page.cityName || "Your City",
      cropName: page.cropName || "This Crop",
      headline: getImageHeadline(page, angle, platform),
      badge: cardData.badge,
      answer: cardData.answer,
      reason: cardData.reason,
      fact1: localFacts[0] || "",
      fact2: localFacts[1] || "",
      fact3: localFacts[2] || "",
      tip: cardData.tip || "",
      footer: "GrowByDate.com",
      emoji: angle === "planting_guide" ? "🌱" : getCropEmoji(page.cropName),
      backgroundStyle: "auto",
      showCityName: true,
      showHeadline: true,
      showIcon: true,
      showBadge: !isCover,
      showBadgeText: !isCover,
      showAnswerLabel: !isCover,
      showSectionLabels: true,
      showAnswer: true,
      showReason: !isCover,
