  function init() {
    state.imagePrefs = loadPersistedImagePrefs();

    if (!data.length) {
      els.empty.textContent = "No crop-city summary data was found.";
      return;
    }

    populateFilters();
    applyFilters();
    bindEvents();
  }


  function loadPersistedImagePrefs() {
    try {
      const raw = window.localStorage.getItem(IMAGE_PREF_STORAGE_KEY);
      const parsed = raw ? JSON.parse(raw) : {};
      return sanitizeImagePrefs(parsed);
    } catch (error) {
      return { instagram: {}, pinterest: {}, cover: {} };
    }
  }

  function sanitizeImagePrefs(input) {
    const cleaned = { instagram: {}, pinterest: {}, cover: {} };
    ["instagram", "pinterest", "cover"].forEach(function (platformKey) {
      const source = input && typeof input === "object" ? input[platformKey] : null;
      if (!source || typeof source !== "object") return;
      IMAGE_PREF_KEYS.forEach(function (key) {
        if (Object.prototype.hasOwnProperty.call(source, key)) {
          cleaned[platformKey][key] = source[key];
        }
      });
    });
    return cleaned;
  }

  function savePersistedImagePrefs() {
    try {
      window.localStorage.setItem(IMAGE_PREF_STORAGE_KEY, JSON.stringify(state.imagePrefs || { instagram: {}, pinterest: {}, cover: {} }));
    } catch (error) {
      // ignore storage failures
    }
  }

  function rememberImagePrefs(platformKey, values) {
    if (!platformKey || !values) return;
    if (!state.imagePrefs) state.imagePrefs = { instagram: {}, pinterest: {}, cover: {} };
    if (!state.imagePrefs[platformKey]) state.imagePrefs[platformKey] = {};

    IMAGE_PREF_KEYS.forEach(function (key) {
      if (Object.prototype.hasOwnProperty.call(values, key)) {
        state.imagePrefs[platformKey][key] = values[key];
      }
    });

    savePersistedImagePrefs();
  }

  function getPersistedImagePrefs(platformKey) {
    if (!state.imagePrefs || !state.imagePrefs[platformKey]) return {};
    return Object.assign({}, state.imagePrefs[platformKey]);
  }

  function bindEvents() {
    els.search.addEventListener("input", applyFilters);
    els.city.addEventListener("change", applyFilters);
    els.crop.addEventListener("change", applyFilters);
    els.page.addEventListener("change", selectCurrentPage);

    els.root.querySelectorAll("[data-angle-value]").forEach(function (button) {
      button.addEventListener("click", function () {
        const angle = button.getAttribute("data-angle-value");
        els.angle.value = angle;

        els.root.querySelectorAll("[data-angle-value]").forEach(function (item) {
          item.classList.toggle("is-active", item === button);
        });

        if (state.selectedPage) {
          renderSelectedPage(state.selectedPage);
        }

        if (state.kit) {
          generateKit();
        }
      });
    });

    els.random.addEventListener("click", function () {
      const source = state.filteredPages.length ? state.filteredPages : data;
      const page = source[Math.floor(Math.random() * source.length)];
      if (!page) return;

      els.city.value = "";
      els.crop.value = "";
      els.search.value = "";
      applyFilters();

      els.page.value = getPageKey(page);
      selectCurrentPage();
      generateKit();
    });

    els.generate.addEventListener("click", generateKit);
    els.copyAll.addEventListener("click", copyAllText);
    els.exportJson.addEventListener("click", exportJson);
    if (els.downloadCurrentSet) els.downloadCurrentSet.addEventListener("click", downloadCurrentPngSet);
    els.batchQa.addEventListener("click", runBatchQa);
  }

  function populateFilters() {
    uniqueSorted(data.map(function (item) { return item.cityName; })).forEach(function (city) {
      const option = document.createElement("option");
      option.value = city;
      option.textContent = city;
      els.city.appendChild(option);
    });

    uniqueSorted(data.map(function (item) { return item.cropName; })).forEach(function (crop) {
      const option = document.createElement("option");
      option.value = crop;
      option.textContent = crop;
      els.crop.appendChild(option);
    });
  }

  function applyFilters() {
    const tokens = tokenize(els.search.value);
    const city = els.city.value;
    const crop = els.crop.value;

    state.filteredPages = data.filter(function (item) {
      const searchText = normalizeSearch([
        item.cityName,
        item.regionName,
        item.country,
        item.cropName,
        item.cropNounSingular,
        item.url,
        item.lede,
        getNested(item, "copy.oneSentenceSummary"),
        getNested(item, "advisory.bestStrategy")
      ].filter(Boolean).join(" "));

      const matchesQuery = !tokens.length || tokens.every(function (token) {
        return searchText.indexOf(token) > -1;
      });
      const matchesCity = !city || item.cityName === city;
      const matchesCrop = !crop || item.cropName === crop;

      return matchesQuery && matchesCity && matchesCrop;
    });

    renderPageOptions();

    if (state.filteredPages.length) {
      const previousKey = state.selectedPage ? getPageKey(state.selectedPage) : "";
      const stillVisible = state.filteredPages.some(function (item) {
        return getPageKey(item) === previousKey;
      });

      els.page.value = stillVisible ? previousKey : getPageKey(state.filteredPages[0]);
      selectCurrentPage();
    } else {
      state.selectedPage = null;
      state.kit = null;
      els.selectedPanel.hidden = true;
      els.output.hidden = true;
      els.empty.hidden = false;
      els.empty.textContent = "No matching crop-city pages found.";
    }
  }

  function renderPageOptions() {
    els.page.innerHTML = "";

    if (!state.filteredPages.length) {
      const option = document.createElement("option");
      option.value = "";
      option.textContent = "No matching pages";
      els.page.appendChild(option);
      return;
    }

    state.filteredPages.forEach(function (item) {
      const option = document.createElement("option");
      option.value = getPageKey(item);
      option.textContent = item.cropName + " in " + item.cityName + ", " + item.regionName;
      els.page.appendChild(option);
    });
  }

  function selectCurrentPage() {
    const key = els.page.value;
    const selected = state.filteredPages.find(function (item) {
      return getPageKey(item) === key;
    });

    state.selectedPage = selected || null;
    state.kit = null;
    state.currentSvgs = {};

    if (!state.selectedPage) {
      els.selectedPanel.hidden = true;
      els.output.hidden = true;
      els.empty.hidden = false;
      return;
    }

    renderSelectedPage(state.selectedPage);

    els.selectedPanel.hidden = false;
    els.output.hidden = true;
    els.empty.hidden = false;
    els.empty.textContent = "Click “Generate Pinterest + Instagram Kit” to create drafts, image templates, and QA notes.";
    els.copyAll.disabled = true;
    els.exportJson.disabled = true;
    if (els.downloadCurrentSet) els.downloadCurrentSet.disabled = true;
  }

  function renderSelectedPage(page) {
    const publicUrl = getPublicUrl(page);
    const angle = els.angle.value;

    els.selectedTitle.textContent = page.cropName + " in " + page.cityName;
    els.selectedLede.textContent = cleanSentence(page.lede || "No lede available.");
    els.selectedUrl.href = publicUrl;
    els.selectedUrl.textContent = publicUrl;

    const meta = [
      ["Spring frost", page.springFrost],
      ["Fall frost", page.fallFrost],
      ["Frost-free days", page.frostFreeDays],
      ["Planting method", getPrimaryMethod(page)],
      ["Primary date", getPrimaryDate(page)],
      ["Fit", getConfidenceLabel(page)]
    ];

    els.meta.innerHTML = meta.map(function (item) {
      const label = escapeHtml(item[0]);
      const value = escapeHtml(formatValue(item[1]));
      return [
        '<div class="social-kit__meta-item">',
        '<span class="social-kit__meta-label">' + label + '</span>',
        '<span class="social-kit__meta-value">' + value + '</span>',
        '</div>'
      ].join("");
    }).join("");

    const pageChecks = validatePageData(page, angle);
    renderQaList(els.pageQa, pageChecks);
    renderQaSummary(els.pageQaSummary, pageChecks, "Page data");
  }

  function generateKit() {
    if (!state.selectedPage) return;

    state.kit = buildSocialKit(state.selectedPage, els.angle.value);
    state.currentSvgs = {};

    renderPosts(state.kit.platforms);
    renderImages(state.kit.images);

    els.output.hidden = false;
    els.empty.hidden = true;
    els.copyAll.disabled = false;
    els.exportJson.disabled = false;
    if (els.downloadCurrentSet) els.downloadCurrentSet.disabled = false;
  }

  function buildSocialKit(page, angle) {
    const pageUrl = getPublicUrl(page);
    const instagram = buildInstagramPost(page, angle, pageUrl);
    const pinterest = buildPinterestPost(page, angle, pageUrl);
    const images = {
      instagram: buildImagePayload(page, angle, "instagram"),
      pinterest: buildImagePayload(page, angle, "pinterest")
    };

    if (angle === "planting_guide") {
      images.cover = buildImagePayload(page, angle, "cover");
    }

    return {
      source: {
        cropName: page.cropName || "This crop",
        cityName: page.cityName || "your city",
        regionName: page.regionName,
        country: page.country,
        url: pageUrl,
        angle: angle,
        angleLabel: ANGLE_LABELS[angle] || angle
      },
      platforms: {
        instagram: instagram,
        pinterest: pinterest
      },
      images: images
    };
  }

  function buildInstagramPost(page, angle, pageUrl) {
    const cropLower = lowerFirst(page.cropName || "this crop");
    const city = page.cityName || "your city";
    const caption = [
      getInstagramOpening(page, angle),
      getAngleSentence(page, angle),
      getPlantingSentence(page),
      getInstagramCloser(page, angle)
    ].filter(Boolean).map(cleanSentence).join("\n\n");

    return {
      caption: caption,
      hashtags: buildHashtags(page).join(" "),
      altText: buildAltText(page, angle, "Instagram image showing local " + cropLower + " planting timing for " + city + "."),
      pageUrl: pageUrl
    };
  }

  function buildPinterestPost(page, angle, pageUrl) {
    return {
      title: getPinterestTitle(page, angle),
      description: getPinterestDescription(page, angle),
      altText: buildAltText(page, angle, "Pinterest pin for the GrowByDate local planting guide."),
      destinationUrl: pageUrl
    };
  }

