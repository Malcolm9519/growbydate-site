      showPlantingBoxText: true,
      showPlantingMethod: true,
      showPlantingStartIndoors: true,
      showPlantingTransplant: true,
      showPlantingDirectSow: true,
      showPlantingMaturity: true,
      showPlantingBestVariety: true,
      showPlantingNote: false,
      showFrostBox: false,
      showFrostBoxAnswer: true,
      showFrostBoxText: true,
      showSeasonBox: false,
      showSeasonBoxAnswer: true,
      showSeasonBoxText: true,
      showMistakeBox: false,
      showMistakeBoxAnswer: true,
      showMistakeBoxText: true,
      showFitBox: false,
      showFitBoxAnswer: true,
      showFitBoxText: true,
      showDataBox: false,
      showDataBoxAnswer: true,
      showDataBoxText: true,
      textScale: isCover ? 104 : 100,
