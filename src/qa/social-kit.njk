      '<rect x="' + cardX + '" y="' + cardY + '" width="' + cardW + '" height="' + cardH + '" rx="64" fill="#fbf7ef" opacity="0.96"/>',
      '<rect x="' + cardX + '" y="' + cardY + '" width="' + cardW + '" height="' + cardH + '" rx="64" fill="none" stroke="#ffffff" stroke-width="10" opacity="0.75"/>',

