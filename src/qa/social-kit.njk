---
layout: layout-base.njk
title: Social Kit Generator
robots: "noindex, nofollow"
eleventyExcludeFromCollections: true
excludeFromSitemap: true
permalink: /qa/social-kit/
---

<style>
  .social-kit {
    --gbd-green: #2f6f3e;
    --gbd-green-dark: #204d2b;
    --gbd-green-soft: #eaf4ed;
    --gbd-cream: #fbf7ef;
    --gbd-ink: #1f2a24;
    --gbd-muted: #65736b;
    --gbd-border: #d7e2da;
    --gbd-card: #ffffff;
    --gbd-warning: #fff5d6;
    --gbd-danger: #ffe5df;
    --gbd-success: #e7f7e9;

    max-width: 1440px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
    color: var(--gbd-ink);
  }

  .social-kit * {
    box-sizing: border-box;
  }

  .social-kit__header {
    margin-bottom: 1.5rem;
  }

  .social-kit__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--gbd-green);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  .social-kit__title {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.05;
  }

  .social-kit__intro {
    max-width: 820px;
    margin: 0.85rem 0 0;
    color: var(--gbd-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .social-kit__notice {
    margin: 1.25rem 0;
    padding: 1rem;
    border: 1px solid #ead68a;
    background: var(--gbd-warning);
    border-radius: 14px;
    color: #5b4b16;
    line-height: 1.5;
  }

  .social-kit__panel,
  .social-kit__post-card,
  .social-kit__image-card {
    background: var(--gbd-card);
    border: 1px solid var(--gbd-border);
    border-radius: 18px;
    box-shadow: 0 10px 30px rgba(31, 42, 36, 0.06);
  }

  .social-kit__panel {
    padding: 1rem;
    margin-bottom: 1.25rem;
  }

  .social-kit__controls {
    display: grid;
    grid-template-columns: minmax(240px, 1.25fr) minmax(160px, 0.75fr) minmax(160px, 0.75fr) auto;
    gap: 0.8rem;
    align-items: end;
  }

  .social-kit__field label,
  .social-kit__field-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 800;
    margin-bottom: 0.35rem;
    color: var(--gbd-green-dark);
  }

  .social-kit__field input,
  .social-kit__field select,
  .social-kit__field textarea {
    width: 100%;
    border: 1px solid var(--gbd-border);
    border-radius: 12px;
    padding: 0.72rem 0.8rem;
    font: inherit;
    color: var(--gbd-ink);
    background: #fff;
  }

  .social-kit__field textarea {
    min-height: 120px;
    resize: vertical;
    line-height: 1.45;
  }

  .social-kit__field--compact textarea {
    min-height: 86px;
  }

  .social-kit__field--tiny textarea {
    min-height: 64px;
  }

  .social-kit__button {
    border: 0;
    border-radius: 12px;
    padding: 0.78rem 1rem;
    font: inherit;
    font-weight: 900;
    cursor: pointer;
    background: var(--gbd-green);
    color: #fff;
    transition: transform 0.12s ease, opacity 0.12s ease;
    white-space: nowrap;
  }

  .social-kit__button:hover {
    transform: translateY(-1px);
  }

  .social-kit__button:active {
    transform: translateY(0);
  }

  .social-kit__button[disabled] {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
  }

  .social-kit__button--secondary {
    background: var(--gbd-green-soft);
    color: var(--gbd-green-dark);
  }

  .social-kit__button--ghost {
    background: transparent;
    color: var(--gbd-green-dark);
    border: 1px solid var(--gbd-border);
  }

  .social-kit__selected {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 1rem;
  }

  .social-kit__selected h2,
  .social-kit__selected h3 {
    margin-top: 0;
  }

  .social-kit__meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .social-kit__meta-item {
    background: var(--gbd-green-soft);
    border-radius: 12px;
    padding: 0.7rem;
  }

  .social-kit__meta-label {
    display: block;
    color: var(--gbd-muted);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .social-kit__meta-value {
    display: block;
    margin-top: 0.18rem;
    font-weight: 900;
  }

  .social-kit__url {
    word-break: break-all;
    color: var(--gbd-green-dark);
  }

  .social-kit__angle-field {
    margin-top: 1rem;
  }

  .social-kit__angle-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .social-kit__angle-button {
    border: 1px solid var(--gbd-border);
    border-radius: 999px;
    background: #fff;
    color: var(--gbd-green-dark);
    padding: 0.55rem 0.8rem;
    font: inherit;
    font-size: 0.9rem;
    font-weight: 900;
    cursor: pointer;
  }

  .social-kit__angle-button.is-active {
    background: var(--gbd-green);
    border-color: var(--gbd-green);
    color: #fff;
  }

  .social-kit__inline-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .social-kit__small {
    font-size: 0.86rem;
    color: var(--gbd-muted);
    line-height: 1.45;
  }

  .social-kit__empty {
    padding: 1.5rem;
    text-align: center;
    color: var(--gbd-muted);
    border: 1px dashed var(--gbd-border);
    border-radius: 18px;
    background: var(--gbd-cream);
  }

  .social-kit__qa-list {
    display: grid;
    gap: 0.42rem;
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
  }

  .social-kit__qa-item {
    display: grid;
    grid-template-columns: 1.3rem 1fr;
    gap: 0.45rem;
    align-items: start;
    padding: 0.45rem 0.55rem;
    border-radius: 10px;
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .social-kit__qa-item[data-status="pass"] {
    background: var(--gbd-success);
    color: #1f5d2b;
  }

  .social-kit__qa-item[data-status="warn"] {
    background: var(--gbd-warning);
    color: #5b4b16;
  }

  .social-kit__qa-item[data-status="fail"] {
    background: var(--gbd-danger);
    color: #7a2a17;
  }

  .social-kit__qa-mark {
    font-weight: 950;
  }

  .social-kit__qa-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.75rem;
  }

  .social-kit__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border-radius: 999px;
    padding: 0.28rem 0.58rem;
    font-size: 0.8rem;
    font-weight: 900;
    background: var(--gbd-green-soft);
    color: var(--gbd-green-dark);
  }

  .social-kit__pill[data-status="pass"] {
    background: var(--gbd-success);
    color: #1f5d2b;
  }

  .social-kit__pill[data-status="warn"] {
    background: var(--gbd-warning);
    color: #5b4b16;
  }

  .social-kit__pill[data-status="fail"] {
    background: var(--gbd-danger);
    color: #7a2a17;
  }

  .social-kit__grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.62fr) minmax(760px, 1.38fr);
    gap: 1.25rem;
    align-items: start;
  }

  .social-kit__posts,
  .social-kit__images {
    display: grid;
    gap: 1rem;
  }

  .social-kit__image-panel {
    position: static;
  }

  .social-kit__image-workspace {
    display: grid;
    grid-template-columns: minmax(320px, 0.9fr) minmax(360px, 1.1fr);
    gap: 1rem;
    align-items: start;
  }

  .social-kit__image-preview-column {
    position: sticky;
    top: 5.75rem;
    align-self: start;
    z-index: 2;
  }

  .social-kit__image-controls-column {
    min-width: 0;
  }

  .social-kit__image-actions--sticky {
    position: sticky;
    bottom: 0.75rem;
    z-index: 3;
    padding: 0;
    margin-top: 0.75rem;
    border: 1px solid var(--gbd-border);
    border-radius: 14px;
    background: rgba(251, 247, 239, 0.96);
    box-shadow: 0 10px 28px rgba(31, 42, 36, 0.1);
  }

  .social-kit__image-actions-shell {
    overflow: hidden;
  }

  .social-kit__image-actions-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.7rem;
    padding: 0.7rem 0.85rem;
    cursor: pointer;
    color: var(--gbd-green-dark);
    font-weight: 950;
    list-style: none;
  }

  .social-kit__image-actions-summary::-webkit-details-marker {
    display: none;
  }

  .social-kit__image-actions-summary::after {
    content: "Show";
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--gbd-border);
    border-radius: 999px;
    padding: 0.22rem 0.55rem;
    background: #fff;
    font-size: 0.74rem;
    font-weight: 900;
  }

  .social-kit__image-actions-shell[open] .social-kit__image-actions-summary::after {
    content: "Hide";
  }

  .social-kit__image-actions-shell .social-kit__image-actions {
    padding: 0 0.7rem 0.75rem;
    margin-top: 0;
  }

  .social-kit__mixed-box-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .social-kit__mixed-section {
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px dashed var(--gbd-border);
  }

  .social-kit__mixed-section-title {
    margin: 0 0 0.65rem;
    color: var(--gbd-green-dark);
    font-weight: 950;
    font-size: 0.86rem;
  }

  .social-kit__post-card {
    overflow: hidden;
  }

  .social-kit__image-card,
  .social-kit__image-body {
    overflow: visible;
  }

  .social-kit__post-header,
  .social-kit__image-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1rem;
    background: var(--gbd-green-soft);
    border-bottom: 1px solid var(--gbd-border);
  }

  .social-kit__post-title,
  .social-kit__image-title {
    margin: 0;
    font-size: 1rem;
  }

  .social-kit__post-body,
  .social-kit__image-body {
    padding: 1rem;
  }

  .social-kit__field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }


  .social-kit__control-section {
    margin: 0.9rem 0;
    padding: 0.85rem;
    border: 1px solid var(--gbd-border);
    border-radius: 16px;
    background: var(--gbd-cream);
  }

  .social-kit__control-section--compact {
    padding: 0.7rem;
    background: #fff;
  }

  .social-kit__section-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
  }

  .social-kit__section-title-row .social-kit__image-options-title {
    margin: 0;
  }

  .social-kit__field-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
  }

  .social-kit__field-label-row label {
    margin-bottom: 0;
  }

  .social-kit__inline-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-size: 0.72rem;
    font-weight: 900;
    color: var(--gbd-green-dark);
    white-space: nowrap;
  }

  .social-kit__inline-toggle input {
    width: auto;
  }

  .social-kit__field-adjustments {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .social-kit__mini-control {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    padding: 0.18rem 0.38rem;
    border: 1px solid var(--gbd-border);
    border-radius: 999px;
    background: #fff;
    color: var(--gbd-green-dark);
    font-size: 0.68rem;
    font-weight: 900;
    white-space: nowrap;
  }

  .social-kit__mini-control input {
    width: 4.2rem;
    min-height: 1.95rem;
    padding: 0.2rem 0.35rem;
    font-size: 0.72rem;
    border-radius: 8px;
  }

  .social-kit__box-editor {
    margin-top: 0.75rem;
    padding: 0.8rem;
    border: 1px solid var(--gbd-border);
    border-radius: 14px;
    background: #fff;
  }

  .social-kit__box-editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
  }

  .social-kit__box-editor-title {
    margin: 0;
    color: var(--gbd-green-dark);
    font-size: 0.9rem;
    font-weight: 950;
  }


  .social-kit__image-options {
    margin: 0.9rem 0;
    padding: 0.8rem;
    border: 1px solid var(--gbd-border);
    border-radius: 14px;
    background: var(--gbd-cream);
  }

  .social-kit__image-options-title {
    margin: 0 0 0.65rem;
    font-size: 0.9rem;
    font-weight: 950;
    color: var(--gbd-green-dark);
  }

  .social-kit__option-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .social-kit__checkbox {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 42px;
    padding: 0.48rem 0.55rem;
    border: 1px solid var(--gbd-border);
    border-radius: 12px;
    background: #fff;
    color: var(--gbd-green-dark);
    font-size: 0.84rem;
    font-weight: 850;
  }

  .social-kit__checkbox input {
    width: auto;
    flex: 0 0 auto;
  }

  .social-kit__number-field input {
    min-height: 42px;
  }

  .social-kit__post-actions,
  .social-kit__image-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.8rem;
  }

  .social-kit__copy-status,
  .social-kit__field-status {
    font-size: 0.82rem;
    color: var(--gbd-green-dark);
    font-weight: 800;
    min-height: 1.2em;
  }

  .social-kit__field-status {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.25rem;
    color: var(--gbd-muted);
  }

  .social-kit__field-status strong {
    color: var(--gbd-green-dark);
  }

  .social-kit__image-preview {
    background: #f4f2ea;
    border: 1px solid var(--gbd-border);
    border-radius: 18px;
    padding: 0.75rem;
    overflow: hidden;
    margin-bottom: 0.9rem;
  }

  .social-kit__image-preview svg {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
  }

  .social-kit__batch {
    margin-top: 1rem;
  }

  .social-kit__batch-table-wrap {
    overflow: auto;
    margin-top: 0.85rem;
    border: 1px solid var(--gbd-border);
    border-radius: 14px;
  }

  .social-kit__batch-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 760px;
    font-size: 0.88rem;
  }

  .social-kit__batch-table th,
  .social-kit__batch-table td {
    padding: 0.65rem;
    border-bottom: 1px solid var(--gbd-border);
    text-align: left;
    vertical-align: top;
  }

  .social-kit__batch-table th {
    background: var(--gbd-green-soft);
    color: var(--gbd-green-dark);
    font-weight: 900;
  }

  .social-kit__batch-table tr:last-child td {
    border-bottom: 0;
  }

  @media (max-width: 1120px) {
    .social-kit__grid,
    .social-kit__selected,
    .social-kit__image-workspace {
      grid-template-columns: 1fr;
    }

    .social-kit__image-panel,
    .social-kit__image-preview-column {
      position: static;
    }
  }

  @media (max-width: 860px) {
    .social-kit__controls,
    .social-kit__field-grid,
    .social-kit__mixed-box-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .social-kit__meta {
      grid-template-columns: 1fr;
    }

    .social-kit__post-header,
    .social-kit__image-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

<section class="social-kit" data-social-kit>
  <header class="social-kit__header">
    <p class="social-kit__eyebrow">Internal QA Tool</p>
    <h1 class="social-kit__title">Social Kit Generator</h1>
    <p class="social-kit__intro">
      Generate and validate Pinterest pins and Instagram posts from existing GrowByDate crop-city data.
      This page is browser-only and built for QA review before anything is published.
    </p>
  </header>

  <div class="social-kit__notice">
    <strong>Review required:</strong> The generator now flags missing data, generic fallback copy, length problems,
    and image-text risks. Use the QA notes as a checklist rather than an automatic publishing approval.
  </div>

  <section class="social-kit__panel">
    <div class="social-kit__controls">
      <div class="social-kit__field">
        <label for="social-kit-search">Search crop, city, region, or URL</label>
        <input id="social-kit-search" type="search" placeholder="Example: tomatoes Edmonton">
      </div>

      <div class="social-kit__field">
        <label for="social-kit-city">City</label>
        <select id="social-kit-city">
          <option value="">All cities</option>
        </select>
      </div>

      <div class="social-kit__field">
        <label for="social-kit-crop">Crop</label>
        <select id="social-kit-crop">
          <option value="">All crops</option>
        </select>
      </div>

      <button class="social-kit__button" id="social-kit-random" type="button">
        Random page
      </button>
    </div>

    <div class="social-kit__field" style="margin-top: 1rem;">
      <label for="social-kit-page">Crop-city page</label>
      <select id="social-kit-page"></select>
    </div>
  </section>

  <section class="social-kit__panel" id="social-kit-selected-panel" hidden>
    <div class="social-kit__selected">
      <div>
        <h2 id="social-kit-selected-title">Selected page</h2>
        <p id="social-kit-selected-lede" class="social-kit__small"></p>
        <p>
          <strong>URL:</strong>
          <a id="social-kit-selected-url" class="social-kit__url" href="#" target="_blank" rel="noopener"></a>
        </p>

        <div class="social-kit__qa-summary" id="social-kit-page-qa-summary"></div>
        <ul class="social-kit__qa-list" id="social-kit-page-qa"></ul>
      </div>

      <div class="social-kit__meta" id="social-kit-meta"></div>
    </div>

    <div class="social-kit__angle-field">
      <span class="social-kit__field-label">Post angle</span>

      <div class="social-kit__angle-buttons" role="group" aria-label="Post angle">
        <button type="button" class="social-kit__angle-button is-active" data-angle-value="planting_timing">Planting timing</button>
        <button type="button" class="social-kit__angle-button" data-angle-value="frost_risk">Frost risk</button>
        <button type="button" class="social-kit__angle-button" data-angle-value="short_season">Will it mature?</button>
        <button type="button" class="social-kit__angle-button" data-angle-value="common_mistake">Common mistake</button>
        <button type="button" class="social-kit__angle-button" data-angle-value="planting_guide">Planting guide</button>
      </div>

      <select id="social-kit-angle" hidden>
        <option value="planting_timing">Planting timing</option>
        <option value="frost_risk">Frost risk</option>
        <option value="short_season">Will it mature?</option>
        <option value="common_mistake">Common mistake</option>
        <option value="planting_guide">Planting guide</option>
      </select>
    </div>

    <div class="social-kit__inline-actions">
      <button class="social-kit__button" id="social-kit-generate" type="button">
        Generate Pinterest + Instagram Kit
      </button>
      <button class="social-kit__button social-kit__button--secondary" id="social-kit-copy-all" type="button" disabled>
        Copy All Text
      </button>
      <button class="social-kit__button social-kit__button--ghost" id="social-kit-export-json" type="button" disabled>
        Export JSON
      </button>
      <button class="social-kit__button social-kit__button--secondary" id="social-kit-download-current-set" type="button" disabled>
        Download Current PNG Set
      </button>
      <button class="social-kit__button social-kit__button--ghost" id="social-kit-batch-qa" type="button">
        Run Batch QA
      </button>
    </div>

    <div class="social-kit__batch" id="social-kit-batch-results" hidden></div>
  </section>

  <section class="social-kit__grid" id="social-kit-output" hidden>
    <div>
      <div class="social-kit__posts" id="social-kit-posts"></div>
    </div>

    <aside class="social-kit__image-panel">
      <div class="social-kit__images" id="social-kit-images"></div>
    </aside>
  </section>

  <section class="social-kit__empty" id="social-kit-empty">
    Select a crop-city page to begin.
  </section>
</section>

<script>
  window.GROWBYDATE_CROP_CITY_SUMMARIES = {{ cropCitySummaries | dump | safe }};
  window.GROWBYDATE_DATA_RANKING_SUMMARIES = {% if dataRankingSummaries %}{{ dataRankingSummaries | dump | safe }}{% else %}[]{% endif %};
</script>

<script>
(function () {
  const SITE_ORIGIN = "https://growbydate.com";
  const data = Array.isArray(window.GROWBYDATE_CROP_CITY_SUMMARIES)
