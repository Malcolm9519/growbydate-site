---
layout: layout-base.njk
layoutClass: "statePage"
pagination:
  data: stateSummariesUS
  size: 1
  alias: state
permalink: "/planting-dates/states/{{ state.key }}/index.html"
eleventyComputed:
  title: "{{ state.name }} Garden Guide: Planting Dates, Frost Dates and Growing Season"
  description: "Browse {{ state.name }} planting dates by city, with average last frost, first frost, frost-free days, and local crop timing links."
  canonical: "https://growbydate.com/planting-dates/states/{{ state.key }}/"
---

<header class="header">
<h1>{{ state.name }} Garden Guide: Planting Dates, Frost Dates & Growing Seasons</h1>

  {% set hero = (state.content and state.content.hero) or {} %}

  {% if hero and hero.note %}
    <div class="callout" style="margin-top:0.75rem;">
      <p>{{ hero.note }}</p>
      {% if hero.extraNote %}
        <p>{{ hero.extraNote }}</p>
      {% endif %}
    </div>
  {% elseif hero and hero.extraNote %}
    <div class="callout" style="margin-top:0.75rem;">
      <p>{{ hero.extraNote }}</p>
    </div>
  {% endif %}

  {% if state.season and state.season.frost and state.season.frost.spring and state.season.frost.fall %}
    <p class="lede">
      In a typical year, the growing season in {{ state.name }} runs roughly from
      <strong>{{ state.season.frost.spring.p50 | mmddLong }}</strong>
      through
      <strong>{{ state.season.frost.fall.p50 | mmddLong }}</strong>{% if state.season.derived and state.season.derived.frostFreeDays_p50 %}, giving many parts of the state about <strong>{{ state.season.derived.frostFreeDays_p50 }} frost-free days</strong>{% endif %}.
      Use this page as a statewide baseline, then compare local city pages for more precise planting timing.
    </p>
  {% elif hero and hero.lede %}
    <p class="lede">{{ hero.lede }}</p>
  {% endif %}
</header>

{% include "region/modules/quick-planning-reference.njk" %}
{% include "region/modules/season-boundaries.njk" %}

{% set detailsPath = "region/" + state.key + "-details.njk" %}
{% include detailsPath ignore missing %}

{% set sourceLinksVariant = "us-planting-dates" %}
{% set sourceLinksId = "planting-dates-state-" + state.key %}
{% set sourceLinksHeading = "Sources for U.S. planting-date context" %}
{% set sourceLinksIntro = "This state planting-date guide uses long-term U.S. climate-normal, frost-date, and growing degree day references to explain typical regional gardening windows. These are planning references, not a forecast for this season." %}
{% include "components/external-source-links.njk" %}
