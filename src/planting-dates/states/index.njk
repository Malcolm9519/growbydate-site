---
layout: layout-base.njk
permalink: "/planting-dates/states/"
title: "Planting Dates by State (Frost & GDD Normals)"
canonical: "https://growbydate.com/planting-dates/states/"
---

<style>
  .index-city-link {
    display: inline-block;
    margin-top: 0.35rem;
    margin-right: 0.65rem;
    text-decoration: none;
    color: var(--color-link, #2f7d32);
  }

  .index-city-link:hover {
    text-decoration: underline;
  }

  .index-subhead {
    margin: 0 0 0.75rem;
  }

  .index-city-region {
    color: rgba(0, 0, 0, 0.68);
    font-weight: 400;
  }
</style>

<section class="card index-card">
  <h1>Planting Dates by State</h1>
  <p class="small intro">
    Normals-based first frost timing and remaining seasonal heat for each published U.S. state.
    Select a state to see typical frost dates and growing degree day capacity.
  </p>
</section>

<section class="card">
  <ul class="index-list">
    {% for st in stateSummariesUS %}
      <li class="index-item">
        <a class="index-link" href="/planting-dates/states/{{ st.key }}/">
          <strong>{{ st.name }}</strong>
          {% if st.lede %}
            <div class="index-desc">{{ st.lede }}</div>
          {% endif %}
        </a>
      </li>
    {% endfor %}
  </ul>
</section>

<section class="card index-card">
  <h2 class="index-subhead">Planting Dates by City</h2>
  <p class="small intro">
    Browse published U.S. city pages for more local planting dates, frost timing, and crop-specific guidance.
  </p>
</section>

<section class="card">
  <ul class="index-list">
    {% for city in citySummaries %}
      {% if city.country == "united-states" or city.country == "usa" or city.country == "us" %}
        <li class="index-item">
          <a class="index-link" href="/planting-dates/{{ city.regionKey }}/{{ city.key }}/">
            <strong>{{ city.name }}</strong>
            <span class="index-city-region">, {{ city.regionName }}</span>
            <div class="index-desc">
              Local planting dates, frost timing, and crop guidance for {{ city.name }}.
            </div>
          </a>

          <div class="index-desc">
            {% for crop in cropCitySummaries %}
              {% if crop.regionKey == city.regionKey and crop.cityKey == city.key %}
                <a class="index-city-link" href="{{ crop.url }}">{{ crop.cropName }}</a>
              {% endif %}
            {% endfor %}
          </div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</section>