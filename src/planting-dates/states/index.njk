---
layout: layout-base.njk
permalink: "/planting-dates/states/"
title: "U.S. Planting Dates by State (Frost & GDD Normals)"
description: "Browse published U.S. state planting date guides with normals-based frost timing, growing degree days, and local city pages."
canonical: "https://growbydate.com/planting-dates/states/"
---

<style>
  .index-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .index-city-list {
    margin: 0.85rem 0 0;
    padding-left: 1rem;
    list-style: none;
  }

  .index-city-item {
    margin: 0 0 0.9rem;
  }

  .index-city-link-main {
    text-decoration: none;
    color: var(--color-link, #2f7d32);
  }

  .index-city-link-main:hover {
    text-decoration: underline;
  }

  .index-city-region {
    color: inherit;
    font-weight: 400;
  }
</style>

<section class="card leaderboardHero">
  <p class="eyebrow">U.S. planting dates</p>
  <h1>Planting Dates by State</h1>
  <p class="lede">
    Normals-based first frost timing and remaining seasonal heat for U.S. states.
    Select a state to see typical frost dates and growing degree day capacity.
  </p>
</section>

<section class="card index-card">
  <p class="small">
    Search by state, city, or abbreviation to find U.S. planting-date guides.
  </p>
  <label class="sr-only" for="state-city-search">Search planting dates by state or city</label>
  <input
    id="state-city-search"
    type="search"
    placeholder="Search state, city, or abbreviation..."
    autocomplete="off"
    style="width:100%;max-width:36rem;margin:0.75rem 0 1rem;padding:0.75rem 0.9rem;border:1px solid #d8e2d0;border-radius:999px;"
  />
  <p class="small" id="state-city-search-count" aria-live="polite"></p>

  <ul class="index-list" id="state-city-list" data-on-this-page-list>
    {% for st in stateSummariesUS %}
      <li class="index-item" data-index-group data-on-this-page-label="{{ st.name }}" data-search="{{ st.name | lower }} {{ st.key | lower }}{% if st.lede %} {{ st.lede | lower }}{% endif %}">
        <a class="index-link" href="/planting-dates/{{ st.key }}/">
          <strong>{{ st.name }}</strong>
          {% if st.lede %}
            <div class="index-desc">{{ st.lede }}</div>
          {% endif %}
        </a>

        {% set hasCities = false %}
        {% for city in citySummaries %}
          {% if (city.country == "united-states" or city.country == "usa" or city.country == "us") and city.regionKey == st.key %}
            {% set hasCities = true %}
          {% endif %}
        {% endfor %}

        {% if hasCities %}
          <ul class="index-city-list">
            {% for city in citySummaries %}
              {% if (city.country == "united-states" or city.country == "usa" or city.country == "us") and city.regionKey == st.key %}
                <li class="index-city-item" data-index-child data-search="{{ city.name | lower }} {{ city.regionName | lower }} {{ city.regionKey | lower }} united states us usa planting dates frost timing crop guidance">
                  <a class="index-city-link-main" href="/planting-dates/{{ city.regionKey }}/{{ city.key }}/">
                    <strong>{{ city.name }}</strong>
                    <span class="index-city-region">, {{ city.regionName }}</span>
                  </a>

                  <div class="index-desc">
                    Local planting dates, frost timing, and crop guidance for {{ city.name }}.
                  </div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</section>

<script>
(function () {
  const input = document.getElementById("state-city-search");
  const list = document.getElementById("state-city-list");
  const count = document.getElementById("state-city-search-count");
  if (!input || !list || !count) return;

  const groups = Array.from(list.querySelectorAll("[data-index-group]"));
  const children = Array.from(list.querySelectorAll("[data-index-child]"));

  function update() {
    const query = input.value.trim().toLowerCase();
    let visibleGroups = 0;
    let visibleChildren = 0;

    groups.forEach((group) => {
      const groupMatches = !query || (group.dataset.search || "").includes(query);
      const groupChildren = Array.from(group.querySelectorAll("[data-index-child]"));
      let childMatches = 0;

      groupChildren.forEach((child) => {
        const matches = groupMatches || !query || (child.dataset.search || "").includes(query);
        child.hidden = !matches;
        if (matches) childMatches += 1;
      });

      const showGroup = groupMatches || childMatches > 0;
      group.hidden = !showGroup;
      if (showGroup) visibleGroups += 1;
      visibleChildren += childMatches;
    });

    count.textContent = `Showing ${visibleGroups} ${visibleGroups === 1 ? "state" : "states"} and ${visibleChildren} ${visibleChildren === 1 ? "city page" : "city pages"}.`;
  }

  input.addEventListener("input", update);
  update();
}());
</script>

