---
layout: layout-base.njk
layoutClass: "cityPage"
pagination:
  data: citySummaries
  size: 1
  alias: city
permalink: "/planting-dates/{% if city.country == 'canada' %}canada/{% endif %}{{ city.regionKey }}/{{ city.key }}/index.html"
eleventyComputed:
  title: "{{ city.name }}, {{ city.regionName }} Garden Guide: Planting Dates, Frost Dates & Growing Season"
  description: "Find {{ city.name }} planting dates, average last spring frost, first fall frost, frost-free season length, and local crop timing guidance."
  canonical: "https://growbydate.com/planting-dates/{% if city.country == 'canada' %}canada/{% endif %}{{ city.regionKey }}/{{ city.key }}/"
---

{% set state = city %}

<header class="header cityHeader">
  <div class="cityHeaderText">
<h1>{{ city.name }}, {{ city.regionName }} Garden Guide: Planting Dates, Frost Dates and Growing Season</h1>

    {% set hero = (state.content and state.content.hero) or {} %}

    {% if hero and hero.note %}
      <div class="callout" style="margin-top:0.75rem;">
        <p>{{ hero.note }}</p>
        {% if hero.extraNote %}
          <p>{{ hero.extraNote }}</p>
        {% endif %}
      </div>
    {% elseif hero and hero.extraNote %}
      <div class="callout" style="margin-top:0.75rem;">
        <p>{{ hero.extraNote }}</p>
      </div>
    {% endif %}

    {% if state.season and state.season.frost and state.season.frost.spring and state.season.frost.fall %}
      {% set frostDays = state.season.derived and state.season.derived.frostFreeDays_p50 %}
      <p class="lede">
        In {{ state.name }}, gardeners usually see the last spring frost around
        <strong>{{ state.season.frost.spring.p50 | mmddLong }}</strong>
        and the first fall frost around
        <strong>{{ state.season.frost.fall.p50 | mmddLong }}</strong>{% if frostDays %}, leaving about <strong>{{ frostDays }} frost-free days</strong>{% endif %} in a typical year.
        {% if frostDays and frostDays < 115 %}
          That makes planting timing, direct-sowing windows, and fast-maturing varieties especially important.
        {% elif frostDays and frostDays < 155 %}
          That gives gardeners a workable season for many common crops, with timing still mattering for slower varieties.
        {% else %}
          That gives gardeners more room for long-season crops, succession planting, and later sowings.
        {% endif %}
      </p>
    {% elif hero and hero.lede %}
      <p class="lede">{{ hero.lede }}</p>
    {% endif %}
  </div>
</header>

{% include "region/modules/quick-planning-reference.njk" %}
{% include "region/modules/season-boundaries.njk" %}

{% set detailsPath = "region/cities/" + state.key + "-details.njk" %}
{% include detailsPath ignore missing %}

{% include "region/modules/city-crop-guides.njk" %}

<section class="small muted" style="margin-top:1rem;">
  <p>
    Looking for broader guidance? See planting timing across
    <a href="/planting-dates/{% if city.country == 'canada' %}canada/provinces{% else %}states{% endif %}/{{ city.regionKey }}/">{{ city.regionName }}</a>
  </p>
</section>