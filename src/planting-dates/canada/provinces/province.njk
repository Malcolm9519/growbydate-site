---
layout: layout-base.njk
layoutClass: "provincePage"
pagination:
  data: provinceSummariesCA
  size: 1
  alias: province
permalink: "/planting-dates/canada/{{ province.key }}/index.html"
eleventyComputed:
  title: "{{ province.name }} Garden Guide: Planting Dates, Frost Dates and Growing Season"
  description: "Browse {{ province.name }} planting dates by city, with average last frost, first frost, frost-free days, and local crop timing links."
  canonical: "https://growbydate.com/planting-dates/canada/{{ province.key }}/"
---

{% set state = province %}

<header class="header">
<h1>{{ province.name }} Garden Guide: Planting Dates, Frost Dates & Growing Season</h1>

  {% set hero = (state.content and state.content.hero) or {} %}

  {% if hero and hero.note %}
    <div class="callout" style="margin-top:0.75rem;">
      <p>{{ hero.note }}</p>
      {% if hero.extraNote %}
        <p>{{ hero.extraNote }}</p>
      {% endif %}
    </div>
  {% elseif hero and hero.extraNote %}
    <div class="callout" style="margin-top:0.75rem;">
      <p>{{ hero.extraNote }}</p>
    </div>
  {% endif %}

  {% if state.season and state.season.frost and state.season.frost.spring and state.season.frost.fall %}
    <p class="lede">
      In a typical year, the growing season in {{ state.name }} runs roughly from
      <strong>{{ state.season.frost.spring.p50 | mmddLong }}</strong>
      through
      <strong>{{ state.season.frost.fall.p50 | mmddLong }}</strong>{% if state.season.derived and state.season.derived.frostFreeDays_p50 %}, leaving about <strong>{{ state.season.derived.frostFreeDays_p50 }} frost-free days</strong> in many parts of the province{% endif %}.
      Use this page as a provincial baseline, then compare city pages for more local planting timing.
    </p>
  {% elif hero and hero.lede %}
    <p class="lede">{{ hero.lede }}</p>
  {% endif %}
</header>

{% include "region/modules/quick-planning-reference.njk" %}
{% include "region/modules/season-boundaries.njk" %}

{% set detailsPath = "region/" + state.key + "-details.njk" %}
{% include detailsPath ignore missing %}

{% set sourceLinksVariant = "canada-planting-dates" %}
{% set sourceLinksId = "planting-dates-province-" + province.key %}
{% set sourceLinksHeading = "Sources for Canadian planting-date context" %}
{% set sourceLinksIntro = "This province planting-date guide uses long-term Canadian climate-normal, frost-date, and degree-day references to explain typical regional gardening windows. These are planning references, not a forecast for this season." %}
{% include "components/external-source-links.njk" %}
