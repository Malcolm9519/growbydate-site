---
layout: layout-base.njk
permalink: "/planting-dates/canada/provinces/"
title: "Canada Planting Dates by Province (Frost & GDD Normals)"
description: "Browse published Canadian province planting date guides with normals-based frost timing, growing degree days, and local city pages."
canonical: "https://growbydate.com/planting-dates/canada/provinces/"
---

<style>
  .index-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .index-city-list {
    margin: 0.85rem 0 0;
    padding-left: 1rem;
    list-style: none;
  }

  .index-city-item {
    margin: 0 0 0.9rem;
  }

  .index-city-link-main {
    text-decoration: none;
    color: var(--color-link, #2f7d32);
  }

  .index-city-link-main:hover {
    text-decoration: underline;
  }

  .index-city-region {
    color: inherit;
    font-weight: 400;
  }
</style>

<section class="card index-card">
  <h1>Planting Dates by Province</h1>
  <p class="small intro">
    Normals-based frost timing and remaining seasonal heat for Canadian provinces.
    Select a province to see typical frost dates and growing degree day capacity.
  </p>

  <p class="small">
    Search by province, city, or abbreviation to find Canadian planting-date guides.
  </p>
  <label class="sr-only" for="province-city-search">Search planting dates by province or city</label>
  <input
    id="province-city-search"
    type="search"
    placeholder="Search province, city, or abbreviation..."
    autocomplete="off"
    style="width:100%;max-width:36rem;margin:0.75rem 0 1rem;padding:0.75rem 0.9rem;border:1px solid #d8e2d0;border-radius:999px;"
  />
  <p class="small" id="province-city-search-count" aria-live="polite"></p>

  <ul class="index-list" id="province-city-list">
    {% for prov in provinceSummariesCA %}
      <li class="index-item" data-index-group data-search="{{ prov.name | lower }} {{ prov.key | lower }}{% if prov.lede %} {{ prov.lede | lower }}{% endif %}">
        <a class="index-link" href="/planting-dates/canada/provinces/{{ prov.key }}/">
          <strong>{{ prov.name }}</strong>
          {% if prov.lede %}
            <div class="index-desc">{{ prov.lede }}</div>
          {% endif %}
        </a>

        {% set hasCities = false %}
        {% for city in citySummaries %}
          {% if city.country == "canada" and city.regionKey == prov.key %}
            {% set hasCities = true %}
          {% endif %}
        {% endfor %}

        {% if hasCities %}
          <ul class="index-city-list">
            {% for city in citySummaries %}
              {% if city.country == "canada" and city.regionKey == prov.key %}
                <li class="index-city-item" data-index-child data-search="{{ city.name | lower }} {{ city.regionName | lower }} {{ city.regionKey | lower }} canada planting dates frost timing crop guidance">
                  <a class="index-city-link-main" href="/planting-dates/canada/{{ city.regionKey }}/{{ city.key }}/">
                    <strong>{{ city.name }}</strong>
                    <span class="index-city-region">, {{ city.regionName }}</span>
                  </a>

                  <div class="index-desc">
                    Local planting dates, frost timing, and crop guidance for {{ city.name }}.
                  </div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</section>

<script>
(function () {
  const input = document.getElementById("province-city-search");
  const list = document.getElementById("province-city-list");
  const count = document.getElementById("province-city-search-count");
  if (!input || !list || !count) return;

  const groups = Array.from(list.querySelectorAll("[data-index-group]"));
  const children = Array.from(list.querySelectorAll("[data-index-child]"));

  function update() {
    const query = input.value.trim().toLowerCase();
    let visibleGroups = 0;
    let visibleChildren = 0;

    groups.forEach((group) => {
      const groupMatches = !query || (group.dataset.search || "").includes(query);
      const groupChildren = Array.from(group.querySelectorAll("[data-index-child]"));
      let childMatches = 0;

      groupChildren.forEach((child) => {
        const matches = groupMatches || !query || (child.dataset.search || "").includes(query);
        child.hidden = !matches;
        if (matches) childMatches += 1;
      });

      const showGroup = groupMatches || childMatches > 0;
      group.hidden = !showGroup;
      if (showGroup) visibleGroups += 1;
      visibleChildren += childMatches;
    });

    count.textContent = `Showing ${visibleGroups} ${visibleGroups === 1 ? "province" : "provinces"} and ${visibleChildren} ${visibleChildren === 1 ? "city page" : "city pages"}.`;
  }

  input.addEventListener("input", update);
  update();
}());
</script>

