---
layout: layout-base.njk
layoutClass: "cropCityPage"
pagination:
  data: cropCitySummaries
  size: 1
  alias: pageData
permalink: "{{ pageData.url }}index.html"
eleventyComputed:
  title: "When to Plant {{ pageData.cropName }} in {{ pageData.cityName }}: Timing and Maturity Guide"
  description: "Find the best time to plant {{ pageData.cropName | lower }} in {{ pageData.cityName }}, {{ pageData.regionName }}, with local planting windows, frost dates, indoor and outdoor timing, and whether the crop will typically mature in time."
  canonical: "https://growbydate.com{{ pageData.url }}"
---

{% macro formatMmdd(mmdd) -%}
{%- if not mmdd -%}
—
{%- else -%}
{{- mmdd
  | replace("01-", "January ")
  | replace("02-", "February ")
  | replace("03-", "March ")
  | replace("04-", "April ")
  | replace("05-", "May ")
  | replace("06-", "June ")
  | replace("07-", "July ")
  | replace("08-", "August ")
  | replace("09-", "September ")
  | replace("10-", "October ")
  | replace("11-", "November ")
  | replace("12-", "December ")
  | replace(" 01", " 1")
  | replace(" 02", " 2")
  | replace(" 03", " 3")
  | replace(" 04", " 4")
  | replace(" 05", " 5")
  | replace(" 06", " 6")
  | replace(" 07", " 7")
  | replace(" 08", " 8")
  | replace(" 09", " 9")
-}}
{%- endif -%}
{%- endmacro %}

{% macro fToC(tempF) %}
  {% if tempF == null %}
    —
  {% else %}
    {{ ((tempF - 32) * 5 / 9) | round }}
  {% endif %}
{% endmacro %}

{% macro frostToleranceText(value) %}
  {% set v = (value or "") | lower %}
  {% if "tender" in v or "none" in v %}
    frost-tender
  {% elif "hardy" in v %}
    frost tolerant
  {% elif "moderate" in v or "half-hardy" in v %}
    somewhat frost tolerant
  {% elif "light" in v %}
    lightly frost tolerant
  {% else %}
    sensitive to frost
  {% endif %}
{% endmacro %}

{% set crop = pageData.crop %}
{% set cropName = pageData.cropName %}
{% set cropLower = cropName | lower %}
{% set cropSingular = pageData.cropNounSingular or pageData.cropSingularName or crop.singularName or cropName %}
{% set cropSingularLower = cropSingular | lower %}

{% set isPluralCrop = cropLower != cropSingularLower %}
{% set cropSubject = cropName %}
{% set cropSubjectLower = cropLower %}
{% set cropVerb = "are" if isPluralCrop else "is" %}
{% set cropBecomeVerb = "become" if isPluralCrop else "becomes" %}

{% set outlookClass = pageData.fit.confidence %}

{% set plantingWindowValue = "" %}
{% if pageData.planting.windowStart and pageData.planting.windowEnd %}
  {% if pageData.planting.windowStart == pageData.planting.windowEnd %}
    {% set plantingWindowValue = formatMmdd(pageData.planting.windowStart) %}
  {% else %}
    {% set plantingWindowValue = formatMmdd(pageData.planting.windowStart) + " – " + formatMmdd(pageData.planting.windowEnd) %}
  {% endif %}
{% elif pageData.planting.windowStart %}
  {% set plantingWindowValue = formatMmdd(pageData.planting.windowStart) %}
{% endif %}

{% set frostLabel = frostToleranceText(crop.frostToleranceLabel or crop.frostTolerance) %}

{% set methodLabel = "" %}
{% if crop.transplantRecommended and crop.directSowRecommended %}
  {% set methodLabel = "Direct sow or transplant" %}
{% elif crop.plantingMethod == "transplant" and crop.startingMethod == "indoors" %}
  {% set methodLabel = "Transplant" %}
{% elif crop.plantingMethod == "direct-sow" %}
  {% set methodLabel = "Direct sow" %}
{% elif crop.plantingMethod and crop.startingMethod %}
  {% set methodLabel = (crop.plantingMethod | replace("-", " ") | title) + " using " + (crop.startingMethod | replace("-", " ")) %}
{% elif crop.plantingMethod %}
  {% set methodLabel = crop.plantingMethod | replace("-", " ") | title %}
{% endif %}

<header class="header cropHero">
  <p class="eyebrow">Climate-based {{ cropSingularLower }} planting guide for {{ pageData.cityName }}, {{ pageData.regionName }}</p>
  <h1>When to Plant {{ cropName }} in {{ pageData.cityName }}: Timing and Maturity Guide</h1>
  <p class="lede">{{ pageData.lede }}</p>
</header>

<section class="quickAnswer card" aria-label="Planting window timing">
  <div class="quickAnswerTop">
    <h2>Typical Planting Window</h2>

    <div class="fitBadge fitBadge-{{ outlookClass }}">
      {% if outlookClass == "surplus" %}
        Excellent fit in this climate
      {% elif outlookClass == "strong" %}
        Strong fit in this climate
      {% elif outlookClass == "good" %}
        Good fit in this climate
      {% elif outlookClass == "borderline" %}
        Borderline in this climate
      {% elif outlookClass == "risky" %}
        Risky in this climate
      {% else %}
        {{ outlookClass | capitalize }}
      {% endif %}
    </div>
  </div>

  <p>
    Use the planting dates below for {{ cropLower }} in {{ pageData.cityName }}.
  </p>

  <div class="quickStats">
{% if pageData.planting.startIndoorsDate %}
  <div class="statCard">
    <span class="statLabel">
      {% if crop.transplantRecommended and crop.directSowRecommended %}
        Optional indoor start
      {% else %}
        Start indoors
      {% endif %}
    </span>
    <strong>{{ formatMmdd(pageData.planting.startIndoorsDate) }}</strong>
  </div>
{% endif %}

    {% if plantingWindowValue %}
      <div class="statCard">
        <span class="statLabel">Typical planting window</span>
        <strong>{{ plantingWindowValue }}</strong>
      </div>
    {% endif %}

    {% if methodLabel %}
      <div class="statCard">
        <span class="statLabel">Method</span>
        <strong>{{ methodLabel }}</strong>
      </div>
    {% endif %}

    {% if crop.daysToMaturityTypical %}
      <div class="statCard">
        <span class="statLabel">Typical days to maturity</span>
        <strong>{{ crop.daysToMaturityTypical }}</strong>
      </div>
    {% endif %}
  </div>

{% if pageData.methodSummary.summarySentence or crop.daysToMaturityTypical %}
  <p>
    {% if pageData.methodSummary.summarySentence %}
      {{ pageData.methodSummary.summarySentence }}
    {% endif %}

{% if crop.daysToMaturityTypical %}
  {% if crop.transplantRecommended and not crop.directSowRecommended %}
    Most varieties need about {{ crop.daysToMaturityTypical }} days to reach maturity once they are in the garden.
  {% else %}
    Most varieties need about {{ crop.daysToMaturityTypical }} days to reach maturity.
  {% endif %}
{% endif %}
  </p>
{% endif %}

  {% if pageData.advisory %}
    <p>{{ pageData.advisory.succeed }}</p>
    <p>{{ pageData.advisory.localInterpretation or pageData.advisory.fail }}</p>
  {% endif %}

{% if pageData.advisory and pageData.advisory.bestStrategy %}
  <p>
    <strong>Best local strategy:</strong>
    {{ pageData.advisory.bestStrategy }}
  </p>
{% endif %}

</section>

<section class="card">
  <h2>Can {{ cropName }} Mature in {{ pageData.cityName }}?</h2>

  <p>
    {% if crop.key == "tomatoes" %}
      Growing degree days measure how much useful warmth the season provides. For tomatoes, that warmth is what drives steady growth, fruit sizing, and ripening, so low GDD seasons often leave later varieties green or unfinished before frost.
    {% elif crop.frostTolerance == "tender" %}
      Growing degree days measure how much useful warmth the season provides. For warm-season crops like {{ cropLower }}, GDD helps show whether local heat accumulation is usually strong enough for the crop to grow steadily and finish before fall.
    {% else %}
      Growing degree days measure how much useful warmth typically accumulates during the season. For {{ cropLower }}, this helps estimate whether local heat accumulation is usually enough for the crop to reach maturity on time.
    {% endif %}
  </p>

  <div class="quickStats">
    <div class="statCard">
      <span class="statLabel">Available GDD (base {{ crop.gddBase or 50 }})</span>
      <strong>{{ pageData.fit.availableGddFromPlanting }}</strong>
    </div>

    <div class="statCard">
      <span class="statLabel">Typical crop GDD target</span>
      <strong>{{ crop.gddTargetTypical }}</strong>
    </div>

    {% if pageData.fit.gddMargin != null %}
      <div class="statCard">
        <span class="statLabel">Heat margin</span>
        <strong>{% if pageData.fit.gddMargin > 0 %}+{% endif %}{{ pageData.fit.gddMargin }}</strong>
      </div>
    {% endif %}
  </div>

  {% if pageData.fit.gddMargin != null %}
    <p>
      From the usual planting window, {{ pageData.cityName }} typically provides about {{ pageData.fit.availableGddFromPlanting }} growing degree days for {{ cropLower }}. With a typical crop target of {{ crop.gddTargetTypical }}, that leaves a heat margin of {% if pageData.fit.gddMargin > 0 %}+{% endif %}{{ pageData.fit.gddMargin }}. {{ pageData.fit.gddInterpretation }}
    </p>
  {% endif %}

  <h3>When Is It Too Late to Plant?</h3>

  <p>{{ pageData.fit.checkpointIntro }}</p>

  {% set checkpointRows = [
    { label: "Apr 15", value: pageData.gdd.remainingApr15 },
    { label: "May 1", value: pageData.gdd.remainingMay1 },
    { label: "May 15", value: pageData.gdd.remainingMay15 },
    { label: "Jun 1", value: pageData.gdd.remainingJun1 },
    { label: "Jun 15", value: pageData.gdd.remainingJun15 },
    { label: "Jul 1", value: pageData.gdd.remainingJul1 }
  ] %}

  <div class="tableWrap" style="margin-top:1rem;">
    <table class="table">
      <thead>
        <tr>
          <th>Checkpoint</th>
          <th>Remaining GDD</th>
          <th>Heat margin</th>
          <th>Fit vs typical target</th>
        </tr>
      </thead>
      <tbody>
        {% for row in checkpointRows %}
          {% set prev = checkpointRows[loop.index0 - 1] if loop.index0 > 0 else null %}
          {% set isFlatRepeat = prev and row.value != null and prev.value != null and row.value == prev.value %}

          {% if not isFlatRepeat %}
            <tr>
              <td>{{ row.label }}</td>
              <td>{% if row.value != null %}{{ row.value }}{% else %}—{% endif %}</td>
              <td>
                {% if row.value != null and crop.gddTargetTypical != null %}
                  {% set cpMargin = row.value - crop.gddTargetTypical %}
                  {% if cpMargin > 0 %}+{% endif %}{{ cpMargin }}
                {% else %}
                  —
                {% endif %}
              </td>
              <td>
                {% if row.value != null and crop.gddTargetTypical != null %}
                  {% set cpMargin = row.value - crop.gddTargetTypical %}
                  {% if cpMargin >= 150 %}
                    Comfortable
                  {% elif cpMargin >= 40 %}
                    Usually fits
                  {% elif cpMargin >= 0 %}
                    Tight fit
                  {% else %}
                    Usually short
                  {% endif %}
                {% else %}
                  —
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<section class="card">

<h2>How Different {{ cropSingular | replace("-", " ") | title }} Varieties Affect Results</h2>

{% if pageData.fit.bestVarietyParagraphOverride %}
  <p>{{ pageData.fit.bestVarietyParagraphOverride }}</p>
{% elif pageData.fit.bestVarietyParagraph %}
  <p>{{ pageData.fit.bestVarietyParagraph }}</p>
{% endif %}

{% if pageData.fit.fittingVarietyExamplesDetailed and pageData.fit.fittingVarietyExamplesDetailed.length %}
  <p style="margin-top:0.6rem;">
    Varieties that often fit well here include:
  </p>

  <ul style="margin-top:0.45rem;">
    {% for v in pageData.fit.fittingVarietyExamplesDetailed %}
      <li><strong>{{ v.name }}</strong> — {{ v.note }}</li>
    {% endfor %}
  </ul>
{% endif %}

{% if pageData.fit.varietyClassFits and pageData.fit.varietyClassFits.length %}
  <div class="tableWrap" style="margin-top:1rem;">
    <table class="table">
      <thead>
        <tr>
          <th>Variety class</th>
          <th>Typical days to maturity</th>
          <th>Typical GDD need</th>
          <th>Local fit</th>
        </tr>
      </thead>
      <tbody>
        {% for v in pageData.fit.varietyClassFits %}
          <tr>
            <td>{{ v.label }}</td>
            <td>{{ v.daysToMaturity or crop.daysToMaturityTypical or "—" }}</td>
            <td>{{ v.gddTarget }}</td>
            <td>
              {% if v.fitLabel == "good" %}
                Good fit
              {% elif v.fitLabel == "workable" %}
                Workable
              {% elif v.fitLabel == "tight" %}
                Tight
              {% elif v.fitLabel == "poor" %}
                Poor fit
              {% else %}
                —
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}

{% if pageData.fit.mainRiskSentence %}
  <p class="small muted">
    Main risk: {{ pageData.fit.mainRiskSentence }}
  </p>

<p>
  For a more detailed variety breakdown, see
  <a href="{{ pageData.url }}best-varieties/">best {{ cropSingularLower }} varieties for {{ pageData.cityName }}</a>.
</p>
{% endif %}
</section>

<section class="card">
  <h2>How Frost Affects Planting Dates for {{ cropName }} in {{ pageData.cityName }}</h2>

  <p>
    {{ pageData.cityName }} usually has about {{ pageData.frost.frostFreeDays }} frost-free days, with a typical last spring frost around {{ formatMmdd(pageData.frost.spring50) }} and a typical first fall frost around {{ formatMmdd(pageData.frost.fall50) }}.
  </p>

  {% if pageData.fit.protectionSentence %}
    <p>{{ pageData.fit.protectionSentence }}</p>
  {% endif %}

  <div class="quickStats">
    <div class="statCard">
      <span class="statLabel">Typical last spring frost</span>
      <strong>{{ formatMmdd(pageData.frost.spring50) }}</strong>
    </div>

    <div class="statCard">
      <span class="statLabel">Typical first fall frost</span>
      <strong>{{ formatMmdd(pageData.frost.fall50) }}</strong>
    </div>

    <div class="statCard">
      <span class="statLabel">Typical frost-free days</span>
      <strong>{{ pageData.frost.frostFreeDays }}</strong>
    </div>

    {% if crop.minSafeTempF != null %}
      <div class="statCard">
        <span class="statLabel">Minimum safe temperature</span>
        <strong>{{ crop.minSafeTempF }}°F / {{ fToC(crop.minSafeTempF) }}°C</strong>
      </div>
    {% endif %}
  </div>

  {% if frostLabel or crop.minSafeTempF != null %}
    <p>
      {% if frostLabel and crop.minSafeTempF != null %}
{{ cropSubjectLower | capitalize }} {{ cropVerb }} generally {{ frostLabel }} and temperatures below about {{ crop.minSafeTempF }}°F ({{ fToC(crop.minSafeTempF) }}°C) can slow growth or damage plants.
      {% elif frostLabel %}
{{ cropSubjectLower | capitalize }} {{ cropVerb }} generally {{ frostLabel }}.
      {% elif crop.minSafeTempF != null %}
        Temperatures below about {{ crop.minSafeTempF }}°F ({{ fToC(crop.minSafeTempF) }}°C) can slow growth or damage plants.
      {% endif %}
    </p>
  {% endif %}

    {% if pageData.fit.frostInterpretation %}
    <p>{{ pageData.fit.frostInterpretation }}</p>
  {% endif %}

  {% if pageData.advisory %}
    <p>{{ pageData.advisory.fail }}</p>
    <p>{{ pageData.advisory.micro }}</p>
  {% endif %}
</section>

<section class="card">
  <h2>Related crops</h2>

  {% if crop.relatedCrops and crop.relatedCrops.length %}
    <p>Related crops worth comparing for the same city:</p>
    <ul>
      {% for key in crop.relatedCrops %}
        <li>
          <a href="/planting-dates/{% if pageData.country == 'canada' %}canada/{% endif %}{{ pageData.regionKey }}/{{ pageData.cityKey }}/{{ key }}/">
            {{ key | replace("-", " ") | title }} in {{ pageData.cityName }}
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {% include "crop-city/modules/related-crops.njk" %}
  
</section>

<p class="small muted" style="margin-top:1rem;">
  For a broader local overview, see the
  <a href="/planting-dates/{% if pageData.country == 'canada' %}canada/{% endif %}{{ pageData.regionKey }}/{{ pageData.cityKey }}/">
    {{ pageData.cityName }} planting guide.</a>
  You can also use the <a href="/tools/growing-degree-day-planner/">Growing Degree Day Planner</a> to test planting dates and crop timing.
</p>
